---
const devFeatures = [
  {
    icon: `<path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>`,
    title: 'SDKs in 7 languages',
    desc: 'Node, Python, Go, Ruby, PHP, Java, .NET. Plus Shopify, Salesforce Commerce, and BigCommerce plugins.',
  },
  {
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
    title: 'Sandbox = production',
    desc: 'Test environment is byte-identical to live. Same latency profile. Same webhook timing. Test wallet passes on real devices.',
  },
  {
    icon: `<path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path d="M12 7v5l3 2"/>`,
    title: 'Versioning that respects your time',
    desc: 'API versions are date-pinned. Breaking changes never auto-apply. 18-month deprecation windows, minimum.',
  },
];
---

<section class="py-[120px] px-8 bg-[var(--bg-alt)]">
  <div class="max-w-layout mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] gap-20 items-center">

      <!-- Left copy -->
      <div>
        <div class="text-[13px] font-bold text-[var(--purple-deep)] uppercase tracking-[0.1em] mb-4">For developers</div>
        <h2 class="text-[clamp(32px,4vw,52px)] font-bold tracking-[-0.03em] leading-[1.05] text-[var(--ink)] mb-5">Built like you'd build it yourself.</h2>
        <p class="text-[19px] text-[var(--slate)] leading-[1.55]">
          Idempotent endpoints. Predictable errors. SDKs in seven languages. Sandbox parity. The kind of API you actually want to integrate.
        </p>

        <div class="flex flex-col gap-6 mt-8">
          {devFeatures.map(f => (
            <div class="flex gap-4 items-start">
              <div class="w-9 h-9 bg-white border border-[var(--line)] rounded-[10px] flex items-center justify-center text-[var(--purple-deep)] flex-shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={f.icon} />
              </div>
              <div>
                <h4 class="text-base font-bold mb-1">{f.title}</h4>
                <p class="text-sm text-[var(--slate)] leading-[1.55]">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Code block -->
      <div class="bg-[#0a0a23] rounded-2xl overflow-hidden" style="box-shadow: 0 24px 60px -20px rgba(10,10,35,0.3);">
        <div class="flex bg-white/[0.03] p-1 gap-0.5" id="dev-tabs">
          {['cURL', 'Node', 'Python', 'Go', 'Ruby'].map((lang, i) => (
            <button
              class={`px-3.5 py-2.5 font-mono text-[11px] rounded-t-md cursor-pointer border-none transition-colors duration-200 dev-tab-btn ${i === 0 ? 'bg-[#1a1a3e] text-[var(--purple-light)] active' : 'bg-transparent text-white/40'}`}
              data-tab={lang}
            >
              {lang}
            </button>
          ))}
        </div>
        <div class="dev-code-body">
<span class="code-line"><span class="tk-com"># Issue a $50 branded eGift, push to wallet, log to ledger</span></span>
<span class="code-line"><span class="tk-fn">curl</span> https://api.99minds.com/v1/gift_cards <span class="tk-punct">\</span></span>
<span class="code-line">  -u <span class="tk-str">sk_live_•••:</span> <span class="tk-punct">\</span></span>
<span class="code-line">  -H <span class="tk-str">"99minds-Version: 2026-04-01"</span> <span class="tk-punct">\</span></span>
<span class="code-line">  -d <span class="tk-str">amount=5000</span> <span class="tk-punct">\</span></span>
<span class="code-line">  -d <span class="tk-str">currency=usd</span> <span class="tk-punct">\</span></span>
<span class="code-line">  -d <span class="tk-str">recipient_email=ada@example.com</span> <span class="tk-punct">\</span></span>
<span class="code-line">  -d <span class="tk-str">design=brand_default</span> <span class="tk-punct">\</span></span>
<span class="code-line">  -d <span class="tk-str">wallet_pass=true</span></span>
<span class="code-line"> </span>
<span class="code-line"><span class="tk-com"># → 201 Created</span></span>
<span class="code-line"><span class="tk-punct">{</span></span>
<span class="code-line">  <span class="tk-key">"id"</span><span class="tk-punct">:</span> <span class="tk-str">"gc_8KPq2x9LmZ"</span><span class="tk-punct">,</span></span>
<span class="code-line">  <span class="tk-key">"amount"</span><span class="tk-punct">:</span> <span class="tk-num">5000</span><span class="tk-punct">,</span></span>
<span class="code-line">  <span class="tk-key">"currency"</span><span class="tk-punct">:</span> <span class="tk-str">"usd"</span><span class="tk-punct">,</span></span>
<span class="code-line">  <span class="tk-key">"status"</span><span class="tk-punct">:</span> <span class="tk-str">"active"</span><span class="tk-punct">,</span></span>
<span class="code-line">  <span class="tk-key">"wallet_pass_url"</span><span class="tk-punct">:</span> <span class="tk-str">"https://w.99m.co/p/8K..."</span><span class="tk-punct">,</span></span>
<span class="code-line">  <span class="tk-key">"created"</span><span class="tk-punct">:</span> <span class="tk-num">1746230400</span></span>
<span class="code-line"><span class="tk-punct">}</span></span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.dev-tab-btn');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('bg-[#1a1a3e]', 'text-[var(--purple-light)]', 'active');
        t.classList.add('bg-transparent', 'text-white/40');
      });
      tab.classList.add('bg-[#1a1a3e]', 'text-[var(--purple-light)]', 'active');
      tab.classList.remove('bg-transparent', 'text-white/40');
    });
  });
</script>
