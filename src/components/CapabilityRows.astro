---
import type { CapabilityRowConfig } from '../config/capabilityrows';

export interface Props {
  rows: CapabilityRowConfig[];
}

const { rows } = Astro.props;
---

<section class="bg-white py-[120px] px-8 max-sm:py-20 max-sm:px-5">
  <div class="mx-auto max-w-[1280px]">

    {rows.map((row) => (
      <div class="grid grid-cols-1 gap-20 items-center py-20 border-b border-[var(--line)] last:border-b-0 lg:grid-cols-2">

        <!-- Text column: always first in DOM; on reverse rows push to col 2 on desktop -->
        <div class={row.reverse ? 'lg:col-start-2 lg:row-start-1' : ''}>
          <div class="text-[12px] font-bold text-[var(--purple-deep)] uppercase tracking-[0.1em] mb-3">
            {row.eyebrow}
          </div>
          <h3 class="text-[36px] font-bold tracking-[-0.025em] leading-[1.1] text-[var(--ink)] mb-4 max-sm:text-[28px]">
            {row.title}
          </h3>
          <p class="text-[16px] text-[var(--slate)] leading-[1.6] mb-6">
            {row.description}
          </p>
          <ul class="list-none">
            {row.bullets.map(b => (
              <li class="flex gap-3 py-[10px] text-[14px] text-[var(--slate)] items-start">
                <span class="w-5 h-5 shrink-0 bg-[var(--purple-pale)] rounded-full flex items-center justify-center text-[var(--purple-deep)] font-bold text-[12px] mt-0.5">✓</span>
                <span set:html={b.html} />
              </li>
            ))}
          </ul>
          {row.ctaLabel && (
            <a href={row.ctaHref ?? '#'} class="mt-6 inline-flex items-center gap-[6px] text-[var(--purple-deep)] font-semibold text-[14px] no-underline transition-[gap] duration-200 hover:gap-[10px]">
              {row.ctaLabel} →
            </a>
          )}
        </div>

        <!-- Visual column: always second in DOM; on reverse rows pull to col 1 on desktop -->
        <div class={`bg-[var(--bg-alt)] border border-[var(--line)] rounded-[20px] p-8 min-h-[400px] relative overflow-hidden${row.reverse ? ' lg:col-start-1 lg:row-start-1' : ''}`}>

          {/* ── ML Personalization ─────────────────────── */}
          {row.visualSlot === 'ml-personalization' && (
            <div class="flex flex-col gap-3">
              {[
                { init: 'A', name: 'Ada · cus_8KPq2x',    meta: '12 orders · $2,840 LTV · Gold',  tag: 'Sure-thing',   tagBg: 'bg-[var(--purple-pale)]', tagColor: 'text-[var(--purple-deep)]',  sensLabel: 'Low (12%)',    sensColor: '#c8c8d8', barW: '12%', barGrad: 'linear-gradient(90deg,var(--purple-deep),var(--purple))', offerVal: 'Early access',    offerColor: '#2dba7c', offerNote: 'No discount needed',    avatarGrad: 'linear-gradient(135deg,#6f4dff,#aa8fff)' },
                { init: 'M', name: 'Marcus · cus_3Lm9zR',  meta: '3 orders · $410 LTV · Bronze',  tag: 'On the fence', tagBg: 'bg-[rgba(255,192,96,0.2)]', tagColor: 'text-[#b8761a]',            sensLabel: 'Medium (54%)', sensColor: '#f5a623', barW: '54%', barGrad: 'linear-gradient(90deg,#f5a623,#ffc060)',              offerVal: '15% off',         offerColor: '#f5a623', offerNote: '+$28 expected lift',    avatarGrad: 'linear-gradient(135deg,#ff8a7a,#ffc060)' },
                { init: 'P', name: 'Priya · cus_7Yp4kQ',   meta: '1 order · $89 LTV · New',       tag: 'Churn risk',   tagBg: 'bg-[rgba(255,138,122,0.2)]', tagColor: 'text-[#c44a3a]',           sensLabel: 'High (87%)',   sensColor: '#2dba7c', barW: '87%', barGrad: 'linear-gradient(90deg,#2dba7c,#7ef0c5)',              offerVal: '25% + free ship', offerColor: '#2dba7c', offerNote: 'High retention payoff', avatarGrad: 'linear-gradient(135deg,#00d4ff,#4a9eff)' },
              ].map(c => (
                <div class="bg-white border border-[var(--line)] rounded-[16px] overflow-hidden">
                  <div class="flex items-center gap-3 px-5 py-4 border-b border-[var(--line)]">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-[14px] shrink-0" style={`background:${c.avatarGrad}`}>{c.init}</div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[14px] font-bold leading-tight">{c.name}</div>
                      <div class="text-[11px] text-[var(--slate)] mt-0.5">{c.meta}</div>
                    </div>
                    <span class={`text-[10px] font-bold px-[10px] py-[4px] rounded-full whitespace-nowrap shrink-0 ${c.tagBg} ${c.tagColor}`}>{c.tag}</span>
                  </div>
                  <div class="grid grid-cols-2 divide-x divide-[var(--line)]">
                    <div class="px-5 py-4">
                      <div class="text-[10px] text-[var(--slate-light)] uppercase tracking-[0.08em] font-bold mb-2">Discount sensitivity</div>
                      <div class="text-[15px] font-bold mb-2" style={`color:${c.sensColor}`}>{c.sensLabel}</div>
                      <div class="h-[5px] bg-[var(--line)] rounded-full overflow-hidden">
                        <div class="h-full rounded-full" style={`width:${c.barW};background:${c.barGrad}`}></div>
                      </div>
                    </div>
                    <div class="px-5 py-4">
                      <div class="text-[10px] text-[var(--slate-light)] uppercase tracking-[0.08em] font-bold mb-2">Recommended offer</div>
                      <div class="text-[15px] font-bold mb-1" style={`color:${c.offerColor}`}>{c.offerVal}</div>
                      <div class="text-[11px] text-[var(--slate)]">{c.offerNote}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* ── A/B Testing ────────────────────────────── */}
          {row.visualSlot === 'ab-testing' && (
            <div>
              <div class="grid grid-cols-2 gap-3 mb-3">
                <!-- Variant A -->
                <div class="bg-white border border-[var(--line)] rounded-[14px] p-[18px]">
                  <div class="text-[11px] text-[var(--slate-light)] uppercase tracking-[0.08em] font-bold mb-2">Variant A</div>
                  <div class="text-[14px] font-bold mb-3">10% off all items</div>
                  {[['Visitors','6,420'],['Orders','412'],['AOV','$148']].map(([k,v]) => (
                    <div class="flex justify-between py-2 text-[12px] border-b border-[var(--line)] last:border-b-0">
                      <span class="text-[var(--slate)]">{k}</span><span class="font-bold">{v}</span>
                    </div>
                  ))}
                  <div class="mt-3 pt-3 border-t border-[var(--line)] text-center">
                    <div class="text-[28px] font-bold tracking-[-0.02em]">6.42%</div>
                    <div class="text-[11px] text-[var(--slate)] uppercase tracking-[0.06em] mt-0.5">Conversion rate</div>
                  </div>
                </div>
                <!-- Variant B (winner) -->
                <div class="relative bg-white rounded-[14px] p-[18px]" style="border:1px solid var(--accent-mint);background:linear-gradient(135deg,rgba(126,240,197,0.1),white);box-shadow:0 8px 24px -8px rgba(126,240,197,0.3)">
                  <div class="absolute -top-[8px] right-3 bg-[var(--ink)] text-white text-[10px] font-bold uppercase tracking-[0.1em] px-[10px] py-[3px] rounded-full">✓ Winner</div>
                  <div class="text-[11px] text-[var(--slate-light)] uppercase tracking-[0.08em] font-bold mb-2">Variant B</div>
                  <div class="text-[14px] font-bold mb-3">Free shipping over $100</div>
                  {[['Visitors','6,420'],['Orders','471'],['AOV','$162']].map(([k,v]) => (
                    <div class="flex justify-between py-2 text-[12px] border-b border-[var(--line)] last:border-b-0">
                      <span class="text-[var(--slate)]">{k}</span><span class="font-bold">{v}</span>
                    </div>
                  ))}
                  <div class="mt-3 pt-3 border-t border-[var(--line)] text-center">
                    <div class="text-[28px] font-bold tracking-[-0.02em]" style="color:#2dba7c">7.34%</div>
                    <div class="text-[11px] text-[var(--slate)] uppercase tracking-[0.06em] mt-0.5">Conversion rate</div>
                  </div>
                </div>
              </div>
              <div class="bg-white border border-[var(--line)] rounded-[10px] p-3 flex items-center gap-[10px] text-[12px] text-[var(--slate)]">
                <div class="w-6 h-6 rounded-[6px] flex items-center justify-center font-bold text-[12px] shrink-0" style="background:rgba(126,240,197,0.2);color:#1a8c5e">✓</div>
                <div><strong class="text-[var(--ink)]">Variant B wins by +14.3%</strong> · 99% confidence · Auto-rolling out to 100%</div>
              </div>
            </div>
          )}

          {/* ── Couponless Redemption ──────────────────── */}
          {row.visualSlot === 'couponless' && (
            <div class="flex flex-col gap-[10px]">
              {[
                { num: '1', title: 'Customer adds items to cart',            desc: 'Identity already known via session or login',    time: '12:04:11', highlight: false },
                { num: '2', title: '99minds evaluates eligibility in 38ms',  desc: 'Cart context + customer profile + active rules', time: '12:04:11', highlight: true  },
                { num: '3', title: 'Best-fit promotion auto-applies',         desc: '25% off + 2x points · "Spring Refresh" rule',   time: '12:04:12', highlight: false },
                { num: '4', title: 'No code shown · No code to leak',         desc: 'Honey extension finds nothing to scrape',       time: '12:04:12', highlight: false },
              ].map((step, i) => (
                <div class={`relative flex items-center gap-3 rounded-[12px] p-[14px_16px] ${step.highlight ? 'cf-highlight' : 'bg-white border border-[var(--line)]'} ${i > 0 ? 'cf-step' : ''}`}>
                  <div class={`w-8 h-8 rounded-[8px] shrink-0 flex items-center justify-center font-bold text-[13px] ${step.highlight ? 'bg-[var(--purple-deep)] text-white' : 'bg-[var(--purple-pale)] text-[var(--purple-deep)]'}`}>{step.num}</div>
                  <div class="flex-1">
                    <div class="text-[13px] font-bold">{step.title}</div>
                    <div class="text-[12px] text-[var(--slate)] mt-0.5">{step.desc}</div>
                  </div>
                  <div class="font-mono text-[11px] text-[var(--slate-light)] shrink-0">{step.time}</div>
                </div>
              ))}
            </div>
          )}

          {/* ── Bulk Gifting ──────────────────────────── */}
          {row.visualSlot === 'bulk-gifting' && (
            <div>
              <!-- Campaign header bar -->
              <div class="bg-white border border-[var(--line)] rounded-[12px] px-[18px] py-3.5 mb-3.5 flex items-center justify-between">
                <div>
                  <div class="text-[14px] font-bold">Q2 Employee Recognition</div>
                  <div class="text-[12px] text-[var(--slate)]">Scheduled for Apr 30, 2026 · 8:00 AM PST</div>
                </div>
                <span class="text-[11px] font-bold px-2 py-1 rounded-full bg-[rgba(126,240,197,0.2)] text-[#1a8c5e]">2,847 / 2,850</span>
              </div>
              <!-- Recipient table -->
              <div class="bg-white border border-[var(--line)] rounded-[12px] overflow-hidden text-[13px] mb-3.5">
                <!-- Header -->
                <div class="grid gap-3 px-4 py-3 bg-[var(--bg-alt)] text-[11px] font-bold uppercase tracking-[0.06em] text-[var(--slate-light)] border-b border-[var(--line)]" style="grid-template-columns: 24px 2fr 1fr 1fr 32px;">
                  <div></div><div>Recipient</div><div>Amount</div><div>Status</div><div></div>
                </div>
                {[
                  { name: 'Sarah Kim',      email: 'sarah.k@northwind.com',    amt: '$250',     status: 'sent',      label: 'Sent',      statusBg: 'bg-[rgba(126,240,197,0.2)] text-[#1a8c5e]' },
                  { name: 'Marcus Johnson', email: 'marcus.j@northwind.com',   amt: '$250',     status: 'sent',      label: 'Sent',      statusBg: 'bg-[rgba(126,240,197,0.2)] text-[#1a8c5e]' },
                  { name: 'Priya Patel',    email: 'priya.p@northwind.com',    amt: '$500',     status: 'queued',    label: 'Queued',    statusBg: 'bg-[var(--purple-pale)] text-[var(--purple-deep)]' },
                  { name: '+ 2,847 more',   email: 'Bulk recipients',          amt: '$250 avg', status: 'scheduled', label: 'Scheduled', statusBg: 'bg-[rgba(255,192,96,0.2)] text-[#b8761a]' },
                ].map(r => (
                  <div class="grid items-center gap-3 px-4 py-3 border-b border-[var(--line)] last:border-b-0" style="grid-template-columns: 24px 2fr 1fr 1fr 32px;">
                    <div class={`w-4 h-4 rounded flex items-center justify-center text-[10px] ${r.status === 'sent' ? 'bg-[var(--purple-deep)] text-white' : 'bg-white border border-[var(--line)]'}`}>{r.status === 'sent' ? '✓' : ''}</div>
                    <div>
                      <div class="font-semibold">{r.name}</div>
                      <div class="text-[11px] text-[var(--slate)]">{r.email}</div>
                    </div>
                    <div class="font-bold">{r.amt}</div>
                    <div><span class={`text-[11px] font-bold px-2 py-1 rounded-full whitespace-nowrap ${r.statusBg}`}>{r.label}</span></div>
                    <div class="text-right text-[var(--slate-light)]">···</div>
                  </div>
                ))}
              </div>
              <!-- Summary strip -->
              <div class="bg-white border border-[var(--line)] rounded-[12px] p-4 grid grid-cols-3 gap-3">
                {[['Recipients','2,850',''],['Total value','$712,500',''],['Delivery rate','99.8%','text-[#2dba7c]']].map(([label,val,color]) => (
                  <div>
                    <div class="text-[11px] text-[var(--slate-light)] uppercase tracking-[0.06em] font-semibold mb-1">{label}</div>
                    <div class={`text-[18px] font-bold tracking-[-0.02em] ${color}`}>{val}</div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* ── Refunds-as-Credit ─────────────────────── */}
          {row.visualSlot === 'refunds-as-credit' && (
            <div>
              <div class="flex flex-col gap-3.5">
                {[
                  { n: '1', title: 'Customer requests refund',              desc: "Order #NW-4291 · $185.00 · Reason: didn't fit",               highlight: false },
                  { n: '2', title: '99minds offers store credit + 15%',     desc: '"Get $212.75 in store credit instead — instantly"',           highlight: true  },
                  { n: '3', title: 'Customer accepts',                      desc: '63% accept on average — no cash leaves the business',         highlight: false },
                ].map((step, i) => (
                  <div class={`relative flex items-center gap-3.5 rounded-[12px] p-4 ${step.highlight ? 'refund-choice border-2 border-[var(--purple-deep)]' : 'bg-white border border-[var(--line)]'} ${i > 0 ? 'refund-step' : ''}`}>
                    <div class={`w-7 h-7 shrink-0 rounded-full flex items-center justify-center font-bold text-[12px] ${step.highlight ? 'bg-[var(--purple-deep)] text-white' : 'bg-[var(--purple-pale)] text-[var(--purple-deep)]'}`}>{step.n}</div>
                    <div class="flex-1">
                      <div class="text-[13px] font-bold">{step.title}</div>
                      <div class="text-[12px] text-[var(--slate)] mt-0.5">{step.desc}</div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-3.5 flex items-center gap-3 rounded-[12px] p-4" style="background:linear-gradient(135deg,var(--purple-pale),white);border:1px solid var(--purple-light)">
                <div class="w-9 h-9 shrink-0 rounded-[10px] bg-[var(--purple-deep)] flex items-center justify-center text-white">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
                <div>
                  <strong class="block text-[14px] text-[var(--ink)]">$212.75 credit issued · LTV +1.4×</strong>
                  <span class="text-[12px] text-[var(--slate)]">Customer redeems within 30 days · 81% of the time</span>
                </div>
              </div>
            </div>
          )}

          {/* ── Omnichannel ───────────────────────────── */}
          {row.visualSlot === 'omnichannel' && (
            <div class="grid grid-cols-2 gap-3">
              {[
                { icon: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 3 4 6.5 4 9s-1.5 6-4 9c-2.5-3-4-6.5-4-9s1.5-6 4-9z"/>',  name: 'Ecommerce',        meta: 'Shopify, BigCommerce, custom storefronts', tag: 'SDK · Plugin' },
                { icon: '<rect x="6" y="2" width="12" height="20" rx="2"/><path d="M11 18h2"/>',                                                 name: 'Mobile App',       meta: 'iOS, Android, React Native',              tag: 'SDK · Native' },
                { icon: '<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 8h18M7 18v3M17 18v3"/>',                                  name: 'Point of Sale',    meta: 'Square, Toast, Lightspeed, Clover',       tag: 'Plug-in · NFC' },
                { icon: '<rect x="6" y="3" width="12" height="18" rx="2"/><path d="M9 7h6M9 11h6M9 15h4"/>',                                    name: 'Mobile Wallet',    meta: 'Apple Wallet, Google Wallet',             tag: 'Pass · Push' },
                { icon: '<path d="M3 5h18v14H3z"/><path d="M3 9h18M7 5v14"/>',                                                                  name: 'Customer Support', meta: 'Zendesk, Intercom, Gladly',               tag: 'Embed · API' },
                { icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 9h10M7 13h6"/>',                                          name: 'Email & SMS',      meta: 'Klaviyo, Braze, Twilio',                  tag: 'Webhook' },
              ].map(ch => (
                <div class="bg-white border border-[var(--line)] rounded-[12px] p-[18px] transition-all hover:-translate-y-0.5 hover:border-[var(--purple)]">
                  <div class="w-9 h-9 bg-[var(--purple-pale)] rounded-[10px] flex items-center justify-center mb-3 text-[var(--purple-deep)]">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={ch.icon} />
                  </div>
                  <div class="text-[14px] font-bold">{ch.name}</div>
                  <div class="text-[12px] text-[var(--slate)] mt-1 leading-[1.5]">{ch.meta}</div>
                  <div class="mt-2.5 inline-block bg-[var(--bg-alt)] rounded-full px-2 py-0.5 text-[10px] font-semibold text-[var(--slate)]" style="font-family:'JetBrains Mono',monospace">{ch.tag}</div>
                </div>
              ))}
            </div>
          )}

          {/* ── Tiers ─────────────────────────────────── */}
          {row.visualSlot === 'tiers' && (
            <div class="flex flex-col gap-3">
              {[
                { level: 'bronze',   label: 'B', name: 'Bronze',   range: '0–999 pts',    perks: '5% discount · Free shipping over $50',          num: '63%', pct: 'of members', grad: 'linear-gradient(135deg,#cd7f32,#a0522d)',                        featured: false },
                { level: 'silver',   label: 'S', name: 'Silver',   range: '1k–4.9k pts',  perks: '10% discount · Early access · Free returns',    num: '25%', pct: 'of members', grad: 'linear-gradient(135deg,#b8b8c8,#808090)',                        featured: false },
                { level: 'gold',     label: 'G', name: 'Gold',     range: '5k–14.9k pts', perks: '15% discount · Dedicated support · Free returns',num: '9%',  pct: 'of members', grad: 'linear-gradient(135deg,var(--accent-gold),#ff9555)',             featured: true  },
                { level: 'platinum', label: 'P', name: 'Platinum', range: '15k+ pts',     perks: 'VIP concierge · Invite-only events · 25% off',   num: '3%',  pct: 'of members', grad: 'linear-gradient(135deg,var(--ink),var(--purple-deep))',           featured: false },
              ].map(t => (
                <div class={`bg-white border rounded-[14px] p-[18px] flex gap-4 items-center transition-transform hover:translate-x-1 ${t.featured ? 'border-[var(--purple-deep)] shadow-[0_8px_24px_-8px_rgba(111,77,255,0.2)]' : 'border-[var(--line)]'}`}>
                  <div class="w-[50px] h-[50px] rounded-full flex items-center justify-center text-white font-bold text-[18px] shrink-0" style={`background:${t.grad};${t.level==='gold'?'color:var(--ink)':''}`}>{t.label}</div>
                  <div class="flex-1">
                    <div class="text-[15px] font-bold tracking-[-0.01em]">{t.name}</div>
                    <div class="font-mono text-[11px] text-[var(--slate-light)] mt-0.5">{t.range}</div>
                    <div class="text-[12px] text-[var(--slate)] mt-1.5">{t.perks}</div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-[18px] font-bold tracking-[-0.01em]">{t.num}</div>
                    <div class="text-[10px] text-[var(--slate-light)] uppercase tracking-[0.06em]">{t.pct}</div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* ── Challenges ────────────────────────────── */}
          {row.visualSlot === 'challenges' && (
            <div class="grid grid-cols-2 gap-3 max-sm:grid-cols-1">
              {[
                { iconClass: '',      name: 'Birthday Boost',   desc: '2× points in your birthday month',    reward: '+500 pts', progress: 100, complete: true  },
                { iconClass: 'alt-1', name: 'Refer a Friend',   desc: 'Earn when your friend orders',         reward: '$10 GC',   progress: 50,  complete: false },
                { iconClass: 'alt-2', name: 'Category Sprint',  desc: 'Buy 3 items in Beauty this month',     reward: '+300 pts', progress: 67,  complete: false },
                { iconClass: 'alt-3', name: 'Review & Earn',    desc: 'Leave a verified review',              reward: '+100 pts', progress: 0,   complete: false },
              ].map(c => (
                <div class={`bg-white border rounded-[14px] p-[18px] transition-all hover:-translate-y-0.5 hover:border-[var(--purple)] ${c.complete ? 'border-[var(--purple-light)]' : 'border-[var(--line)]'}`} style={c.complete ? 'background:linear-gradient(135deg,var(--purple-pale),white)' : ''}>
                  <div class="flex justify-between items-start mb-3">
                    <div class={`ch-icon-${c.iconClass || 'default'} w-9 h-9 rounded-[10px] flex items-center justify-center text-white`} style={
                      c.iconClass === ''      ? 'background:linear-gradient(135deg,var(--purple-deep),var(--purple))' :
                      c.iconClass === 'alt-1' ? 'background:linear-gradient(135deg,var(--accent-coral),var(--accent-gold))' :
                      c.iconClass === 'alt-2' ? 'background:linear-gradient(135deg,var(--accent-cyan),#4a9eff)' :
                      'background:linear-gradient(135deg,var(--accent-mint),#4fd9b0);color:var(--ink)'
                    }>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2l2.5 7h7l-5.5 4.5 2 7L12 16l-6 4.5 2-7L2.5 9h7z"/></svg>
                    </div>
                    <span class="bg-[var(--ink)] text-white text-[10px] font-bold px-2 py-0.5 rounded-full">{c.reward}</span>
                  </div>
                  <div class="text-[14px] font-bold mb-1">{c.name}</div>
                  <div class="text-[12px] text-[var(--slate)] leading-[1.5] mb-3">{c.desc}</div>
                  <div class="h-[5px] bg-[var(--line)] rounded-full overflow-hidden">
                    <div class="h-full rounded-full" style={`width:${c.progress}%;background:linear-gradient(90deg,var(--purple-deep),var(--purple))`}></div>
                  </div>
                  <div class="flex justify-between mt-1.5 text-[11px] text-[var(--slate)] font-semibold">
                    <span>{c.complete ? 'Completed!' : 'In progress'}</span>
                    <span>{c.progress}%</span>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* ── Rewards Catalog ───────────────────────── */}
          {row.visualSlot === 'rewards' && (
            <div class="grid grid-cols-2 gap-3 max-sm:grid-cols-1">
              {[
                { name: '$10 Gift Card',       cost: '1,000 pts', claims: '2,340 claimed', grad: 'linear-gradient(135deg,var(--purple-deep),var(--purple))',         emoji: '🎁' },
                { name: 'Free Shipping Pass',  cost: '500 pts',   claims: '8,120 claimed', grad: 'linear-gradient(135deg,var(--accent-coral),var(--accent-gold))',   emoji: '📦' },
                { name: '25% Off Coupon',      cost: '2,000 pts', claims: '1,080 claimed', grad: 'linear-gradient(135deg,var(--accent-cyan),#4a9eff)',               emoji: '🏷️' },
                { name: 'VIP Event Access',    cost: '5,000 pts', claims: '340 claimed',   grad: 'linear-gradient(135deg,var(--ink),var(--purple-deep))',             emoji: '⭐' },
              ].map(r => (
                <div class="bg-white border border-[var(--line)] rounded-[14px] p-4 transition-all hover:-translate-y-0.5 hover:border-[var(--purple)]">
                  <div class="h-20 rounded-[10px] mb-3 flex items-center justify-center relative overflow-hidden reward-img-card" style={`background:${r.grad}`}>
                    <span class="text-[28px] relative z-10">{r.emoji}</span>
                  </div>
                  <div class="text-[13px] font-bold mb-1">{r.name}</div>
                  <div class="flex justify-between items-center mt-2">
                    <span class="text-[12px] font-bold text-[var(--purple-deep)]">⬟ {r.cost}</span>
                    <span class="text-[10px] text-[var(--slate-light)]">{r.claims}</span>
                  </div>
                </div>
              ))}
            </div>
          )}

        </div>
      </div>
    ))}

  </div>
</section>

