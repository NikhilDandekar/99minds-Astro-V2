---
---

<section class="relative overflow-hidden px-8 pt-12 pb-20 max-sm:px-5 max-sm:pt-8 max-sm:pb-14">

  <!-- mesh bg -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <div class="wh-mesh absolute" style="top:-10%;right:-15%;width:75%;height:100%;background:radial-gradient(ellipse at 30% 50%,rgba(170,143,255,0.32) 0%,transparent 50%),radial-gradient(ellipse at 70% 30%,rgba(126,240,197,0.22) 0%,transparent 50%),radial-gradient(ellipse at 50% 80%,rgba(0,212,255,0.22) 0%,transparent 50%);filter:blur(70px)"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1280px] grid grid-cols-1 gap-16 items-center lg:grid-cols-[1fr_1.05fr]">

    <!-- Left: text -->
    <div>
      <!-- pill -->
      <div class="inline-flex items-center gap-2 bg-white border border-[var(--line)] rounded-full px-3.5 py-[6px] text-[13px] font-semibold text-[var(--purple-deep)] mb-6 shadow-[0_1px_2px_rgba(10,10,35,0.04)]">
        <span class="w-[18px] h-[18px] rounded-[5px] flex items-center justify-center text-white" style="background:linear-gradient(135deg,var(--purple-deep),var(--purple))">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><rect x="6" y="2" width="12" height="20" rx="2"/><path d="M11 18h2"/></svg>
        </span>
        Mobile Wallet Passes
      </div>

      <h1 class="text-[clamp(44px,5.6vw,76px)] leading-none tracking-[-0.04em] font-bold text-[var(--ink)] mb-6">
        Live in your customer's <span style="background:linear-gradient(120deg,var(--purple-deep) 0%,var(--accent-mint) 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">wallet</span>. Forever.
      </h1>

      <p class="text-[19px] text-[var(--slate)] leading-[1.55] max-w-[540px] mb-8">
        Apple Wallet and Google Wallet passes that update in real time. The marketing channel your competitors haven't figured out — and it's already on every customer's phone.
      </p>

      <div class="flex gap-3 items-center mb-10">
        <a href="#" class="inline-flex items-center gap-[6px] font-semibold text-[15px] text-white rounded-full px-[22px] py-[14px] transition-all hover:-translate-y-px" style="background:var(--purple-deep)">Start free trial →</a>
        <a href="#" class="inline-flex items-center gap-[6px] font-semibold text-[15px] text-[var(--ink)] bg-white border border-[var(--line)] rounded-full px-[22px] py-[14px] transition-all hover:border-[var(--purple-deep)] hover:text-[var(--purple-deep)]">Try the designer</a>
      </div>

      <div class="flex flex-col gap-3">
        <div class="flex items-start gap-3 text-[14px] text-[var(--slate)]">
          <span class="w-[18px] h-[18px] shrink-0 bg-[var(--purple-pale)] rounded-full flex items-center justify-center text-[var(--purple-deep)] font-extrabold text-[11px] mt-0.5">✓</span>
          <div><strong class="text-[var(--ink)]">92% open rate on push notifications</strong> — vs 22% for email, 5% for SMS</div>
        </div>
        <div class="flex items-start gap-3 text-[14px] text-[var(--slate)]">
          <span class="w-[18px] h-[18px] shrink-0 bg-[var(--purple-pale)] rounded-full flex items-center justify-center text-[var(--purple-deep)] font-extrabold text-[11px] mt-0.5">✓</span>
          <div>Live balance updates across <strong class="text-[var(--ink)]">both Apple Wallet and Google Wallet</strong> in under 2 seconds</div>
        </div>
        <div class="flex items-start gap-3 text-[14px] text-[var(--slate)]">
          <span class="w-[18px] h-[18px] shrink-0 bg-[var(--purple-pale)] rounded-full flex items-center justify-center text-[var(--purple-deep)] font-extrabold text-[11px] mt-0.5">✓</span>
          <div><strong class="text-[var(--ink)]">Zero developer certificates to manage</strong> — we own the Apple Pass Type ID nightmare</div>
        </div>
      </div>
    </div>

    <!-- Right: phones visual -->
    <div class="relative h-[600px] max-sm:hidden">

      <!-- floating badge 1 -->
      <div class="wh-float absolute z-[5] flex items-center gap-2 bg-white rounded-full px-3.5 py-2 text-[12px] font-semibold shadow-[0_12px_32px_-8px_rgba(10,10,35,0.18),0_0_0_1px_var(--line)]" style="top:100px;left:-20px">
        <span class="w-2 h-2 rounded-full shrink-0 shadow-[0_0_0_4px_rgba(126,240,197,0.25)] wh-pulse" style="background:var(--accent-mint)"></span>
        Balance synced · 1.2s
      </div>

      <!-- Apple phone (back-left, rotated) -->
      <div class="absolute z-[1]" style="top:30px;left:0;width:280px;height:560px;border-radius:44px;background:linear-gradient(180deg,#2c2c2e 0%,#1a1a1c 100%);padding:12px;box-shadow:0 40px 80px -20px rgba(10,10,35,0.45),0 20px 40px -10px rgba(10,10,35,0.25),0 0 0 2px rgba(255,255,255,0.05) inset;transform:rotate(-6deg)">
        <div class="w-full h-full overflow-hidden relative" style="border-radius:32px;background:linear-gradient(180deg,#1c1c1e 0%,#2c2c2e 100%);color:white;padding:36px 14px 14px">
          <!-- notch -->
          <div class="absolute z-10 top-2 left-1/2 -translate-x-1/2 bg-black" style="width:90px;height:22px;border-radius:14px"></div>

          <!-- status bar -->
          <div class="flex justify-between items-center text-[11px] font-semibold px-2 pb-4">
            <span>9:41</span>
            <span>▂▄▆▇ 📶 🔋</span>
          </div>

          <!-- wallet title -->
          <div class="text-center text-[22px] font-bold tracking-[-0.01em] mb-3.5">Wallet</div>

          <!-- pass 1: Northwind Gold -->
          <div class="relative rounded-[14px] p-3.5 mb-2 overflow-hidden text-white" style="background:linear-gradient(135deg,#6f4dff 0%,#aa8fff 100%);box-shadow:0 8px 16px -4px rgba(0,0,0,0.3)">
            <div class="absolute" style="top:-30%;right:-15%;width:140px;height:140px;background:radial-gradient(circle,rgba(255,255,255,0.15) 0%,transparent 60%)"></div>
            <div class="relative flex justify-between items-start mb-3">
              <div class="text-[9px] font-bold uppercase tracking-[0.15em] opacity-85">NORTHWIND</div>
              <div class="w-[22px] h-[22px] rounded-full flex items-center justify-center font-extrabold text-[10px]" style="background:rgba(255,255,255,0.2)">N</div>
            </div>
            <div class="text-[8px] font-bold uppercase tracking-[0.1em] opacity-70 mb-0.5">Balance</div>
            <div class="text-[26px] font-bold tracking-[-0.02em] leading-none">$184.50</div>
            <div class="flex justify-between mt-3 text-[8px]">
              <div>
                <div class="opacity-70 uppercase tracking-[0.08em] font-bold">Member</div>
                <div class="font-bold text-[10px] mt-0.5">Gold · 2,840 pts</div>
              </div>
              <div class="text-right">
                <div class="opacity-70 uppercase tracking-[0.08em] font-bold">ID</div>
                <div class="font-bold text-[10px] mt-0.5">8KPQ2X</div>
              </div>
            </div>
            <div class="mt-2.5 rounded bg-white" style="height:36px;background-image:repeating-linear-gradient(90deg,#000 0,#000 1.5px,white 1.5px,white 3px,#000 3px,#000 4px,white 4px,white 7px,#000 7px,#000 8.5px,white 8.5px,white 11px),linear-gradient(white,white)"></div>
            <div class="text-center mt-1 opacity-70 text-[8px] font-semibold" style="font-family:'JetBrains Mono',monospace">NW-8KPQ2X</div>
          </div>

          <!-- pass 2: Verdant -->
          <div class="relative rounded-[14px] p-3.5 overflow-hidden text-white" style="background:linear-gradient(135deg,#0a0a23 0%,#6f4dff 100%);box-shadow:0 8px 16px -4px rgba(0,0,0,0.3)">
            <div class="flex justify-between items-start mb-3">
              <div class="text-[9px] font-bold uppercase tracking-[0.15em] opacity-85">VERDANT REWARDS</div>
              <div class="w-[22px] h-[22px] rounded-full flex items-center justify-center font-extrabold text-[10px] italic" style="background:rgba(255,255,255,0.2)">v</div>
            </div>
            <div class="text-[8px] font-bold uppercase tracking-[0.1em] opacity-70 mb-0.5">Points</div>
            <div class="text-[26px] font-bold tracking-[-0.02em] leading-none">1,420</div>
          </div>

          <!-- notification -->
          <div class="wh-notif absolute z-20 flex gap-2.5 items-center rounded-[14px] p-[10px_12px] text-white" style="top:80px;left:14px;right:14px;background:rgba(40,40,42,0.95);backdrop-filter:blur(20px)">
            <div class="w-8 h-8 rounded-[8px] flex items-center justify-center shrink-0 text-white" style="background:linear-gradient(135deg,#6f4dff,#aa8fff)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2l2.5 7h7l-5.5 4.5 2 7L12 16l-6 4.5 2-7L2.5 9h7z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-[9px] font-semibold uppercase tracking-[0.06em] opacity-70">Wallet</div>
              <div class="text-[11px] font-semibold mt-0.5 leading-[1.3]">Balance updated · $184.50</div>
            </div>
            <div class="text-[9px] opacity-50 shrink-0 self-start">now</div>
          </div>
        </div>
      </div>

      <!-- Google phone (front-right, rotated) -->
      <div class="absolute z-[2]" style="top:60px;right:0;width:280px;height:560px;border-radius:44px;background:linear-gradient(180deg,#2c2c2e 0%,#1a1a1c 100%);padding:12px;box-shadow:0 40px 80px -20px rgba(10,10,35,0.45),0 20px 40px -10px rgba(10,10,35,0.25),0 0 0 2px rgba(255,255,255,0.05) inset;transform:rotate(5deg)">
        <div class="w-full h-full overflow-hidden relative" style="border-radius:32px;background:#f8f9fa;padding:36px 14px 14px">
          <!-- notch -->
          <div class="absolute z-10 top-2 left-1/2 -translate-x-1/2 bg-black" style="width:90px;height:22px;border-radius:14px"></div>

          <!-- status bar -->
          <div class="flex justify-between items-center text-[11px] font-semibold px-2 pb-4 text-[var(--ink)]">
            <span>9:41</span>
            <span>📶 🔋</span>
          </div>

          <!-- wallet header -->
          <div class="flex items-center gap-2 px-2 mb-4">
            <div class="w-7 h-7 rounded-[8px] flex items-center justify-center text-white" style="background:linear-gradient(135deg,#4285F4,#34A853)">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="6" width="18" height="13" rx="2"/></svg>
            </div>
            <div class="text-[18px] font-semibold text-[var(--ink)]">Wallet</div>
          </div>

          <!-- Google pass -->
          <div class="bg-white rounded-[12px] overflow-hidden mb-2" style="box-shadow:0 2px 8px rgba(0,0,0,0.08)">
            <div class="relative overflow-hidden p-3.5 text-white" style="background:linear-gradient(135deg,#6f4dff 0%,#aa8fff 100%)">
              <div class="absolute" style="top:-40%;right:-20%;width:130px;height:130px;background:radial-gradient(circle,rgba(255,255,255,0.15),transparent 60%)"></div>
              <div class="relative flex items-center gap-2 mb-3.5">
                <div class="w-6 h-6 rounded-[6px] flex items-center justify-center font-extrabold text-[10px]" style="background:rgba(255,255,255,0.25)">N</div>
                <div class="text-[12px] font-bold">Northwind</div>
                <div class="ml-auto text-[9px] font-bold px-2 py-0.5 rounded-full" style="background:rgba(255,255,255,0.2)">★ GOLD</div>
              </div>
              <div class="text-[8px] font-bold uppercase tracking-[0.1em] opacity-80 mb-0.5">Store balance</div>
              <div class="text-[24px] font-bold tracking-[-0.02em] leading-none">$184.50</div>
              <div class="text-[10px] opacity-80 mt-1">+ 2,840 reward points</div>
            </div>
            <div class="p-3.5 text-[11px]">
              <div class="flex justify-between py-[6px] border-b" style="border-color:var(--line-soft)">
                <span class="text-[var(--slate)]">Member since</span>
                <span class="font-bold text-[var(--ink)]">Mar 2023</span>
              </div>
              <div class="flex justify-between py-[6px] border-b" style="border-color:var(--line-soft)">
                <span class="text-[var(--slate)]">Next tier in</span>
                <span class="font-bold text-[var(--ink)]">4,080 pts</span>
              </div>
              <div class="text-center pt-2.5 border-t mt-1.5" style="border-color:var(--line-soft)">
                <div class="w-20 h-20 mx-auto rounded bg-white border border-[var(--line)] p-1.5" style="background:repeating-conic-gradient(var(--ink) 0% 25%,white 0% 50%) 0 0/6px 6px"></div>
                <div class="mt-1 text-[9px] text-[var(--slate)] font-semibold" style="font-family:'JetBrains Mono',monospace">NW-8KPQ2X</div>
              </div>
            </div>
          </div>

          <!-- secondary pass -->
          <div class="bg-white rounded-[12px] p-[12px_14px] flex items-center gap-2.5" style="box-shadow:0 2px 8px rgba(0,0,0,0.06)">
            <div class="w-8 h-8 rounded-[8px] shrink-0" style="background:linear-gradient(135deg,var(--accent-coral),var(--accent-gold))"></div>
            <div class="flex-1 min-w-0">
              <div class="text-[12px] font-bold">Verdant Rewards</div>
              <div class="text-[10px] text-[var(--slate)] mt-0.5">1,420 points · Silver</div>
            </div>
            <div class="text-[var(--slate-light)] text-[14px]">›</div>
          </div>
        </div>
      </div>

      <!-- floating badge 2 -->
      <div class="wh-float absolute z-[5] flex items-center gap-2 bg-white rounded-full px-3.5 py-2 text-[12px] font-semibold shadow-[0_12px_32px_-8px_rgba(10,10,35,0.18),0_0_0_1px_var(--line)]" style="bottom:60px;right:-10px;animation-delay:2.5s">
        <span class="w-2 h-2 rounded-full shrink-0 shadow-[0_0_0_4px_rgba(126,240,197,0.25)] wh-pulse" style="background:var(--accent-mint)"></span>
        Pass installed · iOS + Android
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes whMeshShift {
    0%, 100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(-30px,20px) scale(1.05); }
  }
  .wh-mesh { animation: whMeshShift 22s ease-in-out infinite; }

  @keyframes whNotifSlide {
    0%, 20% { transform: translateY(-100px); opacity: 0; }
    30%, 80% { transform: translateY(0); opacity: 1; }
    90%, 100% { transform: translateY(-100px); opacity: 0; }
  }
  .wh-notif { animation: whNotifSlide 4s ease-in-out infinite; }

  @keyframes whFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .wh-float { animation: whFloat 5s ease-in-out infinite; }

  @keyframes whPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .wh-pulse { animation: whPulse 2s ease-in-out infinite; }
</style>
