---
---

<section class="relative overflow-hidden py-[64px] px-8 pb-[100px] max-sm:py-12 max-sm:px-5 max-sm:pb-16">

  <!-- mesh bg -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <div class="rh-mesh absolute" style="top:-10%;right:-10%;width:70%;height:100%;filter:blur(70px);background:radial-gradient(ellipse at 30% 50%,rgba(255,138,122,0.25) 0%,transparent 50%),radial-gradient(ellipse at 70% 30%,rgba(170,143,255,0.32) 0%,transparent 50%),radial-gradient(ellipse at 50% 80%,rgba(255,192,96,0.2) 0%,transparent 50%)"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1280px] grid gap-16 items-center" style="grid-template-columns:1.1fr 1fr">

    <!-- LEFT: copy -->
    <div>
      <div class="inline-flex items-center gap-2 bg-white border border-[var(--line)] px-4 py-1.5 rounded-full text-[13px] font-semibold text-[var(--ink)] mb-6 pl-2" style="box-shadow:0 1px 2px rgba(10,10,35,0.04)">
        <span class="bg-[var(--purple-deep)] text-white px-[10px] py-[3px] rounded-full text-[11px] font-bold uppercase tracking-[0.06em]">Retail</span>
        Built for apparel, beauty &amp; home brands
      </div>

      <h1 class="font-['Fraunces',Georgia,serif] font-semibold tracking-[-0.04em] text-[var(--ink)] mb-6 leading-none" style="font-size:clamp(44px,5.6vw,76px)">
        The reward stack <em class="font-['Fraunces',Georgia,serif] font-semibold italic" style="background:linear-gradient(120deg,var(--purple-deep) 0%,#ff8a7a 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">retail brands</em><br /> actually run on.
      </h1>

      <p class="text-[19px] text-[var(--slate)] leading-[1.55] max-w-[540px] mb-8">
        Gift cards that print money in November. Loyalty that brings them back in February. Promotions that don't bleed margin in May. One platform — sized for your peak, priced for your year.
      </p>

      <div class="flex gap-3 items-center mb-10">
        <a href="#" class="inline-flex items-center gap-1.5 font-semibold text-[15px] px-[22px] py-[14px] rounded-full text-white transition-all hover:bg-[var(--ink)] hover:-translate-y-px" style="background:var(--purple-deep)">Talk to retail team →</a>
        <a href="#" class="inline-flex items-center gap-1.5 font-semibold text-[15px] px-[22px] py-[14px] rounded-full bg-white text-[var(--ink)] border border-[var(--line)] transition-all hover:border-[var(--purple-deep)] hover:text-[var(--purple-deep)]">See retail demo</a>
      </div>

      <div class="flex items-center mb-6 gap-4 text-[13px] text-[var(--slate)]">
        <span><strong class="text-[var(--ink)] font-bold">600+</strong> retail brands</span>
        <span class="w-px h-[14px] bg-[var(--line)]"></span>
        <span><strong class="text-[var(--ink)] font-bold">$2.4B</strong> processed annually</span>
        <span class="w-px h-[14px] bg-[var(--line)]"></span>
        <span><strong class="text-[var(--ink)] font-bold">~14 days</strong> avg launch</span>
      </div>
    </div>

    <!-- RIGHT: dashboard + floating cards -->
    <div class="relative max-sm:hidden">

      <!-- floating card 1 -->
      <div class="rh-float absolute z-10 bg-white rounded-[14px] flex items-center gap-2.5 px-4 py-3" style="top:-16px;right:30px;box-shadow:0 16px 40px -10px rgba(10,10,35,0.18),0 0 0 1px var(--line);animation:rhFloat 5s ease-in-out infinite">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white flex-shrink-0" style="background:#ff8a7a">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l1-5h16l1 5"/><path d="M3 9v11h18V9"/></svg>
        </div>
        <div>
          <strong class="text-[13px] block font-semibold">$184k today</strong>
          <span class="text-[11px] text-[var(--slate)]">Black Friday peak</span>
        </div>
      </div>

      <!-- retail dashboard -->
      <div class="bg-white rounded-[20px] border border-[var(--line)] overflow-hidden" style="box-shadow:0 30px 60px -20px rgba(10,10,35,0.18);transform:perspective(1500px) rotateY(-3deg) rotateX(2deg)">

        <!-- toolbar -->
        <div class="flex items-center gap-2 px-4 py-3 bg-[var(--bg-alt)] border-b border-[var(--line)]">
          <span class="w-[10px] h-[10px] rounded-full" style="background:#ff8a7a"></span>
          <span class="w-[10px] h-[10px] rounded-full" style="background:#ffc060"></span>
          <span class="w-[10px] h-[10px] rounded-full" style="background:#7ef0c5"></span>
          <div class="flex-1 text-center text-[12px] text-[var(--slate)] font-semibold">app.99minds.com · Retail Dashboard</div>
        </div>

        <!-- body -->
        <div class="p-6">

          <!-- header row -->
          <div class="flex justify-between items-end mb-[18px]">
            <div>
              <div class="text-[16px] font-bold">Holiday performance</div>
              <div class="text-[12px] text-[var(--slate)] mt-0.5">Nov 1 – Dec 24, 2026</div>
            </div>
            <div class="flex items-center gap-1.5 px-[10px] py-1 rounded-full text-[11px] font-bold" style="background:rgba(126,240,197,0.2);color:#1a8c5e">
              <span class="w-1.5 h-1.5 rounded-full rh-pulse-dot" style="background:#1a8c5e"></span>
              Live
            </div>
          </div>

          <!-- stats grid -->
          <div class="grid grid-cols-3 gap-[10px] mb-5">
            {[
              { label: 'Gift card rev', val: '$1.4M',  delta: '↑ 38%' },
              { label: 'New members',   val: '12,840', delta: '↑ 22%' },
              { label: 'AOV uplift',    val: '+$28',   delta: 'via promos' },
            ].map(s => (
              <div class="bg-[var(--bg-alt)] border border-[var(--line)] rounded-[10px] p-3">
                <div class="text-[10px] text-[var(--slate-light)] uppercase tracking-[0.06em] font-semibold mb-1">{s.label}</div>
                <div class="text-[18px] font-bold tracking-[-0.02em]">{s.val}</div>
                <div class="text-[10px] font-semibold mt-0.5" style="color:#2dba7c">{s.delta}</div>
              </div>
            ))}
          </div>

          <!-- chart -->
          <div class="bg-[var(--bg-alt)] border border-[var(--line)] rounded-[10px] p-[14px] mb-4" style="height:130px">
            <svg width="100%" height="100%" viewBox="0 0 400 100" preserveAspectRatio="none">
              <defs>
                <linearGradient id="rdGrad" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#6f4dff" stop-opacity="0.3"/>
                  <stop offset="100%" stop-color="#6f4dff" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="M0,75 L25,72 L50,68 L75,70 L100,55 L125,52 L150,48 L175,40 L200,35 L225,42 L250,28 L275,15 L300,18 L325,10 L350,8 L375,12 L400,5 L400,100 L0,100 Z" fill="url(#rdGrad)"/>
              <path d="M0,75 L25,72 L50,68 L75,70 L100,55 L125,52 L150,48 L175,40 L200,35 L225,42 L250,28 L275,15 L300,18 L325,10 L350,8 L375,12 L400,5" stroke="#6f4dff" stroke-width="2" fill="none"/>
              <line x1="275" y1="0" x2="275" y2="100" stroke="#aa8fff" stroke-dasharray="3 3" opacity="0.5"/>
              <text x="280" y="14" font-family="Montserrat" font-size="9" fill="#6f4dff" font-weight="700">BFCM</text>
              <circle cx="400" cy="5" r="3" fill="#6f4dff"/>
            </svg>
          </div>

          <!-- segments -->
          <div class="flex flex-col gap-1.5">
            {[
              { color: '#6f4dff', name: 'Gold + Platinum',   val: '$842k', pct: '60%' },
              { color: '#ff8a7a', name: 'First-time gifters', val: '$420k', pct: '30%' },
            ].map(seg => (
              <div class="flex items-center gap-2.5 px-[10px] py-2 bg-[var(--bg-alt)] rounded-lg text-[12px]">
                <span class="w-[10px] h-[10px] rounded-full flex-shrink-0" style={`background:${seg.color}`}></span>
                <span class="flex-1 font-semibold">{seg.name}</span>
                <span class="font-bold text-[var(--ink)]">{seg.val}</span>
                <span class="text-[11px] text-[var(--slate)] ml-2">{seg.pct}</span>
              </div>
            ))}
          </div>

        </div>
      </div>

      <!-- floating card 2 -->
      <div class="absolute z-10 bg-white rounded-[14px] flex items-center gap-2.5 px-4 py-3" style="bottom:-16px;left:40px;box-shadow:0 16px 40px -10px rgba(10,10,35,0.18),0 0 0 1px var(--line);animation:rhFloat 5s ease-in-out infinite;animation-delay:2s">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white flex-shrink-0" style="background:var(--purple-deep)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <div>
          <strong class="text-[13px] block font-semibold">64% refund-to-credit</strong>
          <span class="text-[11px] text-[var(--slate)]">Jan returns recovered</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes rhMeshShift {
    0%, 100% { transform: translate(0,0) scale(1); }
    50%       { transform: translate(-30px,20px) scale(1.05); }
  }
  @keyframes rhFloat {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }
  @keyframes rhPulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }
  .rh-mesh       { animation: rhMeshShift 22s ease-in-out infinite; }
  .rh-pulse-dot  { animation: rhPulse 2s ease-in-out infinite; }
</style>
