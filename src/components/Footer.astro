---
const footerCols = [
  {
    heading: 'Products',
    links: [
      { label: 'Gift Cards', href: '/gift-cards' },
      { label: 'Store Credit', href: '/store-credit' },
      { label: 'Loyalty Engine', href: '/loyalty' },
      { label: 'Promotions', href: '/promotions' },
      { label: 'Wallet Passes', href: '/wallet-passes' },
    ],
  },
  {
    heading: 'Solutions',
    links: ['Retail & DTC', 'Restaurants', 'Travel', 'Banking', 'Marketplaces'],
  },
  {
    heading: 'Developers',
    links: ['Documentation', 'API Reference', 'SDKs', 'Changelog', 'Status'],
  },
  {
    heading: 'Company',
    links: ['About', 'Customers', 'Pricing', 'Careers', 'Contact'],
  },
];
---

<footer class="bg-[var(--ink)] text-white pt-20 pb-8 px-8">
  <div class="max-w-layout mx-auto">
    <!-- Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-[1.5fr_repeat(4,1fr)] gap-12 pb-14 border-b border-white/[0.08]">
      <!-- Brand col -->
      <div class="col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <span class="logo-mark" style="width:32px;height:32px;"></span>
          <span class="text-[22px] font-extrabold tracking-[-0.03em]">99minds</span>
        </div>
        <p class="text-white/55 text-sm leading-[1.55] max-w-[280px]">
          The complete customer value platform. Gift cards, loyalty, promotions, and mobile wallet — unified.
        </p>
      </div>

      <!-- Link cols -->
      {footerCols.map(col => (
        <div>
          <h4 class="text-[13px] font-bold uppercase tracking-[0.08em] mb-4 text-white/85">{col.heading}</h4>
          <ul class="list-none">
            {col.links.map(link => (
              <li class="mb-2.5">
                <a
  href={link.href}
  class="text-white/55 no-underline text-sm transition-colors duration-200 hover:text-white"
>
  {link.label}
</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex justify-between items-center mt-8 text-[13px] text-white/40">
      <div>© 2026 99minds, Inc. All rights reserved.</div>
      <div class="flex gap-6">
        <a href="#" class="text-white/40 no-underline hover:text-white/70 transition-colors">Privacy</a>
        <a href="#" class="text-white/40 no-underline hover:text-white/70 transition-colors">Terms</a>
        <a href="#" class="text-white/40 no-underline hover:text-white/70 transition-colors">Security</a>
      </div>
    </div>
  </div>
</footer>
