---
/**
 * GiftCardHero — exact layout match to .product-hero in original HTML.
 *
 * .product-hero: relative overflow-hidden padding: 48px 32px 80px
 * .product-hero-bg: absolute inset-0 z-0 overflow-hidden
 * .ph-mesh: absolute top:-10% right:-20% w:70% h:100% blur(70px) animated
 * .product-hero-inner: relative z-10 max-w-[1280px] mx-auto grid 1fr 1.05fr gap-16 items-center
 *   ≤1024: single col gap-12
 *
 * Left copy:
 *   .ph-product-pill: inline-flex items-center gap-2 bg-white border border-line px-3.5 py-1.5 rounded-pill text-[13px] font-semibold text-purple-deep mb-6 shadow-[0_1px_2px_rgba(10,10,35,0.04)]
 *   .ph-product-pill-icon: w-[18px] h-[18px] rounded-[5px] bg-grad flex items-center justify-center text-white
 *   h1: clamp(44px,5.6vw,76px) leading-[1] tracking-[-0.04em] font-bold text-ink mb-6
 *   .gradient: purple-deep → accent-coral
 *   .lede: text-[19px] text-slate leading-[1.55] max-w-[520px] mb-8
 *   .ph-actions: flex gap-3 items-center mb-10  (btn-purple lg + btn-outline lg)
 *   .ph-feature-list: flex flex-col gap-3
 *   .ph-feature-item: flex items-start gap-3 text-[14px] text-slate
 *   .ph-feature-check: w-[18px] h-[18px] flex-shrink-0 bg-purple-pale rounded-full flex items-center justify-center text-purple-deep font-extrabold text-[11px] mt-0.5
 *
 * Right visual .gift-stack:
 *   relative h-[520px] [perspective:1500px]
 *   ≤1024: scale(0.85) origin-top-left; ≤640: display:none
 *   .gift-card: absolute w-[380px] h-[240px] rounded-[18px] shadow-[0_30px_60px_-20px_rgba(10,10,35,0.35),inset_0_0_0_1px_rgba(255,255,255,0.08)] overflow-hidden transition duration-[600ms] cursor-pointer
 *   gc-1: bg purple grad, top:30 left:20 rotate(-8deg) z-10
 *   gc-2: bg dark grad, top:100 left:100 rotate(2deg) z-20
 *   gc-3: bg coral grad, top:200 left:60 rotate(-3deg) z-30
 *   hover fan-out via .gift-stack:hover .gc-N
 *   .gc-floating-info: absolute bg-white rounded-12 p-[14px_16px] shadow-[0_12px_32px_-8px_rgba(10,10,35,0.18),0_0_0_1px_#e8e6f5] text-[13px] z-40 flex items-center gap-2.5
 *   gc-floating-1: top:10 right:-10 animate-float
 *   gc-floating-2: bottom:30 right:30 animate-float-delay
 */
interface Feature { text: string; }
interface Props {
  pill?:         string;
  title?:        string;
  titleGradient?:string;
  lede?:         string;
  primaryCta?:   { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  features?:     Feature[];
}
const {
  pill          = 'Gift Cards & eGifts',
  title         = 'Gift cards your',
  titleGradient = 'brand deserves',
  lede          = 'Beautiful eGifts. PCI-compliant infrastructure. Bulk corporate gifting. Refunds-as-credit. Every channel, every currency, one API.',
  primaryCta    = { label:'Start free trial →', href:'#' },
  secondaryCta  = { label:'See live demo',       href:'#' },
  features      = [
    { text:'Launch a branded program in <strong>under 14 days</strong> — not 14 weeks' },
    { text:'PCI-DSS L1 + SOC 2 Type II from day one — <strong>no vendor risk review needed</strong>' },
    { text:'One ledger across <strong>web, mobile, POS, customer service, and wallet</strong>' },
  ],
} = Astro.props;
---

<section class="relative overflow-hidden px-8 pt-12 pb-20">
  <!-- Background mesh blob -->
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <div class="ph-mesh animate-mesh"></div>
  </div>

  <!-- Inner grid: 1fr 1.05fr, gap 64px, ≤1024 single col -->
  <div class="relative z-10 max-w-[1280px] mx-auto grid grid-cols-1 lg:[grid-template-columns:1fr_1.05fr] gap-16 items-center">

    <!-- ── Left copy ───────────────────────────── -->
    <div>
      <!-- Pill badge -->
      <div class="inline-flex items-center gap-2 bg-white border border-line px-3.5 py-1.5 rounded-pill text-[13px] font-semibold text-purple-deep mb-6"
           style="box-shadow:0 1px 2px rgba(10,10,35,0.04)">
        <div class="w-[18px] h-[18px] rounded-[5px] flex items-center justify-center text-white flex-shrink-0"
             style="background:linear-gradient(135deg,#6f4dff,#aa8fff)">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18M12 6v13"/>
          </svg>
        </div>
        {pill}
      </div>

      <!-- Headline: clamp(44px,5.6vw,76px) -->
      <h1 class="font-bold tracking-[-0.04em] leading-[1] text-ink mb-6"
          style="font-size:clamp(44px,5.6vw,76px)">
        {title} <span class="text-grad-gc">{titleGradient}</span>.
      </h1>

      <!-- Lede -->
      <p class="text-[19px] text-slate leading-[1.55] max-w-[520px] mb-8">{lede}</p>

      <!-- CTA buttons -->
      <div class="flex flex-wrap gap-3 items-center mb-10">
        <a href={primaryCta.href}
           class="font-semibold text-[15px] text-white bg-purple-deep px-[22px] py-[14px] rounded-pill no-underline transition-all duration-200 hover:bg-ink hover:-translate-y-px">
          {primaryCta.label}
        </a>
        {secondaryCta && (
          <a href={secondaryCta.href}
             class="font-semibold text-[15px] text-ink bg-white border border-line px-[22px] py-[14px] rounded-pill no-underline transition-all duration-200 hover:border-purple-deep hover:text-purple-deep">
            {secondaryCta.label}
          </a>
        )}
      </div>

      <!-- Feature checklist -->
      <div class="flex flex-col gap-3">
        {features.map(f => (
          <div class="flex items-start gap-3 text-[14px] text-slate">
            <div class="w-[18px] h-[18px] flex-shrink-0 bg-purple-pale rounded-full flex items-center justify-center text-purple-deep font-extrabold text-[11px] mt-0.5">✓</div>
            <div set:html={f.text}/>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Right: gift card stack ──────────────── -->
    <!--
      gift-stack: relative h-[520px] perspective-[1500px]
      ≤1024: scale(0.85) origin top-left
      ≤640: hidden
    -->
    <div class="gift-stack relative hidden sm:block lg:scale-100 scale-[0.85] origin-top-left"
         style="height:520px;perspective:1500px" aria-hidden="true">

      <!-- Floating badge 1 -->
      <div class="absolute top-[10px] right-[-10px] z-40 bg-white rounded-12 p-[14px_16px] flex items-center gap-2.5 text-[13px] animate-float"
           style="box-shadow:0 12px 32px -8px rgba(10,10,35,0.18),0 0 0 1px #e8e6f5">
        <div class="w-7 h-7 rounded-full flex items-center justify-center font-bold flex-shrink-0" style="background:#7ef0c5;color:#0a0a23">↑</div>
        <div>
          <div class="text-[10px] font-bold uppercase tracking-[0.06em] text-slate-light">Today's issuance</div>
          <div class="font-bold text-[13px] text-ink">$48,210</div>
        </div>
      </div>

      <!-- Gift card 1: purple grad, top:30 left:20 rotate(-8deg) z-10 -->
      <div class="gc-1 absolute rounded-[18px] overflow-hidden cursor-pointer"
           style="width:380px;height:240px;background:linear-gradient(135deg,#6f4dff 0%,#aa8fff 100%);top:30px;left:20px;transform:rotate(-8deg);z-index:10;box-shadow:0 30px 60px -20px rgba(10,10,35,0.35),inset 0 0 0 1px rgba(255,255,255,0.08);transition:transform 0.6s cubic-bezier(0.2,0.8,0.2,1)">
        <div class="relative w-full h-full flex flex-col justify-between text-white p-[26px_28px]">
          <div class="dot-pattern"></div>
          <div class="card-shine"></div>
          <div class="relative flex justify-between items-start">
            <div class="text-[10px] font-bold tracking-[0.2em] uppercase" style="opacity:0.85">NORTHWIND</div>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" opacity="0.7"><path d="M20 12V8H6a2 2 0 010-4h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/></svg>
          </div>
          <div>
            <div class="text-[44px] font-bold tracking-[-0.03em] leading-none">$50</div>
            <div class="text-[11px] mt-1.5" style="opacity:0.7">Just because.</div>
          </div>
          <div class="relative flex justify-between items-end font-mono text-[10px]" style="opacity:0.7">
            <div class="gc-chip"></div>
            <span>NW-7K2P9X</span>
          </div>
        </div>
      </div>

      <!-- Gift card 2: dark grad, top:100 left:100 rotate(2deg) z-20 -->
      <div class="gc-2 absolute rounded-[18px] overflow-hidden cursor-pointer"
           style="width:380px;height:240px;background:linear-gradient(135deg,#0a0a23 0%,#6f4dff 100%);top:100px;left:100px;transform:rotate(2deg);z-index:20;box-shadow:0 30px 60px -20px rgba(10,10,35,0.35),inset 0 0 0 1px rgba(255,255,255,0.08);transition:transform 0.6s cubic-bezier(0.2,0.8,0.2,1)">
        <div class="relative w-full h-full flex flex-col justify-between text-white p-[26px_28px]">
          <div class="dot-pattern"></div>
          <div class="card-shine"></div>
          <div class="relative flex justify-between items-start">
            <div class="text-[10px] font-bold tracking-[0.2em] uppercase" style="opacity:0.85">NORTHWIND · BIRTHDAY</div>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" opacity="0.7"><path d="M20 12V8H6a2 2 0 010-4h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/></svg>
          </div>
          <div>
            <div class="text-[44px] font-bold tracking-[-0.03em] leading-none">$100</div>
            <div class="text-[11px] mt-1.5" style="opacity:0.7">Happy birthday, Ada!</div>
          </div>
          <div class="relative flex justify-between items-end font-mono text-[10px]" style="opacity:0.7">
            <div class="gc-chip"></div>
            <span>NW-8KPQ2X</span>
          </div>
        </div>
      </div>

      <!-- Gift card 3: coral grad, top:200 left:60 rotate(-3deg) z-30 -->
      <div class="gc-3 absolute rounded-[18px] overflow-hidden cursor-pointer"
           style="width:380px;height:240px;background:linear-gradient(135deg,#ff8a7a 0%,#ffc060 100%);top:200px;left:60px;transform:rotate(-3deg);z-index:30;box-shadow:0 30px 60px -20px rgba(10,10,35,0.35),inset 0 0 0 1px rgba(255,255,255,0.08);transition:transform 0.6s cubic-bezier(0.2,0.8,0.2,1)">
        <div class="relative w-full h-full flex flex-col justify-between text-white p-[26px_28px]">
          <div class="dot-pattern"></div>
          <div class="card-shine"></div>
          <div class="relative flex justify-between items-start">
            <div class="text-[10px] font-bold tracking-[0.2em] uppercase" style="opacity:0.85">NORTHWIND · SUMMER</div>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" opacity="0.7"><path d="M20 12V8H6a2 2 0 010-4h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/></svg>
          </div>
          <div>
            <div class="text-[44px] font-bold tracking-[-0.03em] leading-none">$25</div>
            <div class="text-[11px] mt-1.5" style="opacity:0.7">Refund credit · Order #4291</div>
          </div>
          <div class="relative flex justify-between items-end font-mono text-[10px]" style="opacity:0.7">
            <div class="gc-chip"></div>
            <span>NW-9LMNZ4</span>
          </div>
        </div>
      </div>

      <!-- Floating badge 2 -->
      <div class="absolute z-40 bg-white rounded-12 p-[14px_16px] flex items-center gap-2.5 text-[13px] animate-float-delay"
           style="bottom:30px;right:30px;box-shadow:0 12px 32px -8px rgba(10,10,35,0.18),0 0 0 1px #e8e6f5">
        <div class="w-7 h-7 rounded-full bg-purple-deep flex items-center justify-center flex-shrink-0">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <div>
          <div class="text-[10px] font-bold uppercase tracking-[0.06em] text-slate-light">Redemption rate</div>
          <div class="font-bold text-[13px] text-ink">73.4%</div>
        </div>
      </div>

    </div>
  </div>
</section>
