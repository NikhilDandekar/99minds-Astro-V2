---
/**
 * GiftCardCapabilities.astro
 * Three alternating capability rows specific to the Gift Cards product page:
 *  1. Bulk / B2B gifting  (text-left, visual-right)
 *  2. Refunds-as-credit   (text-right, visual-left — reverse)
 *  3. Omnichannel         (text-left, visual-right)
 *
 * The inline visuals are purpose-built for each row and rely only on CSS
 * custom properties defined in global.css, so they blend perfectly with
 * the shared site theme.
 */
---

<section class="capabilities">
  <div class="container">

    <!-- ── ROW 1: Bulk / B2B gifting ─────────────── -->
    <div class="cap-row">
      <div class="cap-text">
        <div class="cap-eyebrow">Corporate & B2B Gifting</div>
        <h3>Send 10,000 gift cards by Friday.</h3>
        <p>
          Upload a CSV, schedule the send, watch them deliver. Custom branding per program,
          per-recipient personalisation, and white-glove approval workflows when finance needs to
          sign off.
        </p>
        <ul class="cap-bullet-list">
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Programmatic CSV upload</strong> with field mapping and dry-run preview</span>
          </li>
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Multi-step approval</strong> — finance signs off before mass-issuance</span>
          </li>
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Volume pricing &amp; invoicing</strong> for orders of 1,000+ at a time</span>
          </li>
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Real-time delivery dashboard</strong> with bounce/open/redemption tracking</span>
          </li>
        </ul>
        <a href="#" class="cap-link">Learn about bulk gifting →</a>
      </div>

      <div class="cap-visual">
        <!-- Campaign header bar -->
        <div class="bulk-campaign-bar">
          <div>
            <div class="bulk-campaign-name">Q2 Employee Recognition</div>
            <div class="bulk-campaign-sub">Scheduled for Apr 30, 2026 · 8:00 AM PST</div>
          </div>
          <span class="bulk-status sent">2,847 / 2,850</span>
        </div>

        <!-- Recipient table -->
        <div class="bulk-table">
          <div class="bulk-row header">
            <div></div>
            <div>Recipient</div>
            <div>Amount</div>
            <div>Status</div>
            <div></div>
          </div>
          {[
            { name: 'Sarah Kim',    email: 'sarah.k@northwind.com',   amt: '$250', status: 'sent',      label: 'Sent' },
            { name: 'Marcus Johnson', email: 'marcus.j@northwind.com', amt: '$250', status: 'sent',    label: 'Sent' },
            { name: 'Priya Patel', email: 'priya.p@northwind.com',    amt: '$500', status: 'queued',   label: 'Queued' },
            { name: '+ 2,847 more', email: 'Bulk recipients',         amt: '$250 avg', status: 'scheduled', label: 'Scheduled' },
          ].map(r => (
            <div class="bulk-row">
              <div class={`bulk-checkbox${r.status !== 'sent' ? ' empty' : ''}`}>
                {r.status === 'sent' ? '✓' : ''}
              </div>
              <div>
                <div class="bulk-name">{r.name}</div>
                <div class="bulk-email">{r.email}</div>
              </div>
              <div class="bulk-amt">{r.amt}</div>
              <div><span class={`bulk-status ${r.status}`}>{r.label}</span></div>
              <div class="bulk-more">···</div>
            </div>
          ))}
        </div>

        <!-- Summary strip -->
        <div class="bulk-summary">
          <div class="bulk-summary-item">
            <div class="stat-label-sm">Recipients</div>
            <div class="stat-value-md">2,850</div>
          </div>
          <div class="bulk-summary-item">
            <div class="stat-label-sm">Total value</div>
            <div class="stat-value-md">$712,500</div>
          </div>
          <div class="bulk-summary-item">
            <div class="stat-label-sm">Delivery rate</div>
            <div class="stat-value-md green">99.8%</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── ROW 2: Refunds-as-credit (reversed) ───── -->
    <div class="cap-row reverse">
      <div class="cap-text">
        <div class="cap-eyebrow">Refunds-as-Credit</div>
        <h3>Recover 60% of refund revenue.</h3>
        <p>
          When a customer wants a refund, offer them store credit instead — with a small bonus. Most
          accept. Cash stays in your business, lifetime value goes up, and customer satisfaction
          climbs because you said "yes" to credit instead of "wait 5–7 days" to a refund.
        </p>
        <ul class="cap-bullet-list">
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Dynamic incentives</strong> — offer +10%, +15%, or +20% bonus tuned to LTV</span>
          </li>
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Embedded in returns flow</strong> — Shopify, Loop, Returnly, custom portals</span>
          </li>
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Auto-credit instead of refund</strong> for damaged or late shipments</span>
          </li>
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Full audit trail</strong> from return reason to credit issuance to redemption</span>
          </li>
        </ul>
        <a href="#" class="cap-link">Learn about refunds-as-credit →</a>
      </div>

      <div class="cap-visual">
        <div class="refund-flow">
          {[
            { n: '1', title: 'Customer requests refund',       desc: 'Order #NW-4291 · $185.00 · Reason: didn\'t fit', highlight: false },
            { n: '2', title: '99minds offers store credit + 15%', desc: '"Get $212.75 in store credit instead — instantly"', highlight: true },
            { n: '3', title: 'Customer accepts',               desc: '63% accept on average — no cash leaves the business', highlight: false },
          ].map(step => (
            <div class={`flow-step${step.highlight ? ' choice' : ''}`}>
              <div class="flow-num">{step.n}</div>
              <div class="flow-content">
                <div class="flow-title">{step.title}</div>
                <div class="flow-desc">{step.desc}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="flow-result">
          <div class="flow-result-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
          </div>
          <div class="flow-result-text">
            <strong>$212.75 credit issued · LTV +1.4×</strong>
            <span>Customer redeems within 30 days · 81% of the time</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── ROW 3: Omnichannel ─────────────────────── -->
    <div class="cap-row">
      <div class="cap-text">
        <div class="cap-eyebrow">Omnichannel</div>
        <h3>Issue anywhere. Redeem everywhere.</h3>
        <p>
          One balance, one ledger. A card sold online redeems at the POS. A refund issued by
          support shows up in the wallet. No reconciliation hell. No "sorry, we can't see that on
          this system."
        </p>
        <ul class="cap-bullet-list">
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Real-time balance sync</strong> across web, mobile, POS, support, and wallet</span>
          </li>
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Pre-built integrations</strong> with Shopify, BigCommerce, Salesforce, Square, Toast</span>
          </li>
          <li class="cap-bullet">
            <span class="cap-bullet-icon">✓</span>
            <span><strong>Customer service tools</strong> — issue, void, reissue, transfer in two clicks</span>
          </li>
        </ul>
        <a href="#" class="cap-link">See all integrations →</a>
      </div>

      <div class="cap-visual">
        <div class="channel-grid">
          {[
            { icon: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 3 4 6.5 4 9s-1.5 6-4 9c-2.5-3-4-6.5-4-9s1.5-6 4-9z"/>', name: 'Ecommerce',       meta: 'Shopify, BigCommerce, custom storefronts', tag: 'SDK · Plugin' },
            { icon: '<rect x="6" y="2" width="12" height="20" rx="2"/><path d="M11 18h2"/>',                                                 name: 'Mobile App',      meta: 'iOS, Android, React Native',              tag: 'SDK · Native' },
            { icon: '<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 8h18M7 18v3M17 18v3"/>',                                  name: 'Point of Sale',   meta: 'Square, Toast, Lightspeed, Clover',       tag: 'Plug-in · NFC' },
            { icon: '<rect x="6" y="3" width="12" height="18" rx="2"/><path d="M9 7h6M9 11h6M9 15h4"/>',                                    name: 'Mobile Wallet',   meta: 'Apple Wallet, Google Wallet',             tag: 'Pass · Push' },
            { icon: '<path d="M3 5h18v14H3z"/><path d="M3 9h18M7 5v14"/>',                                                                  name: 'Customer Support',meta: 'Zendesk, Intercom, Gladly',               tag: 'Embed · API' },
            { icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 9h10M7 13h6"/>',                                          name: 'Email & SMS',     meta: 'Klaviyo, Braze, Twilio',                  tag: 'Webhook' },
          ].map(ch => (
            <div class="channel-card">
              <div class="channel-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={ch.icon} />
              </div>
              <div class="channel-name">{ch.name}</div>
              <div class="channel-meta">{ch.meta}</div>
              <div class="channel-tag">{ch.tag}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .capabilities { background: white; padding: 120px 32px; }

  .container { max-width: 1280px; margin: 0 auto; }

  /* ── Alternating rows ───────────────────────── */
  .cap-row {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 80px;
    align-items: center;
    padding: 80px 0;
    border-bottom: 1px solid var(--line);
  }

  .cap-row:last-child { border-bottom: none; }
  .cap-row.reverse { direction: rtl; }
  .cap-row.reverse > * { direction: ltr; }

  /* Text column */
  .cap-eyebrow {
    font-size: 12px; font-weight: 700; color: var(--purple-deep);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;
  }

  .cap-text h3 {
    font-size: 36px; font-weight: 700; letter-spacing: -0.025em;
    line-height: 1.1; margin-bottom: 16px;
  }

  .cap-text p {
    font-size: 16px; color: var(--slate); line-height: 1.6; margin-bottom: 24px;
  }

  .cap-bullet-list { list-style: none; }

  .cap-bullet {
    display: flex; gap: 12px; padding: 10px 0;
    font-size: 14px; color: var(--slate); align-items: flex-start;
  }

  .cap-bullet-icon {
    width: 20px; height: 20px; flex-shrink: 0;
    background: var(--purple-pale); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--purple-deep); font-weight: 700; font-size: 12px;
    margin-top: 2px;
  }

  .cap-bullet strong { color: var(--ink); }

  .cap-link {
    margin-top: 24px;
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--purple-deep); font-weight: 600; font-size: 14px;
    text-decoration: none; transition: gap 0.2s;
  }

  .cap-link:hover { gap: 10px; }

  /* Visual column shared shell */
  .cap-visual {
    background: var(--bg-alt);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 32px;
    min-height: 400px;
    position: relative;
    overflow: hidden;
  }

  /* ── Bulk gifting visual ────────────────────── */
  .bulk-campaign-bar {
    background: white; border-radius: 12px; border: 1px solid var(--line);
    padding: 14px 18px; margin-bottom: 14px;
    display: flex; align-items: center; justify-content: space-between;
  }

  .bulk-campaign-name { font-size: 14px; font-weight: 700; }
  .bulk-campaign-sub  { font-size: 12px; color: var(--slate); }

  .bulk-table {
    background: white; border-radius: 12px; border: 1px solid var(--line);
    overflow: hidden; font-size: 13px;
  }

  .bulk-row {
    display: grid;
    grid-template-columns: 24px 2fr 1fr 1fr 32px;
    gap: 12px;
    padding: 12px 16px;
    align-items: center;
    border-bottom: 1px solid var(--line);
  }

  .bulk-row:last-child { border-bottom: none; }

  .bulk-row.header {
    background: var(--bg-alt);
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--slate-light);
  }

  .bulk-checkbox {
    width: 16px; height: 16px;
    background: var(--purple-deep); border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 10px; flex-shrink: 0;
  }

  .bulk-checkbox.empty { background: white; border: 1px solid var(--line); }

  .bulk-name   { font-weight: 600; font-size: 13px; }
  .bulk-email  { font-size: 11px; color: var(--slate); }
  .bulk-amt    { font-weight: 700; }
  .bulk-more   { text-align: right; color: var(--slate-light); }

  .bulk-status {
    font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 999px;
    white-space: nowrap;
  }

  .bulk-status.sent      { background: rgba(126,240,197,.2); color: #1a8c5e; }
  .bulk-status.queued    { background: var(--purple-pale); color: var(--purple-deep); }
  .bulk-status.scheduled { background: rgba(255,192,96,.2); color: #b8761a; }

  .bulk-summary {
    margin-top: 16px;
    background: white; border-radius: 12px; border: 1px solid var(--line);
    padding: 16px;
    display: grid; grid-template-columns: repeat(3,1fr); gap: 12px;
  }

  .stat-label-sm {
    font-size: 11px; color: var(--slate-light);
    text-transform: uppercase; letter-spacing: 0.06em;
    font-weight: 600; margin-bottom: 4px;
  }

  .stat-value-md { font-size: 18px; font-weight: 700; letter-spacing: -0.02em; }
  .stat-value-md.green { color: #2dba7c; }

  /* ── Refund flow visual ─────────────────────── */
  .refund-flow { display: flex; flex-direction: column; gap: 14px; }

  .flow-step {
    background: white; border-radius: 12px; border: 1px solid var(--line);
    padding: 16px;
    display: flex; align-items: center; gap: 14px;
    position: relative;
  }

  .flow-step + .flow-step::before {
    content: ''; position: absolute;
    top: -14px; left: 32px;
    width: 1px; height: 14px;
    background: var(--purple);
  }

  .flow-step.choice {
    border-color: var(--purple-deep);
    border-width: 2px;
    box-shadow: 0 4px 16px -4px rgba(111,77,255,.2);
  }

  .flow-num {
    width: 28px; height: 28px; flex-shrink: 0;
    background: var(--purple-pale); color: var(--purple-deep);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 12px;
  }

  .flow-step.choice .flow-num { background: var(--purple-deep); color: white; }

  .flow-content { flex: 1; }
  .flow-title { font-size: 13px; font-weight: 700; }
  .flow-desc  { font-size: 12px; color: var(--slate); margin-top: 2px; }

  .flow-result {
    margin-top: 14px;
    background: linear-gradient(135deg, var(--purple-pale), white);
    border: 1px solid var(--purple-light);
    border-radius: 12px; padding: 16px;
    display: flex; gap: 12px; align-items: center;
  }

  .flow-result-icon {
    width: 36px; height: 36px;
    background: var(--purple-deep); border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: white; flex-shrink: 0;
  }

  .flow-result-text strong { display: block; font-size: 14px; color: var(--ink); }
  .flow-result-text span   { font-size: 12px; color: var(--slate); }

  /* ── Omnichannel grid ───────────────────────── */
  .channel-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 12px; }

  .channel-card {
    background: white; border-radius: 12px; border: 1px solid var(--line);
    padding: 18px; transition: all 0.25s;
  }

  .channel-card:hover { border-color: var(--purple); transform: translateY(-2px); }

  .channel-icon-wrap {
    width: 36px; height: 36px;
    background: var(--purple-pale); border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px; color: var(--purple-deep);
  }

  .channel-name { font-size: 14px; font-weight: 700; }
  .channel-meta { font-size: 12px; color: var(--slate); margin-top: 4px; line-height: 1.5; }

  .channel-tag {
    display: inline-block; margin-top: 10px;
    background: var(--bg-alt); padding: 3px 8px; border-radius: 999px;
    font-size: 10px; color: var(--slate); font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .cap-row { grid-template-columns: 1fr; gap: 48px; }
    .cap-row.reverse { direction: ltr; }
    .capabilities { padding: 80px 20px; }
  }
</style>
