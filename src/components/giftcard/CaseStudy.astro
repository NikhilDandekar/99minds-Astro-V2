---
interface Metric {
  value: string;
  label: string;
}

interface Props {
  variant?: "card" | "simple";
  eyebrow?: string;
  title?: string;
  quote?: string;
  authorInitials?: string;
  authorName?: string;
  authorRole?: string;
  avatarGradient?: string;
  avatarClass?: string;
  metrics?: Metric[];
  bgClass?: string;
}

const {
  variant = "card",
  eyebrow = "Case study",
  title = "Northwind increased gift card revenue 3x in one quarter.",
  quote = "We were stuck on a legacy system that couldn't handle Apple Wallet. 99minds had us live in 3 weeks. Our gift card sales jumped from 8% to 24% of revenue. The breakage reporting alone saved us hours every month.",
  authorInitials = "SM",
  authorName = "Sarah Mitchell",
  authorRole = "Director of Finance, Northwind Retail",
  avatarGradient = "linear-gradient(135deg, #6f4dff, #00d4ff)",
  avatarClass,
  metrics = [
    { value: "3×", label: "Gift card revenue growth" },
    { value: "62%", label: "Customers use Wallet passes" },
    { value: "12 hrs", label: "Saved per month on reconciliation" },
  ],
  bgClass = "bg-white",
} = Astro.props;
---

{
  variant === "simple" ? (
    <section class={`py-[120px] px-8 max-sm:py-20 max-sm:px-5 ${bgClass}`}>
      <div class="max-w-[1280px] mx-auto">
        <div class="max-w-[900px] mx-auto text-center">
          <div class="text-[80px] leading-[0.5] text-purple font-serif">"</div>
          <p class="quote-text font-medium text-ink tracking-[-0.02em] my-8">{quote}</p>
          <div class="flex items-center justify-center gap-3.5">
            <div
              class={`${avatarClass ?? ""} w-12 h-12 rounded-full flex items-center justify-center text-white font-bold`}
              style={avatarClass ? undefined : `background: ${avatarGradient};`}
            >
              {authorInitials}
            </div>
            <div class="text-left">
              <div class="font-bold text-sm">{authorName}</div>
              <div class="text-[13px] text-slate">{authorRole}</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class={`py-[120px] px-8 max-sm:py-20 max-sm:px-5 ${bgClass}`}>
      <div class="max-w-[900px] mx-auto">
        <div class="text-center mb-12">
          <div class="text-[13px] font-bold text-purple-deep uppercase tracking-[0.1em] mb-4">
            {eyebrow}
          </div>
          <h2 class="section-title font-bold text-ink tracking-[-0.03em]">{title}</h2>
        </div>

        <div class="bg-bg-alt border border-line rounded-2xl p-10">
          <div class="text-[80px] leading-[0.5] text-purple font-serif mb-8">"</div>
          <p class="text-[22px] leading-relaxed text-ink font-medium tracking-[-0.01em] mb-8">
            {quote}
          </p>
          <div class="flex items-center gap-4">
            <div
              class={`${avatarClass ?? ""} w-14 h-14 rounded-full flex items-center justify-center text-white font-bold text-lg`}
              style={avatarClass ? undefined : `background: ${avatarGradient};`}
            >
              {authorInitials}
            </div>
            <div>
              <div class="font-bold text-sm">{authorName}</div>
              <div class="text-[13px] text-slate">{authorRole}</div>
            </div>
          </div>

          {metrics && metrics.length > 0 && (
            <div class="grid grid-cols-3 gap-6 mt-10 pt-10 border-t border-line">
              {metrics.map((m) => (
                <div>
                  <div class="text-3xl font-bold text-purple-deep mb-1">{m.value}</div>
                  <div class="text-sm text-slate">{m.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )
}
