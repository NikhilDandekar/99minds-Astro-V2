---
interface CtaButton {
  label: string;
  href: string;
  variant?: "primary" | "ghost";
}

interface Props {
  titleLead?: string;
  titleHighlight?: string;
  titleTail?: string;
  description?: string;
  buttons?: CtaButton[];
  bgClass?: string;
  titleClass?: string;
}

const {
  titleLead = "Launch gift cards in ",
  titleHighlight = "a sprint",
  titleTail = ", not a quarter.",
  description = "Start with sandbox keys. Talk to sales when you're ready to go live.",
  buttons = [
    { label: "Start building →", href: "#", variant: "primary" },
    { label: "See pricing", href: "#", variant: "ghost" },
  ],
  bgClass = "bg-white",
  titleClass = "section-title",
} = Astro.props;
---

<div
  class={`final-glow py-[120px] px-8 max-sm:py-20 max-sm:px-5 text-center ${bgClass} relative overflow-hidden`}
>
  <div class="relative max-w-[720px] mx-auto">
    <h2 class={`${titleClass} font-bold tracking-[-0.03em] leading-tight mb-5`}>
      {titleLead}<span class="text-purple-deep">{titleHighlight}</span>{titleTail}
    </h2>
    <p class="text-[19px] text-slate mb-9">{description}</p>
    <div class="flex gap-3 justify-center flex-wrap">
      {
        buttons.map((btn) => (
          <a
            href={btn.href}
            class={
              btn.variant === "ghost"
                ? "font-semibold text-[15px] px-[22px] py-[14px] rounded-full bg-transparent text-ink hover:bg-line-soft transition-all no-underline"
                : "font-semibold text-[15px] px-[22px] py-[14px] rounded-full bg-purple-deep text-white hover:bg-ink hover:-translate-y-px transition-all no-underline"
            }
          >
            {btn.label}
          </a>
        ))
      }
    </div>
  </div>
</div>
