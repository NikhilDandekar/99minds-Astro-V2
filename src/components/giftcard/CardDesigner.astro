---
/**
 * CardDesigner — exact layout match.
 * .designer: bg-bg-alt overflow-hidden py-[120px] px-8
 * .designer-frame: bg-white rounded-20 border border-line shadow-[0_24px_60px_-20px_rgba(10,10,35,0.12)] overflow-hidden flex flex-col
 * .designer-toolbar: bg-bg-alt border-b border-line px-4 py-3 flex items-center gap-2 (spans full width)
 * .designer-body: grid [280px_1fr_320px] min-h-[540px]
 *   ≤1024: single col; designer-left and designer-right hidden
 * Left: bg-bg-alt border-r border-line p-5 overflow-y-auto
 * Center: p-10 flex flex-col items-center justify-center (radial bg)
 * Right: bg-white border-l border-line p-5 overflow-y-auto
 */
const swatches = [
  { hex:'#6f4dff', grad:'linear-gradient(135deg,#6f4dff,#aa8fff)',  active:true  },
  { hex:'#0a0a23', grad:'linear-gradient(135deg,#0a0a23,#6f4dff)',  active:false },
  { hex:'#ff8a7a', grad:'linear-gradient(135deg,#ff8a7a,#ffc060)',  active:false },
  { hex:'#7ef0c5', grad:'linear-gradient(135deg,#7ef0c5,#00d4ff)',  active:false },
  { hex:'#00d4ff', grad:'linear-gradient(135deg,#00d4ff,#4a9eff)',  active:false },
  { hex:'#ffc060', grad:'linear-gradient(135deg,#ffc060,#ff8a7a)',  active:false },
  { hex:'#aa8fff', grad:'linear-gradient(135deg,#aa8fff,#b8bfff)',  active:false },
  { hex:'#1a8c5e', grad:'linear-gradient(135deg,#1a8c5e,#7ef0c5)',  active:false },
];
const templates = [
  { cls:'bg-[linear-gradient(135deg,#6f4dff,#aa8fff)]', active:true  },
  { cls:'bg-[linear-gradient(135deg,#0a0a23,#6f4dff)]', active:false },
  { cls:'bg-[linear-gradient(135deg,#ff8a7a,#ffc060)]', active:false },
  { cls:'bg-[linear-gradient(135deg,#7ef0c5,#00d4ff)]', active:false },
  { cls:'bg-[linear-gradient(135deg,#f4f2fb,#b8bfff)]', active:false },
  { cls:'bg-[linear-gradient(135deg,#ffc060,#ff8a7a)]', active:false },
];
const amounts  = ['$25','$50','$100','Custom'];
const toggleRows = [
  { label:'Email delivery',       sub:'ada@example.com',        on:true  },
  { label:'Add to mobile wallet', sub:'Apple + Google',         on:true  },
  { label:'Schedule for later',   sub:'Send on a specific date',on:false },
];
---

<section class="bg-bg-alt overflow-hidden py-[120px] px-8">
  <div class="max-w-[1280px] mx-auto">

    <!-- Section header: max-w-[720px] mb-16 -->
    <div class="max-w-[720px] mb-16">
      <p class="text-[13px] font-bold uppercase tracking-[0.1em] text-purple-deep mb-4">Card Designer</p>
      <h2 class="font-bold tracking-[-0.03em] leading-[1.05] text-ink mb-5" style="font-size:clamp(32px,4vw,52px)">Cards that look like your brand. Not ours.</h2>
      <p class="text-[19px] text-slate leading-[1.55]">Drop in your logo, choose your palette, and ship pixel-perfect eGifts that match your brand system. No design ticket required.</p>
    </div>

    <!-- Designer frame: flex flex-col -->
    <div class="bg-white rounded-20 border border-line overflow-hidden flex flex-col"
         style="box-shadow:0 24px 60px -20px rgba(10,10,35,0.12)">

      <!-- Toolbar: full width row -->
      <div class="bg-bg-alt border-b border-line px-4 py-3 flex items-center gap-2">
        <span class="w-[11px] h-[11px] rounded-full bg-accent-coral"></span>
        <span class="w-[11px] h-[11px] rounded-full bg-accent-gold"></span>
        <span class="w-[11px] h-[11px] rounded-full bg-accent-mint"></span>
        <div class="flex-1 text-center text-[12px] text-slate font-semibold">Card Designer · Northwind / Birthday Template</div>
      </div>

      <!-- 3-panel body: 280px | 1fr | 320px; ≤1024 single col -->
      <div class="grid grid-cols-1 lg:[grid-template-columns:280px_1fr_320px] min-h-[540px]">

        <!-- ── LEFT: Templates + colors (hidden ≤1024) ─ -->
        <div class="hidden lg:block bg-bg-alt border-r border-line p-5 overflow-y-auto">

          <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-slate-light mb-3">Templates</p>
          <div class="grid grid-cols-2 gap-2 mb-5">
            {templates.map(t => (
              <div data-thumb
                   class:list={['design-thumb aspect-[1.6/1] rounded-8 cursor-pointer border-2 transition-all duration-200 hover:-translate-y-0.5 overflow-hidden', t.cls, t.active ? 'border-purple-deep shadow-[0_0_0_3px_rgba(111,77,255,0.15)]' : 'border-transparent']}
              ></div>
            ))}
          </div>

          <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-slate-light mb-3 mt-5">Brand colors</p>
          <div class="flex gap-1.5 flex-wrap mb-5">
            {swatches.map(s => (
              <div data-swatch
                   data-grad={s.grad}
                   class:list={['w-7 h-7 rounded-full cursor-pointer border-2 border-white transition-transform duration-200 hover:scale-110', s.active ? 'shadow-[0_0_0_2px_#6f4dff]' : 'shadow-[0_0_0_1px_#e8e6f5]']}
                   style={`background:${s.hex}`}
              ></div>
            ))}
          </div>

          <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-slate-light mb-3 mt-5">Pattern</p>
          <div class="grid grid-cols-2 gap-2">
            <div data-thumb class="design-thumb aspect-[1.6/1] rounded-8 cursor-pointer border-2 border-purple-deep shadow-[0_0_0_3px_rgba(111,77,255,0.15)] relative overflow-hidden"
                 style="background:linear-gradient(135deg,#6f4dff,#aa8fff)">
              <div class="absolute inset-0 opacity-20" style="background-image:radial-gradient(circle at 1px 1px,white 1px,transparent 1px);background-size:6px 6px"></div>
            </div>
            <div data-thumb class="design-thumb aspect-[1.6/1] rounded-8 cursor-pointer border-2 border-transparent transition-all hover:-translate-y-0.5"
                 style="background:linear-gradient(135deg,#6f4dff,#aa8fff)"></div>
          </div>
        </div>

        <!-- ── CENTER: Live preview ──────────────────── -->
        <div class="p-10 flex flex-col items-center justify-center"
             style="background:radial-gradient(circle at 30% 20%,#f1edff,transparent 50%),radial-gradient(circle at 70% 80%,rgba(126,240,197,0.1),transparent 50%),white">

          <!-- Preview card: w-[360px] h-[220px] -->
          <div id="previewCard"
               class="relative overflow-hidden flex flex-col justify-between text-white transition-all duration-[400ms]"
               style="width:360px;height:220px;border-radius:18px;background:linear-gradient(135deg,#6f4dff 0%,#aa8fff 100%);box-shadow:0 24px 50px -16px rgba(111,77,255,0.4),inset 0 0 0 1px rgba(255,255,255,0.08);padding:24px 26px">
            <div class="dot-pattern-sm"></div>
            <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(125deg,transparent 30%,rgba(255,255,255,0.18) 50%,transparent 70%)"></div>
            <!-- Header -->
            <div class="relative flex justify-between items-start">
              <div class="text-[10px] font-bold tracking-[0.18em] uppercase" style="opacity:0.9">NORTHWIND · BIRTHDAY</div>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" opacity="0.7"><path d="M20 12V8H6a2 2 0 010-4h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/></svg>
            </div>
            <!-- Amount -->
            <div>
              <div id="previewAmount" class="text-[42px] font-bold tracking-[-0.03em] leading-none">$100</div>
              <div class="text-[12px] italic mt-1" style="opacity:0.85">"Happy birthday, Ada — enjoy!"</div>
            </div>
            <!-- Footer -->
            <div class="relative flex justify-between items-end font-mono text-[9px]" style="opacity:0.7">
              <div class="gc-chip"></div>
              <span>NW-8KPQ2X · EXP 12/27</span>
            </div>
          </div>

          <!-- Channel pills: mt-6 flex gap-2 -->
          <div class="mt-6 flex gap-2 flex-wrap justify-center">
            {['Email','SMS','Apple Wallet','Google Wallet'].map(ch => (
              <div class="bg-white border border-line rounded-pill px-3 py-1.5 text-[11px] font-semibold text-slate flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-mint flex-shrink-0"></span>
                {ch}
              </div>
            ))}
          </div>
        </div>

        <!-- ── RIGHT: Settings (hidden ≤1024) ──────── -->
        <div class="hidden lg:block bg-white border-l border-line p-5 overflow-y-auto">

          {[{label:'Recipient name',val:'Ada Lovelace'},{label:'Personal message',val:'Happy birthday, Ada — enjoy!'}].map(f => (
            <div class="mb-4">
              <label class="block text-[12px] font-semibold text-ink mb-1.5">{f.label}</label>
              <input value={f.val} class="w-full px-3 py-[9px] font-sans text-[13px] text-ink bg-bg-alt border border-line rounded-8 transition-colors duration-200 focus:outline-none focus:border-purple-deep focus:bg-white"/>
            </div>
          ))}

          <!-- Amount chips: grid repeat(4,1fr) gap-1.5 -->
          <div class="mb-4">
            <label class="block text-[12px] font-semibold text-ink mb-1.5">Amount</label>
            <div class="grid grid-cols-4 gap-1.5">
              {amounts.map(amt => (
                <button data-chip type="button"
                        class:list={['font-sans text-[12px] font-semibold py-2 rounded-[6px] border cursor-pointer transition-all duration-200', amt==='$100' ? 'bg-purple-deep text-white border-purple-deep' : 'bg-bg-alt text-ink border-line hover:border-purple']}>
                  {amt}
                </button>
              ))}
            </div>
          </div>

          {[{label:'Currency',val:'USD — US Dollar'},{label:'Expiration',val:'No expiration (recommended)'}].map(f => (
            <div class="mb-4">
              <label class="block text-[12px] font-semibold text-ink mb-1.5">{f.label}</label>
              <input value={f.val} class="w-full px-3 py-[9px] font-sans text-[13px] text-ink bg-bg-alt border border-line rounded-8 transition-colors duration-200 focus:outline-none focus:border-purple-deep focus:bg-white"/>
            </div>
          ))}

          <!-- Delivery toggles -->
          <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-slate-light mt-6 mb-0">Delivery</p>
          {toggleRows.map(t => (
            <div class="flex justify-between items-center py-3 border-b border-line last:border-b-0">
              <div>
                <div class="text-[13px] font-medium text-ink">{t.label}</div>
                <div class="text-[11px] text-slate-light mt-0.5">{t.sub}</div>
              </div>
              <div class:list={['toggle-switch', !t.on && 'off']}></div>
            </div>
          ))}

          <!-- Issue CTA -->
          <div class="mt-5 pt-5 border-t border-line">
            <button type="button" class="w-full py-[11px] font-sans text-[13px] font-semibold text-white bg-ink rounded-8 border-none cursor-pointer transition-colors duration-200 hover:bg-purple-deep">
              Issue gift card →
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  // Template thumbnail selection
  document.querySelectorAll('[data-thumb]').forEach(el => {
    el.addEventListener('click', () => {
      el.closest('.grid')?.querySelectorAll('[data-thumb]').forEach(t => {
        t.classList.remove('border-purple-deep','shadow-[0_0_0_3px_rgba(111,77,255,0.15)]');
        t.classList.add('border-transparent');
      });
      el.classList.remove('border-transparent');
      el.classList.add('border-purple-deep','shadow-[0_0_0_3px_rgba(111,77,255,0.15)]');
    });
  });

  // Swatch → update preview gradient
  const previewCard = document.getElementById('previewCard');
  document.querySelectorAll('[data-swatch]').forEach(swatch => {
    swatch.addEventListener('click', () => {
      document.querySelectorAll('[data-swatch]').forEach(s => {
        s.classList.remove('shadow-[0_0_0_2px_#6f4dff]'); s.classList.add('shadow-[0_0_0_1px_#e8e6f5]');
      });
      swatch.classList.add('shadow-[0_0_0_2px_#6f4dff]'); swatch.classList.remove('shadow-[0_0_0_1px_#e8e6f5]');
      const grad = (swatch as HTMLElement).dataset.grad;
      if (previewCard && grad) previewCard.style.background = grad;
    });
  });

  // Amount chip → update preview amount
  const previewAmount = document.getElementById('previewAmount');
  document.querySelectorAll('[data-chip]').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('[data-chip]').forEach(c => {
        c.classList.remove('bg-purple-deep','text-white','border-purple-deep');
        c.classList.add('bg-bg-alt','text-ink','border-line');
      });
      chip.classList.add('bg-purple-deep','text-white','border-purple-deep');
      chip.classList.remove('bg-bg-alt','text-ink','border-line');
      const label = chip.textContent?.trim() ?? '';
      if (label !== 'Custom' && previewAmount) previewAmount.textContent = label;
    });
  });

  // Toggle switches
  document.querySelectorAll('.toggle-switch').forEach(t => t.addEventListener('click', () => t.classList.toggle('off')));
</script>
