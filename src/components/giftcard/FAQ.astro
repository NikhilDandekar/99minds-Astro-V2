---
interface FAQItem { question: string; answer: string; open?: boolean; }
interface Props {
  eyebrow?: string;
  title?:   string;
  items?:   FAQItem[];
  bgClass?: string;
}
const {
  eyebrow = 'Common questions',
  title   = 'Things buyers usually ask.',
  items   = [],
  bgClass = 'bg-bg-alt',
} = Astro.props;
---

<section class:list={[bgClass, 'py-[120px] px-8']}>
  <div class="max-w-[1280px] mx-auto">

    <div class="max-w-[720px] mx-auto text-center mb-16">
      <p class="text-[13px] font-bold uppercase tracking-[0.1em] text-purple-deep mb-4">{eyebrow}</p>
      <h2 class="font-bold tracking-[-0.03em] leading-[1.05] text-ink" style="font-size:clamp(32px,4vw,52px)">{title}</h2>
    </div>

    <div class="max-w-[880px] mx-auto">
      {items.map(item => (
        <div class:list={['faq-item bg-white border border-line rounded-12 mb-3 overflow-hidden', item.open && 'open']}>
          <button
            type="button"
            class="faq-q w-full px-7 py-[22px] flex justify-between items-center text-[16px] font-semibold text-ink cursor-pointer transition-colors duration-200 hover:text-purple-deep bg-transparent border-none text-left"
          >
            <span>{item.question}</span>
            <span class="faq-toggle w-6 h-6 bg-purple-pale text-purple-deep rounded-full flex items-center justify-center font-bold text-[14px] flex-shrink-0 ml-6 transition-transform duration-300">
              +
            </span>
          </button>
          <div class="faq-answer">
            <div class="px-7 pb-[22px] text-[15px] text-slate leading-[1.6]">{item.answer}</div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => btn.closest('.faq-item')?.classList.toggle('open'));
  });
</script>
