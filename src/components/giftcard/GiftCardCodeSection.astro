---
/**
 * GiftCardCodeSection.astro
 * Dark developer section tailored for the Gift Cards product page.
 * Headline, callouts, and code snippet are specific to the gift card API.
 *
 * Reuse CodeSection.astro (loyalty page version) for other pages.
 * This component follows the same layout pattern but with different content.
 */
---

<section class="code-section">
  <div class="container">
    <div class="code-grid">

      <!-- Left: copy + callouts -->
      <div>
        <div class="section-eyebrow">For developers</div>
        <h2 class="section-title">
          Issue your first gift card in
          <span class="gradient-text">five lines of code</span>.
        </h2>
        <p class="section-lede">
          Idempotent endpoints. Webhooks for every state change. Sandbox parity. SDKs in seven
          languages. The kind of API your team won't dread.
        </p>

        <div class="code-callout-list">
          {[
            {
              icon: '<path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>',
              title: 'Seven SDKs, one mental model',
              desc:  'Node, Python, Go, Ruby, PHP, Java, .NET. Same shape, same idioms, same docs.',
            },
            {
              icon: '<path d="M12 2v6m0 0l3-3m-3 3l-3-3"/><rect x="3" y="10" width="18" height="11" rx="2"/>',
              title: 'Idempotency keys built in',
              desc:  'Retry safely. Network blips never double-issue a card. Distributed-systems hygiene by default.',
            },
            {
              icon: '<path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path d="M9 12l2 2 4-4"/>',
              title: '60+ webhook event types',
              desc:  'Subscribe to exactly the events you need. Signed payloads. At-least-once delivery. Exponential retry.',
            },
          ].map(c => (
            <div class="code-callout">
              <div class="code-callout-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={c.icon} />
              </div>
              <div>
                <h4>{c.title}</h4>
                <p>{c.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: syntax-highlighted code card -->
      <div class="code-snippet-card">
        <div class="code-snippet-tabs">
          <button class="csi-tab active">Node</button>
          <button class="csi-tab">Python</button>
          <button class="csi-tab">Ruby</button>
          <button class="csi-tab">cURL</button>
        </div>
        <div class="csi-body">
<span class="code-line"><span class="tk-com">// Issue a $50 branded eGift, push to wallet, log to ledger</span></span>
<span class="code-line"><span class="tk-key">import</span> NinetyNine <span class="tk-key">from</span> <span class="tk-str">'99minds'</span><span class="tk-punct">;</span></span>
<span class="code-line"><span class="tk-key">const</span> client <span class="tk-punct">=</span> <span class="tk-key">new</span> <span class="tk-fn">NinetyNine</span><span class="tk-punct">(</span><span class="tk-str">'sk_live_•••'</span><span class="tk-punct">);</span></span>
<span class="code-line"> </span>
<span class="code-line"><span class="tk-key">const</span> giftCard <span class="tk-punct">=</span> <span class="tk-key">await</span> client<span class="tk-punct">.</span>giftCards<span class="tk-punct">.</span><span class="tk-fn">create</span><span class="tk-punct">({</span></span>
<span class="code-line">  amount<span class="tk-punct">:</span>    <span class="tk-num">5000</span><span class="tk-punct">,</span>                       <span class="tk-com">// $50.00</span></span>
<span class="code-line">  currency<span class="tk-punct">:</span>  <span class="tk-str">'usd'</span><span class="tk-punct">,</span></span>
<span class="code-line">  recipient<span class="tk-punct">:</span> <span class="tk-punct">{</span></span>
<span class="code-line">    email<span class="tk-punct">:</span> <span class="tk-str">'ada@example.com'</span><span class="tk-punct">,</span></span>
<span class="code-line">    name<span class="tk-punct">:</span>  <span class="tk-str">'Ada Lovelace'</span></span>
<span class="code-line">  <span class="tk-punct">},</span></span>
<span class="code-line">  design<span class="tk-punct">:</span>      <span class="tk-str">'birthday_purple'</span><span class="tk-punct">,</span></span>
<span class="code-line">  message<span class="tk-punct">:</span>     <span class="tk-str">'Happy birthday, Ada!'</span><span class="tk-punct">,</span></span>
<span class="code-line">  wallet_pass<span class="tk-punct">:</span> <span class="tk-key">true</span><span class="tk-punct">,</span></span>
<span class="code-line">  delivery<span class="tk-punct">:</span>    <span class="tk-str">'email'</span></span>
<span class="code-line"><span class="tk-punct">},</span> <span class="tk-punct">{</span> idempotencyKey<span class="tk-punct">:</span> <span class="tk-str">'birthday-ada-2026'</span> <span class="tk-punct">});</span></span>
<span class="code-line"> </span>
<span class="code-line">console<span class="tk-punct">.</span><span class="tk-fn">log</span><span class="tk-punct">(</span>giftCard<span class="tk-punct">.</span>id<span class="tk-punct">);</span> <span class="tk-com">// gc_8KPq2x9LmZ</span></span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .code-section {
    background: var(--ink);
    color: white;
    overflow: hidden;
    position: relative;
    padding: 120px 32px;
  }

  .code-section::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at top right,   rgba(170,143,255,.18) 0%, transparent 50%),
      radial-gradient(ellipse at bottom left,  rgba(255,138,122,.10) 0%, transparent 50%);
    pointer-events: none;
  }

  .container { max-width: 1280px; margin: 0 auto; position: relative; }

  /* Section label + heading */
  .section-eyebrow {
    font-size: 13px; font-weight: 700; color: var(--purple-light);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px;
  }

  .section-title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700; letter-spacing: -0.03em; line-height: 1.05;
    color: white; margin-bottom: 20px;
  }

  .gradient-text {
    background: linear-gradient(120deg, var(--purple-light), var(--accent-cyan));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-lede { font-size: 19px; color: rgba(255,255,255,.65); line-height: 1.55; }

  /* 2-col grid */
  .code-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 64px;
    align-items: center;
  }

  /* Callouts */
  .code-callout-list { display: flex; flex-direction: column; gap: 24px; margin-top: 32px; }

  .code-callout { display: flex; gap: 16px; align-items: flex-start; }

  .code-callout-icon {
    width: 36px; height: 36px;
    background: rgba(170,143,255,.15);
    border: 1px solid rgba(170,143,255,.3);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: var(--purple-light); flex-shrink: 0;
  }

  .code-callout h4 { font-size: 16px; font-weight: 700; color: white; margin-bottom: 4px; }
  .code-callout p  { font-size: 14px; color: rgba(255,255,255,.65); line-height: 1.55; }

  /* Code card */
  .code-snippet-card {
    background: #1a1a3e;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 60px -20px rgba(0,0,0,.5);
    border: 1px solid rgba(255,255,255,.08);
  }

  .code-snippet-tabs {
    display: flex;
    background: rgba(0,0,0,.3);
    padding: 4px 4px 0; gap: 2px;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .csi-tab {
    padding: 10px 14px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: rgba(255,255,255,.4);
    border-radius: 8px 8px 0 0;
    cursor: pointer; background: transparent; border: none;
    transition: all 0.2s;
  }

  .csi-tab.active { background: #1a1a3e; color: var(--purple-light); }

  .csi-body {
    padding: 24px 28px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px; line-height: 1.75; color: #e0e0ff;
    min-height: 380px;
  }

  .code-line { display: block; }
  .tk-key   { color: #c4b5fd; }
  .tk-str   { color: #7ef0c5; }
  .tk-num   { color: #fbbf6e; }
  .tk-fn    { color: #82d4ff; }
  .tk-com   { color: rgba(255,255,255,.35); font-style: italic; }
  .tk-punct { color: rgba(255,255,255,.5); }

  /* Responsive */
  @media (max-width: 1024px) {
    .code-grid { grid-template-columns: 1fr; gap: 48px; }
    .code-section { padding: 80px 20px; }
  }
</style>

<script>
  document.querySelectorAll('.csi-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      tab.parentElement?.querySelectorAll('.csi-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
    });
  });
</script>
