---
import logo from '../assets/99minds-logo-b.svg';
---

<nav class="sticky top-0 z-[100] border-b border-[var(--line)] bg-white/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-[1280px] items-center justify-between px-8 py-4 max-lg:px-5">

    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-3 no-underline"
    >
      <img
        src={logo.src}
        alt="99minds logo"
        class="h-7 w-auto object-contain"
      />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-10 lg:flex">

      <!-- Menu -->
      <ul class="flex items-center gap-7">

        <!-- Products -->
        <li class="group relative">
          <button
            class="flex items-center gap-1 text-[15px] font-medium text-[var(--ink)] transition-colors duration-200 hover:text-[var(--purple-deep)]"
          >
            Products

            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="opacity-60 transition-transform duration-200 group-hover:rotate-180"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>

          <!-- Dropdown -->
          <div
            class="invisible absolute left-0 top-[calc(100%+18px)] w-[280px] rounded-2xl border border-[var(--line)] bg-white p-3 opacity-0 shadow-[0_20px_60px_-15px_rgba(10,10,35,0.12)] transition-all duration-200 group-hover:visible group-hover:opacity-100"
          >
            <a
              href="/gift-cards"
              class="flex rounded-xl p-4 transition-colors hover:bg-[var(--bg-alt)]"
            >
              <div>
                <div class="mb-1 text-sm font-semibold text-[var(--ink)]">
                  Gift Cards
                </div>
                <p class="text-[13px] leading-[1.5] text-[var(--slate)]">
                  Digital cards with unified balance tracking.
                </p>
              </div>
            </a>

            <a
              href="/loyalty"
              class="flex rounded-xl p-4 transition-colors hover:bg-[var(--bg-alt)]"
            >
              <div>
                <div class="mb-1 text-sm font-semibold text-[var(--ink)]">
                  Loyalty
                </div>
                <p class="text-[13px] leading-[1.5] text-[var(--slate)]">
                  Build flexible rewards and VIP programs.
                </p>
              </div>
            </a>

            <a
              href="/promotions"
              class="flex rounded-xl p-4 transition-colors hover:bg-[var(--bg-alt)]"
            >
              <div>
                <div class="mb-1 text-sm font-semibold text-[var(--ink)]">
                  Promotions
                </div>
                <p class="text-[13px] leading-[1.5] text-[var(--slate)]">
                  Apple & Google Wallet integrations for engagement.
                </p>
              </div>
            </a>
          </div>
        </li>

        <!-- Solutions -->
        <li class="group relative">
          <button
            class="flex items-center gap-1 text-[15px] font-medium text-[var(--ink)] transition-colors duration-200 hover:text-[var(--purple-deep)]"
          >
            Solutions

            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="opacity-60 transition-transform duration-200 group-hover:rotate-180"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>
        </li>

        <!-- Developers -->
        <li class="group relative">
          <button
            class="flex items-center gap-1 text-[15px] font-medium text-[var(--ink)] transition-colors duration-200 hover:text-[var(--purple-deep)]"
          >
            Developers

            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="opacity-60 transition-transform duration-200 group-hover:rotate-180"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>
        </li>

        <!-- Resources -->
        <li class="group relative">
          <button
            class="flex items-center gap-1 text-[15px] font-medium text-[var(--ink)] transition-colors duration-200 hover:text-[var(--purple-deep)]"
          >
            Resources

            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="opacity-60 transition-transform duration-200 group-hover:rotate-180"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>
        </li>

        <!-- Links -->
        <li>
          <a
            href="#"
            class="text-[15px] font-medium text-[var(--ink)] transition-colors duration-200 hover:text-[var(--purple-deep)]"
          >
            Pricing
          </a>
        </li>

        <li>
          <a
            href="#"
            class="text-[15px] font-medium text-[var(--ink)] transition-colors duration-200 hover:text-[var(--purple-deep)]"
          >
            Customers
          </a>
        </li>
      </ul>

      <!-- Actions -->
      <div class="flex items-center gap-3">

        <a
          href="#"
          class="rounded-full px-4 py-2.5 text-sm font-semibold text-[var(--ink)] transition-colors duration-200 hover:bg-[var(--bg-alt)]"
        >
          Sign in
        </a>

        <a
          href="#"
          class="rounded-full bg-[var(--ink)] px-5 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-px hover:bg-[var(--purple-deep)]"
        >
          Contact sales
        </a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <button
      class="flex h-11 w-11 items-center justify-center rounded-full border border-[var(--line)] lg:hidden"
      aria-label="Open Menu"
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>
</nav>