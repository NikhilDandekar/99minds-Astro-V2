---
import logo from '../assets/99minds-logo-b.svg';
---

<nav class="sticky top-0 z-[100] backdrop-blur-xl bg-white/70 border-b border-[var(--line)]/60"
     style="backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%);">
  <div class="max-w-layout mx-auto px-8 py-[18px] flex items-center justify-between gap-12">
   <a
  href="/"
  class="font-extrabold text-[22px] tracking-[-0.03em] text-[var(--ink)] no-underline flex items-center gap-2"
>
  <img
    src={logo.src}
    alt="99minds logo"
    class="h-7 w-auto object-contain"
  />
</a>
    <ul class="hidden lg:flex gap-8 list-none flex-1">
      <li>
        <a href="#" class="text-[var(--ink)] no-underline text-sm font-medium transition-colors duration-200 hover:text-[var(--purple-deep)] flex items-center gap-1">
          Products
          <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" class="opacity-50"><path d="M6 8L2 4h8z"/></svg>
        </a>
      </li>
      <li>
        <a href="#" class="text-[var(--ink)] no-underline text-sm font-medium transition-colors duration-200 hover:text-[var(--purple-deep)] flex items-center gap-1">
          Solutions
          <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" class="opacity-50"><path d="M6 8L2 4h8z"/></svg>
        </a>
      </li>
      <li>
        <a href="#" class="text-[var(--ink)] no-underline text-sm font-medium transition-colors duration-200 hover:text-[var(--purple-deep)] flex items-center gap-1">
          Developers
          <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" class="opacity-50"><path d="M6 8L2 4h8z"/></svg>
        </a>
      </li>
      <li>
        <a href="#" class="text-[var(--ink)] no-underline text-sm font-medium transition-colors duration-200 hover:text-[var(--purple-deep)] flex items-center gap-1">
          Resources
          <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" class="opacity-50"><path d="M6 8L2 4h8z"/></svg>
        </a>
      </li>
      <li>
        <a href="#" class="text-[var(--ink)] no-underline text-sm font-medium transition-colors duration-200 hover:text-[var(--purple-deep)]">Pricing</a>
      </li>
      <li>
        <a href="#" class="text-[var(--ink)] no-underline text-sm font-medium transition-colors duration-200 hover:text-[var(--purple-deep)]">Customers</a>
      </li>
    </ul>

    <div class="flex gap-2 items-center">
      <a href="#"
         class="font-semibold text-sm px-[18px] py-[10px] rounded-full no-underline inline-flex items-center gap-1.5 transition-all duration-200 text-[var(--ink)] hover:bg-[var(--line-soft)] whitespace-nowrap">
        Sign in
      </a>
      <a href="#"
         class="font-semibold text-sm px-[18px] py-[10px] rounded-full no-underline inline-flex items-center gap-1.5 transition-all duration-200 bg-[var(--ink)] text-white hover:bg-[var(--purple-deep)] hover:-translate-y-px whitespace-nowrap">
        Contact sales →
      </a>
    </div>
  </div>
</nav>
