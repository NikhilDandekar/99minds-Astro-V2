---
export interface FAQItem {
  question: string;
  answer: string;
  open?: boolean;
}

export interface Props {
  eyebrow?: string;
  title?: string;
  items?: FAQItem[];
}

const {
  eyebrow = 'Common questions',
  title = 'Things buyers usually ask.',
  items = [
    {
      question: 'Can we migrate members and points from Antavo or Yotpo?',
      answer: 'Yes — we have proven migration playbooks for Antavo, Yotpo, Smile.io, and LoyaltyLion. We import member balances, tier assignments, and historical earning events so day-one balances match exactly. Most migrations finish in 4–6 weeks including parallel-running and final cutover.',
      open: true,
    },
    {
      question: 'How does pricing compare to Antavo for an enterprise program?',
      answer: 'Antavo\'s enterprise pricing typically runs into six figures annually with significant implementation fees on top. 99minds pricing is tiered on monthly active members with no implementation fee for self-serve onboarding. For a program of 100k active members, our customers typically save 40–60% versus a comparable Antavo contract.',
    },
    {
      question: 'Does the rules builder handle truly complex earning logic?',
      answer: 'Yes. Anything you can describe with a trigger event, conditional logic, and an action is buildable. Multi-step funnels, time-decayed earning, category-based multipliers, A/B-tested earning rates, partner-cobranded earning — all native. For the rare case that needs custom logic, drop into our scripting layer (sandboxed JavaScript).',
    },
    {
      question: 'Can we run multiple programs (B2B + B2C, or by region) on one account?',
      answer: 'Yes — multi-program is native. Create as many distinct programs as you need with separate rule sets, tier structures, branding, and reporting. They share the underlying customer ledger so a member who\'s in two programs sees both balances cleanly.',
    },
    {
      question: 'What about international compliance and data residency?',
      answer: 'EU, UK, and APAC data residency available. GDPR-ready data export and right-to-erasure tooling for member data. PSD2-compliant for European loyalty-as-payment use cases. SOC 2 Type II audited annually.',
    },
  ],
} = Astro.props;
---

<section class="faq-section">
  <div class="container">
    <div class="section-header center">
      <div class="section-eyebrow">{eyebrow}</div>
      <h2 class="section-title">{title}</h2>
    </div>

    <div class="faq-list">
      {items.map(item => (
        <div class={`faq-item${item.open ? ' open' : ''}`}>
          <div class="faq-q">
            {item.question}
            <div class="faq-toggle">+</div>
          </div>
          <div class="faq-a">
            <div class="faq-a-inner">{item.answer}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    background: white;
    padding: 120px 32px;
  }

  .container { max-width: 1280px; margin: 0 auto; }

  .section-header { max-width: 720px; margin-bottom: 64px; }
  .section-header.center { margin-left: auto; margin-right: auto; text-align: center; }

  .section-eyebrow {
    font-size: 13px; font-weight: 700; color: var(--purple-deep);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px;
  }

  .section-title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700; letter-spacing: -0.03em; line-height: 1.05;
    color: var(--ink);
  }

  .faq-list {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--line);
  }

  .faq-q {
    padding: 24px 0;
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    user-select: none;
  }

  .faq-q:hover { color: var(--purple-deep); }

  .faq-toggle {
    width: 28px; height: 28px;
    background: var(--bg-alt);
    border: 1px solid var(--line);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 400;
    color: var(--slate);
    flex-shrink: 0;
    transition: all 0.2s;
    line-height: 1;
  }

  .faq-a {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
  }

  .faq-item.open .faq-a { max-height: 300px; }
  .faq-item.open .faq-toggle {
    transform: rotate(45deg);
    background: var(--purple-pale);
    border-color: var(--purple-light);
    color: var(--purple-deep);
  }

  .faq-a-inner {
    padding: 0 28px 22px;
    font-size: 15px;
    color: var(--slate);
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .faq-section { padding: 80px 20px; }
  }
</style>

<script>
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.parentElement?.classList.toggle('open');
    });
  });
</script>
