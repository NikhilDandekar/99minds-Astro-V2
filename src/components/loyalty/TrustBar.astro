---
import type { TrustItem } from '../../config/trustbar';
import { loyaltyTrustItems } from '../../config/trustbar';

export interface Props {
  items?: TrustItem[];
}

const { items = loyaltyTrustItems } = Astro.props;
---

<div class="bg-[var(--bg-alt)] border-t border-b border-[var(--line)] py-8 px-8">
  <div class="max-w-layout mx-auto flex flex-wrap justify-between items-center gap-6">
    {items.map(item => (
      <div class="flex items-center gap-3 text-[13px] text-[var(--slate)]">
        <div class="w-8 h-8 bg-white border border-[var(--line)] rounded-lg flex items-center justify-center text-[var(--purple-deep)] shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={item.icon} />
        </div>
        <div>
          <strong class="block text-[14px] font-semibold text-[var(--ink)]">{item.label}</strong>
          <span class="text-[12px] text-[var(--slate-light)]">{item.sublabel}</span>
        </div>
      </div>
    ))}
  </div>
</div>
