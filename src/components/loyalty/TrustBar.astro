---
export interface TrustItem {
  icon: string; // SVG path(s) as raw string
  label: string;
  sublabel: string;
  viewBox?: string;
}

export interface Props {
  items?: TrustItem[];
}

const defaultItems: TrustItem[] = [
  {
    icon: '<path d="M13 2L3 14h7l-1 8 10-12h-7z"/>',
    label: 'Sub-30-day launches',
    sublabel: 'Avg time-to-go-live',
  },
  {
    icon: '<circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/>',
    label: 'SOC 2 Type II',
    sublabel: 'Continuous compliance',
  },
  {
    icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/>',
    label: 'Unified ledger',
    sublabel: 'Points + cards + credit',
  },
  {
    icon: '<path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path d="M12 6v6l4 2"/>',
    label: 'Real-time tier-up',
    sublabel: 'Sub-second evaluation',
  },
  {
    icon: '<path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>',
    label: '7 SDKs',
    sublabel: '+ Shopify, Salesforce',
  },
];

const { items = defaultItems } = Astro.props;
---

<div class="trust-bar">
  <div class="trust-bar-inner">
    {items.map(item => (
      <div class="trust-item">
        <div class="trust-item-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={item.icon} />
        </div>
        <div>
          <strong>{item.label}</strong>
          <span>{item.sublabel}</span>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .trust-bar {
    background: var(--bg-alt);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 32px;
  }

  .trust-bar-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: var(--slate);
  }

  .trust-item-icon {
    width: 32px;
    height: 32px;
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--purple-deep);
    flex-shrink: 0;
  }

  .trust-item strong {
    color: var(--ink);
    display: block;
    font-size: 14px;
  }

  .trust-item span {
    font-size: 12px;
    color: var(--slate-light);
  }
</style>
