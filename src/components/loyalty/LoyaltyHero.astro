---
/**
 * LoyaltyHero — exact layout match to loyalty page .product-hero.
 * Same structure as GiftCardHero but with:
 *  - ph-mesh-loyalty (slightly different gradient)
 *  - Different pill icon
 *  - Different h1 gradient (purple→gold)
 *  - Right visual: member card + tier pyramid + floating points badges
 */
interface Feature { text: string; }
interface Props {
  pill?:         string;
  title?:        string;
  titleGradient?:string;
  titleSuffix?:  string;
  lede?:         string;
  primaryCta?:   { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  features?:     Feature[];
}
const {
  pill          = 'Loyalty Engine',
  title         = 'Loyalty that',
  titleGradient = 'marketing ships',
  titleSuffix   = ', engineering trusts.',
  lede          = 'A visual rules builder for marketers. A programmable engine for developers. The same loyalty platform — finally aligned.',
  primaryCta    = { label:'Start free trial →',    href:'#' },
  secondaryCta  = { label:'Try the rules builder', href:'#' },
  features      = [
    { text:"Launch your first program in <strong>under 30 days</strong> — Antavo takes a quarter, Yotpo isn't built for it" },
    { text:'One ledger across <strong>points, gift card balance, and store credit</strong> — not three' },
    { text:'Visual builder marketing <strong>actually uses</strong> — not a glorified Zapier' },
  ],
} = Astro.props;

const tiers = [
  { w:'95%', label:'B', name:'Bronze · 0–999 pts', perks:'5% off, free ship over $50', pct:'63%', grad:'linear-gradient(135deg,#cd7f32,#a0522d)', textDark:false },
  { w:'80%', label:'S', name:'Silver · 1k–4.9k',  perks:'10% off, early access',       pct:'25%', grad:'linear-gradient(135deg,#b8b8c8,#808090)', textDark:false },
  { w:'65%', label:'G', name:'Gold · 5k–14.9k',   perks:'15% off, free returns',       pct:'9%',  grad:'linear-gradient(135deg,#ffc060,#ff9555)', textDark:true  },
  { w:'50%', label:'P', name:'Platinum · 15k+',   perks:'VIP concierge',               pct:'3%',  grad:'linear-gradient(135deg,#0a0a23,#6f4dff)', textDark:false },
];
---

<section class="relative overflow-hidden px-8 pt-12 pb-20">
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <div class="ph-mesh-loyalty animate-mesh-slow"></div>
  </div>

  <div class="relative z-10 max-w-[1280px] mx-auto grid grid-cols-1 lg:[grid-template-columns:1fr_1.05fr] gap-16 items-center">

    <!-- Left copy (identical structure to GiftCardHero) -->
    <div>
      <div class="inline-flex items-center gap-2 bg-white border border-line px-3.5 py-1.5 rounded-pill text-[13px] font-semibold text-purple-deep mb-6"
           style="box-shadow:0 1px 2px rgba(10,10,35,0.04)">
        <div class="w-[18px] h-[18px] rounded-[5px] flex items-center justify-center text-white flex-shrink-0"
             style="background:linear-gradient(135deg,#6f4dff,#aa8fff)">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <path d="M12 2l2.5 7h7l-5.5 4.5 2 7L12 16l-6 4.5 2-7L2.5 9h7z"/>
          </svg>
        </div>
        {pill}
      </div>

      <h1 class="font-bold tracking-[-0.04em] leading-[1] text-ink mb-6"
          style="font-size:clamp(44px,5.6vw,76px)">
        {title} <span class="text-grad-loyalty">{titleGradient}</span>{titleSuffix}
      </h1>

      <p class="text-[19px] text-slate leading-[1.55] max-w-[540px] mb-8">{lede}</p>

      <div class="flex flex-wrap gap-3 items-center mb-10">
        <a href={primaryCta.href} class="font-semibold text-[15px] text-white bg-purple-deep px-[22px] py-[14px] rounded-pill no-underline transition-all duration-200 hover:bg-ink hover:-translate-y-px">{primaryCta.label}</a>
        {secondaryCta && <a href={secondaryCta.href} class="font-semibold text-[15px] text-ink bg-white border border-line px-[22px] py-[14px] rounded-pill no-underline transition-all duration-200 hover:border-purple-deep hover:text-purple-deep">{secondaryCta.label}</a>}
      </div>

      <div class="flex flex-col gap-3">
        {features.map(f => (
          <div class="flex items-start gap-3 text-[14px] text-slate">
            <div class="w-[18px] h-[18px] flex-shrink-0 bg-purple-pale rounded-full flex items-center justify-center text-purple-deep font-extrabold text-[11px] mt-0.5">✓</div>
            <div set:html={f.text}/>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: member card + tier pyramid -->
    <div class="relative hidden sm:block" style="height:540px" aria-hidden="true">

      <!-- Floating badge: points earned -->
      <div class="absolute top-[-10px] left-[30px] z-40 bg-white rounded-pill px-3.5 py-2 flex items-center gap-2 text-[13px] font-semibold animate-floatB"
           style="box-shadow:0 12px 32px -8px rgba(10,10,35,0.18),0 0 0 1px #e8e6f5">
        <div class="w-[22px] h-[22px] rounded-full bg-purple-deep flex items-center justify-center flex-shrink-0">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><path d="M12 2l2.5 7h7l-5.5 4.5 2 7L12 16l-6 4.5 2-7L2.5 9h7z"/></svg>
        </div>
        +500 points earned
      </div>

      <!-- Member card: absolute top:30 right:0 w-[320px] -->
      <div class="absolute text-white z-30 overflow-hidden"
           style="top:30px;right:0;width:320px;border-radius:20px;background:linear-gradient(135deg,#0a0a23 0%,#6f4dff 100%);padding:24px;box-shadow:0 30px 60px -20px rgba(111,77,255,0.4),inset 0 0 0 1px rgba(255,255,255,0.08)">
        <!-- Gold radial glow -->
        <div class="absolute pointer-events-none rounded-full" style="top:-40%;right:-20%;width:200px;height:200px;background:radial-gradient(circle,rgba(255,192,96,0.3) 0%,transparent 60%)"></div>

        <!-- Tier badge + medal -->
        <div class="relative flex justify-between items-start mb-[18px]">
          <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-pill text-[11px] font-bold uppercase tracking-[0.06em]"
               style="background:linear-gradient(135deg,#ffc060,#ff9555);color:#0a0a23">★ Gold Member</div>
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-extrabold text-[16px]"
               style="background:linear-gradient(135deg,#ffc060,#ff9555);color:#0a0a23;box-shadow:0 4px 12px rgba(255,192,96,0.4)">G</div>
        </div>

        <div class="text-[18px] font-bold tracking-[-0.01em] mb-1">Ada Lovelace</div>
        <div class="text-[11px] font-mono mb-[18px]" style="opacity:0.6">MEM-8KPQ2X · Member since 2023</div>
        <div class="text-[11px] uppercase tracking-[0.08em]" style="opacity:0.7">Points balance</div>
        <div class="text-[38px] font-bold tracking-[-0.02em] leading-none mt-1 mb-[18px]">8,420</div>
        <div class="flex justify-between text-[11px] mb-1.5" style="opacity:0.7">
          <span>Progress to Platinum</span><span>8,420 / 12,500</span>
        </div>
        <div class="h-1.5 rounded-pill overflow-hidden" style="background:rgba(255,255,255,0.15)">
          <div class="mc-progress-bar"></div>
        </div>
        <div class="text-[11px] mt-2" style="opacity:0.7">4,080 points to unlock VIP concierge &amp; 25% off</div>
      </div>

      <!-- Tier pyramid: absolute bottom:0 left:0 flex flex-col gap-2 -->
      <div class="absolute bottom-0 left-0 z-20 flex flex-col gap-2">
        {tiers.map(tier => (
          <div class="bg-white border border-line rounded-14 px-[18px] py-3.5 flex items-center gap-3.5 transition-transform duration-300 hover:translate-x-2"
               style={`width:${tier.w};box-shadow:0 8px 24px -8px rgba(10,10,35,0.08)`}>
            <div class="w-9 h-9 flex-shrink-0 rounded-full flex items-center justify-center font-bold text-[14px]"
                 style={`background:${tier.grad};color:${tier.textDark?'#0a0a23':'white'}`}>
              {tier.label}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-[13px] font-bold text-ink">{tier.name}</div>
              <div class="text-[11px] text-slate mt-0.5">{tier.perks}</div>
            </div>
            <div class="text-[12px] font-bold text-purple-deep flex-shrink-0">{tier.pct}</div>
          </div>
        ))}
      </div>

      <!-- Floating badge: tier upgraded -->
      <div class="absolute z-40 bg-white rounded-pill px-3.5 py-2 flex items-center gap-2 text-[13px] font-semibold animate-float"
           style="bottom:80px;right:50px;animation-delay:2s;box-shadow:0 12px 32px -8px rgba(10,10,35,0.18),0 0 0 1px #e8e6f5">
        <div class="w-[22px] h-[22px] rounded-full flex items-center justify-center flex-shrink-0" style="background:#7ef0c5;color:#0a0a23">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#0a0a23" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        Tier upgraded
      </div>

    </div>
  </div>
</section>
