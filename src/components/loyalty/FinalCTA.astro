---
export interface Props {
  title?: string;
  highlightText?: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  title = 'Ready to ship loyalty your',
  highlightText = 'marketing team owns',
  subtitle = 'Start with a sandbox key in 30 seconds. Talk to sales when you\'re ready to migrate.',
  primaryCta = { label: 'Start free trial →', href: '#' },
  secondaryCta = { label: 'Book a demo', href: '#' },
} = Astro.props;
---

<div class="final-cta">
  <div class="final-cta-inner">
    <h2>{title} <span class="highlight">{highlightText}</span>?</h2>
    <p>{subtitle}</p>
    <div class="final-cta-actions">
      <a href={primaryCta.href} class="btn btn-purple btn-lg">{primaryCta.label}</a>
      {secondaryCta && <a href={secondaryCta.href} class="btn btn-outline btn-lg">{secondaryCta.label}</a>}
    </div>
  </div>
</div>

<style>
  .final-cta {
    padding: 120px 32px;
    text-align: center;
    background: white;
    position: relative;
    overflow: hidden;
  }

  .final-cta::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(170,143,255,0.18) 0%, transparent 60%);
    pointer-events: none;
  }

  .final-cta-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }

  .final-cta h2 {
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 20px;
    color: var(--ink);
  }

  .highlight { color: var(--purple-deep); }

  .final-cta p {
    font-size: 19px;
    color: var(--slate);
    margin-bottom: 36px;
  }

  .final-cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    font-family: inherit;
    font-weight: 600;
    font-size: 14px;
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .btn-lg { padding: 14px 22px; font-size: 15px; }

  .btn-purple { background: var(--purple-deep); color: white; }
  .btn-purple:hover { background: var(--ink); transform: translateY(-1px); }

  .btn-outline { background: white; color: var(--ink); border-color: var(--line); }
  .btn-outline:hover { border-color: var(--purple-deep); color: var(--purple-deep); }

  @media (max-width: 640px) {
    .final-cta { padding: 80px 20px; }
  }
</style>
