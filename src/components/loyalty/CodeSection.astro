---
// CodeSection.astro — Developer section with syntax-highlighted YAML code block
---

<section class="code-section">
  <div class="container">
    <div class="code-grid">
      <div>
        <div class="section-eyebrow">For developers</div>
        <h2 class="section-title">
          Visual and code stay
          <span class="gradient-text">in lockstep</span>.
        </h2>
        <p class="section-lede">
          Every rule built in the visual editor is a typed config you can review in a PR. Every API-driven rule shows up in the visual editor for your marketing team to inspect. One source of truth. No drift.
        </p>

        <div class="code-callout-list">
          {[
            {
              icon: '<path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>',
              title: 'Typed rule configs',
              desc: 'JSON or YAML. Versioned in your repo. Diffable in PRs. Roll back any rule to any prior state in one click.',
            },
            {
              icon: '<path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path d="M9 12l2 2 4-4"/>',
              title: 'Dry-run before deploy',
              desc: 'Test any rule against your last 30 days of customer events. See exactly which members would have triggered it.',
            },
            {
              icon: '<path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>',
              title: 'Hooks at every step',
              desc: 'Subscribe to tier.changed, points.earned, reward.redeemed and 30+ more events.',
            },
          ].map(c => (
            <div class="code-callout">
              <div class="code-callout-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={c.icon} />
              </div>
              <div>
                <h4>{c.title}</h4>
                <p>{c.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="code-snippet-card">
        <div class="code-snippet-tabs">
          <button class="csi-tab active">Rule (YAML)</button>
          <button class="csi-tab">Award (Node)</button>
          <button class="csi-tab">Webhook</button>
        </div>
        <div class="csi-body">
<span class="code-line"><span class="tk-com"># Birthday reward rule — same as visual builder</span></span>
<span class="code-line"><span class="tk-key">name</span><span class="tk-punct">:</span> <span class="tk-str">birthday_gold_platinum</span></span>
<span class="code-line"><span class="tk-key">version</span><span class="tk-punct">:</span> <span class="tk-num">3</span></span>
<span class="code-line"><span class="tk-key">enabled</span><span class="tk-punct">:</span> <span class="tk-key">true</span></span>
<span class="code-line"> </span>
<span class="code-line"><span class="tk-key">trigger</span><span class="tk-punct">:</span></span>
<span class="code-line">  <span class="tk-key">event</span><span class="tk-punct">:</span> <span class="tk-str">customer.birthday</span></span>
<span class="code-line">  <span class="tk-key">timezone</span><span class="tk-punct">:</span> <span class="tk-str">customer.local</span></span>
<span class="code-line">  <span class="tk-key">fires_at</span><span class="tk-punct">:</span> <span class="tk-str">"08:00"</span></span>
<span class="code-line"> </span>
<span class="code-line"><span class="tk-key">conditions</span><span class="tk-punct">:</span></span>
<span class="code-line">  <span class="tk-punct">-</span> <span class="tk-key">customer.tier</span><span class="tk-punct">:</span></span>
<span class="code-line">      <span class="tk-key">in</span><span class="tk-punct">:</span> <span class="tk-punct">[</span><span class="tk-str">gold</span><span class="tk-punct">,</span> <span class="tk-str">platinum</span><span class="tk-punct">]</span></span>
<span class="code-line"> </span>
<span class="code-line"><span class="tk-key">actions</span><span class="tk-punct">:</span></span>
<span class="code-line">  <span class="tk-punct">-</span> <span class="tk-key">type</span><span class="tk-punct">:</span> <span class="tk-str">issue_gift_card</span></span>
<span class="code-line">    <span class="tk-key">amount</span><span class="tk-punct">:</span> <span class="tk-num">2500</span>            <span class="tk-com"># $25.00</span></span>
<span class="code-line">    <span class="tk-key">currency</span><span class="tk-punct">:</span> <span class="tk-str">usd</span></span>
<span class="code-line">    <span class="tk-key">delivery</span><span class="tk-punct">:</span> <span class="tk-punct">[</span><span class="tk-str">email</span><span class="tk-punct">,</span> <span class="tk-str">wallet</span><span class="tk-punct">]</span></span>
<span class="code-line">  <span class="tk-punct">-</span> <span class="tk-key">type</span><span class="tk-punct">:</span> <span class="tk-str">award_points</span></span>
<span class="code-line">    <span class="tk-key">amount</span><span class="tk-punct">:</span> <span class="tk-num">500</span></span>
<span class="code-line">    <span class="tk-key">reason</span><span class="tk-punct">:</span> <span class="tk-str">"Birthday bonus"</span></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .code-section {
    background: var(--ink);
    color: white;
    overflow: hidden;
    position: relative;
    padding: 120px 32px;
  }

  .code-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at top right, rgba(170, 143, 255, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(255, 192, 96, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .container { max-width: 1280px; margin: 0 auto; position: relative; }

  .section-eyebrow {
    font-size: 13px; font-weight: 700;
    color: var(--purple-light);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px;
  }

  .section-title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700; letter-spacing: -0.03em; line-height: 1.05;
    color: white; margin-bottom: 20px;
  }

  .gradient-text {
    background: linear-gradient(120deg, var(--purple-light), var(--accent-gold));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-lede { font-size: 19px; color: rgba(255,255,255,0.65); line-height: 1.55; }

  .code-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 64px;
    align-items: center;
  }

  .code-callout-list { display: flex; flex-direction: column; gap: 24px; margin-top: 32px; }

  .code-callout { display: flex; gap: 16px; align-items: flex-start; }

  .code-callout-icon {
    width: 36px; height: 36px;
    background: rgba(170, 143, 255, 0.15);
    border: 1px solid rgba(170, 143, 255, 0.3);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: var(--purple-light);
    flex-shrink: 0;
  }

  .code-callout h4 { font-size: 16px; font-weight: 700; color: white; margin-bottom: 4px; }
  .code-callout p  { font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.55; }

  /* Code snippet card */
  .code-snippet-card {
    background: #1a1a3e;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255,255,255,0.08);
  }

  .code-snippet-tabs {
    display: flex;
    background: rgba(0,0,0,0.3);
    padding: 4px 4px 0;
    gap: 2px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .csi-tab {
    padding: 10px 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    border-radius: 8px 8px 0 0;
    cursor: pointer;
    background: transparent;
    border: none;
    transition: all 0.2s;
  }

  .csi-tab.active { background: #1a1a3e; color: var(--purple-light); }

  .csi-body {
    padding: 24px 28px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    line-height: 1.75;
    color: #e0e0ff;
    min-height: 380px;
  }

  .code-line { display: block; }
  .tk-key   { color: #c4b5fd; }
  .tk-str   { color: #7ef0c5; }
  .tk-num   { color: #fbbf6e; }
  .tk-com   { color: rgba(255,255,255,0.35); font-style: italic; }
  .tk-punct { color: rgba(255,255,255,0.5); }

  @media (max-width: 1024px) {
    .code-grid { grid-template-columns: 1fr; gap: 48px; }
    .code-section { padding: 80px 20px; }
  }
</style>

<script>
  document.querySelectorAll('.csi-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      tab.parentElement?.querySelectorAll('.csi-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
    });
  });
</script>
