---
// RulesBuilder.astro — Visual/Code mode demo section
---

<section class="rules-builder">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">Visual Rules Builder</div>
      <h2 class="section-title">Marketing ships rules without filing tickets.</h2>
      <p class="section-lede">
        Drag a trigger, pick a condition, choose a reward. Watch your loyalty logic come to life — then flip to code mode and your engineers see the same rule as a typed config they can review in a PR.
      </p>
    </div>

    <div class="builder-frame">
      <div class="builder-toolbar">
        <span class="bt-dot"></span>
        <span class="bt-dot"></span>
        <span class="bt-dot"></span>
        <div class="bt-title">Loyalty Rules · Birthday Reward · v3</div>
        <div class="bt-mode-switch">
          <div class="bt-mode active" data-mode="visual">Visual</div>
          <div class="bt-mode" data-mode="code">Code</div>
          <div class="bt-mode" data-mode="logs">Logs</div>
        </div>
      </div>

      <div class="builder-body">
        <!-- LEFT: Trigger library -->
        <div class="builder-left">
          <div class="bl-section-label">Triggers</div>
          {[
            { icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>', name: 'Customer birthday', desc: 'Fires daily at 8am local' },
            { icon: '<rect x="3" y="6" width="18" height="13" rx="2"/>', name: 'Order completed', desc: 'After payment captured' },
            { icon: '<path d="M12 2l2.5 7h7l-5.5 4.5 2 7L12 16l-6 4.5 2-7L2.5 9h7z"/>', name: 'Review submitted', desc: 'Verified purchase only' },
            { icon: '<path d="M16 3l-8 8 8 8"/>', name: 'Friend referred', desc: 'After their first order' },
          ].map(t => (
            <div class="bl-trigger">
              <div class="bl-trigger-icon">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" set:html={t.icon} />
              </div>
              <div class="bl-trigger-meta">
                <div class="bl-trigger-name">{t.name}</div>
                <div class="bl-trigger-desc">{t.desc}</div>
              </div>
              <div class="bl-trigger-grab">⋮⋮</div>
            </div>
          ))}

          <div class="bl-section-label">Actions</div>
          {[
            { icon: '<path d="M12 2l2.5 7h7l-5.5 4.5 2 7L12 16l-6 4.5 2-7L2.5 9h7z"/>', name: 'Award points', desc: 'Static or formula-based' },
            { icon: '<rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/>', name: 'Issue gift card', desc: 'Email or wallet pass' },
            { icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>', name: 'Upgrade tier', desc: 'Immediate or end of period' },
          ].map(t => (
            <div class="bl-trigger">
              <div class="bl-trigger-icon">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" set:html={t.icon} />
              </div>
              <div class="bl-trigger-meta">
                <div class="bl-trigger-name">{t.name}</div>
                <div class="bl-trigger-desc">{t.desc}</div>
              </div>
              <div class="bl-trigger-grab">⋮⋮</div>
            </div>
          ))}
        </div>

        <!-- CENTER: Canvas -->
        <div class="builder-canvas">
          <div class="canvas-label">Rule Canvas</div>
          <div class="rule-flow">
            <div class="rule-node trigger-node">
              <div class="rn-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
                </svg>
              </div>
              <div class="rn-text">
                <div class="rn-type">TRIGGER</div>
                <div class="rn-name">Customer Birthday</div>
              </div>
            </div>
            <div class="rule-connector">
              <div class="rc-line"></div>
              <div class="rc-dot"></div>
            </div>
            <div class="rule-node condition-node">
              <div class="rn-icon rn-icon-cond">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
              </div>
              <div class="rn-text">
                <div class="rn-type">CONDITION</div>
                <div class="rn-name">Tier is Gold or Platinum</div>
              </div>
              <div class="rn-check">✓</div>
            </div>
            <div class="rule-connector">
              <div class="rc-line"></div>
              <div class="rc-dot"></div>
            </div>
            <div class="rule-node action-node">
              <div class="rn-icon rn-icon-action">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/>
                </svg>
              </div>
              <div class="rn-text">
                <div class="rn-type">ACTION</div>
                <div class="rn-name">Issue $25 Gift Card</div>
              </div>
            </div>
            <div class="rule-connector">
              <div class="rc-line"></div>
              <div class="rc-dot"></div>
            </div>
            <div class="rule-node action-node">
              <div class="rn-icon rn-icon-action">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M12 2l2.5 7h7l-5.5 4.5 2 7L12 16l-6 4.5 2-7L2.5 9h7z"/>
                </svg>
              </div>
              <div class="rn-text">
                <div class="rn-type">ACTION</div>
                <div class="rn-name">+500 Bonus Points</div>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Live preview -->
        <div class="builder-right">
          <div class="br-label">Live Preview</div>
          <div class="br-preview-stat">
            <div class="br-stat-label">Members Eligible</div>
            <div class="br-stat-val">12,840</div>
            <div class="br-stat-delta">↑ 340 from last month</div>
          </div>
          <div class="br-preview-stat">
            <div class="br-stat-label">Est. Monthly Cost</div>
            <div class="br-stat-val">$14,200</div>
            <div class="br-stat-delta">0.8% of LTV</div>
          </div>

          <div class="br-section-title">Recent Events</div>
          {[
            { time: '09:42:01', event: 'birthday.fired', id: 'cus_84kq2x' },
            { time: '09:42:01', event: 'gift_card.issued', id: 'gc_1a2b3c' },
            { time: '09:38:17', event: 'birthday.fired', id: 'cus_zp9m3r' },
            { time: '09:38:17', event: 'points.awarded', id: '+500 pts' },
          ].map(e => (
            <div class="br-event">
              <span class="ev-time">{e.time}</span> <span class="ev-event">{e.event}</span> <span class="ev-id">{e.id}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rules-builder {
    background: var(--bg-alt);
    padding: 120px 32px;
    overflow: hidden;
  }

  .container { max-width: 1280px; margin: 0 auto; }

  .section-header { max-width: 720px; margin-bottom: 64px; }

  .section-eyebrow {
    font-size: 13px;
    font-weight: 700;
    color: var(--purple-deep);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  .section-title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .section-lede { font-size: 19px; color: var(--slate); line-height: 1.55; }

  /* Builder frame */
  .builder-frame {
    background: white;
    border-radius: 20px;
    border: 1px solid var(--line);
    box-shadow: 0 24px 60px -20px rgba(10, 10, 35, 0.12);
    overflow: hidden;
  }

  .builder-toolbar {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--line);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bt-dot { width: 11px; height: 11px; border-radius: 50%; }
  .bt-dot:nth-child(1) { background: #ff8a7a; }
  .bt-dot:nth-child(2) { background: #ffc060; }
  .bt-dot:nth-child(3) { background: #7ef0c5; }

  .bt-title {
    flex: 1;
    text-align: center;
    font-size: 12px;
    color: var(--slate);
    font-weight: 600;
  }

  .bt-mode-switch {
    display: flex;
    gap: 2px;
    background: white;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 3px;
  }

  .bt-mode {
    padding: 5px 12px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 999px;
    cursor: pointer;
    color: var(--slate);
    transition: all 0.2s;
    user-select: none;
  }

  .bt-mode.active { background: var(--ink); color: white; }

  .builder-body {
    display: grid;
    grid-template-columns: 280px 1fr 320px;
    min-height: 540px;
  }

  /* Left panel */
  .builder-left {
    background: var(--bg-alt);
    border-right: 1px solid var(--line);
    padding: 20px;
    overflow-y: auto;
  }

  .bl-section-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--slate-light);
    margin-bottom: 12px;
    margin-top: 20px;
  }

  .bl-section-label:first-child { margin-top: 0; }

  .bl-trigger {
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 6px;
    font-size: 13px;
    cursor: grab;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.2s;
  }

  .bl-trigger:hover {
    border-color: var(--purple);
    transform: translateX(2px);
  }

  .bl-trigger-icon {
    width: 24px;
    height: 24px;
    background: var(--purple-pale);
    color: var(--purple-deep);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bl-trigger-meta { flex: 1; }
  .bl-trigger-name { font-size: 12px; font-weight: 600; color: var(--ink); }
  .bl-trigger-desc { font-size: 11px; color: var(--slate-light); margin-top: 1px; }
  .bl-trigger-grab { color: var(--slate-light); font-size: 14px; letter-spacing: 1px; }

  /* Center canvas */
  .builder-canvas {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: white;
  }

  .canvas-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--slate-light);
  }

  .rule-flow {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .rule-node {
    background: white;
    border: 1.5px solid var(--line);
    border-radius: 12px;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    max-width: 380px;
    box-shadow: 0 4px 12px -4px rgba(10,10,35,0.06);
    transition: box-shadow 0.2s;
  }

  .rule-node:hover { box-shadow: 0 8px 24px -8px rgba(10,10,35,0.12); }

  .trigger-node  { border-color: var(--purple-light); }
  .condition-node { border-color: var(--accent-gold); }
  .action-node   { border-color: var(--accent-mint); }

  .rn-icon {
    width: 32px; height: 32px;
    background: var(--purple-pale);
    color: var(--purple-deep);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .rn-icon-cond   { background: rgba(255,192,96,0.15); color: #b87d00; }
  .rn-icon-action { background: rgba(126,240,197,0.2); color: #1a7a5c; }

  .rn-text { flex: 1; }
  .rn-type { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--slate-light); }
  .rn-name { font-size: 13px; font-weight: 600; color: var(--ink); margin-top: 2px; }

  .rn-check {
    width: 20px; height: 20px;
    background: var(--accent-mint);
    color: var(--ink);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800;
  }

  .rule-connector {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-left: 22px;
    gap: 2px;
    height: 24px;
  }

  .rc-line {
    width: 1px;
    height: 14px;
    background: var(--line);
  }

  .rc-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--purple-deep);
  }

  /* Right panel */
  .builder-right {
    background: var(--ink);
    color: white;
    padding: 20px;
    overflow-y: auto;
  }

  .br-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--purple-light);
    margin-bottom: 16px;
  }

  .br-preview-stat {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 14px;
    margin-bottom: 8px;
  }

  .br-stat-label {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  .br-stat-val {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(180deg, white 0%, var(--purple-light) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .br-stat-delta {
    font-size: 11px;
    color: var(--accent-mint);
    font-weight: 600;
    margin-top: 2px;
  }

  .br-section-title {
    font-size: 13px;
    font-weight: 700;
    margin: 24px 0 10px;
  }

  .br-event {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.8);
    line-height: 1.5;
  }

  .ev-time  { color: var(--purple-light); }
  .ev-event { color: var(--accent-mint); }
  .ev-id    { color: rgba(255,255,255,0.4); }

  @media (max-width: 1024px) {
    .builder-body { grid-template-columns: 1fr; }
    .builder-left, .builder-right { display: none; }
    .rules-builder { padding: 80px 20px; }
  }
</style>

<script>
  document.querySelectorAll('.bt-mode').forEach(mode => {
    mode.addEventListener('click', () => {
      mode.parentElement?.querySelectorAll('.bt-mode').forEach(m => m.classList.remove('active'));
      mode.classList.add('active');
    });
  });
</script>
