---
export interface ComparisonRow {
  feature: string;
  us: string | boolean;
  competitor1: string | boolean;
  competitor2: string | boolean;
  highlight?: boolean;
}

export interface Props {
  eyebrow?: string;
  title?: string;
  lede?: string;
  usLabel?: string;
  competitor1Label?: string;
  competitor2Label?: string;
  rows?: ComparisonRow[];
}

const {
  eyebrow = "Why teams switch from Antavo & Yotpo",
  title = "Loyalty depth without the loyalty silo.",
  lede = "Antavo is a great loyalty platform — that doesn't do gift cards, store credit, or wallet passes. Yotpo bolted loyalty onto a reviews company. We built the whole reward stack from day one.",
  usLabel = "99minds",
  competitor1Label = "Antavo",
  competitor2Label = "Yotpo",
  rows = [
    { feature: "Visual rules builder", us: true, competitor1: true, competitor2: "Templated" },
    { feature: "Programmable via typed configs", us: true, competitor1: "Limited", competitor2: false },
    { feature: "Native gift card issuance", us: true, competitor1: "3rd party", competitor2: "3rd party" },
    { feature: "Store credit & refunds-as-credit", us: true, competitor1: false, competitor2: false },
    { feature: "Apple + Google Wallet passes", us: true, competitor1: false, competitor2: false },
    { feature: "Unified customer ledger", us: true, competitor1: false, competitor2: "Partial" },
    { feature: "Dry-run rules on real data", us: true, competitor1: "Sandbox", competitor2: false },
    { feature: "Time-to-launch", us: "~30 days", competitor1: "3–6 months", competitor2: "~60 days", highlight: true },
  ],
} = Astro.props;

function renderCell(val: string | boolean, isUs = false, isHighlight = false) {
  if (val === true) return `<span class="check-lg">✓</span>`;
  if (val === false) return `<span class="cross-lg">—</span>`;
  if (isUs && isHighlight) return `<span style="font-weight:700;color:var(--purple-deep)">${val}</span>`;
  if (typeof val === 'string' && val !== '✓' && val !== '—') return `<span class="partial-lg">${val}</span>`;
  return val;
}
---

<section class="vs-section">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">{eyebrow}</div>
      <h2 class="section-title">{title}</h2>
      <p class="section-lede">{lede}</p>
    </div>

    <div class="vs-table">
      <div class="vs-grid">
        <div class="vs-cell header"></div>
        <div class="vs-cell header featured">{usLabel}</div>
        <div class="vs-cell header">{competitor1Label}</div>
        <div class="vs-cell header">{competitor2Label}</div>

        {rows.map(row => (
          <>
            <div class="vs-cell vs-row-label">{row.feature}</div>
            <div class="vs-cell featured" set:html={renderCell(row.us, true, row.highlight)} />
            <div class="vs-cell" set:html={renderCell(row.competitor1)} />
            <div class="vs-cell" set:html={renderCell(row.competitor2)} />
          </>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .vs-section {
    background: white;
    padding: 120px 32px;
  }

  .container { max-width: 1280px; margin: 0 auto; }

  .section-header { max-width: 720px; margin-bottom: 64px; }

  .section-eyebrow {
    font-size: 13px; font-weight: 700; color: var(--purple-deep);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px;
  }

  .section-title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700; letter-spacing: -0.03em; line-height: 1.05;
    color: var(--ink); margin-bottom: 20px;
  }

  .section-lede { font-size: 19px; color: var(--slate); line-height: 1.55; }

  .vs-table {
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    background: white;
  }

  .vs-grid {
    display: grid;
    grid-template-columns: 1.8fr repeat(3, 1fr);
  }

  .vs-cell {
    padding: 16px 20px;
    font-size: 14px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
  }

  .vs-cell:last-child { border-right: none; }

  .vs-cell.header {
    font-size: 13px;
    font-weight: 700;
    color: var(--ink);
    background: var(--bg-alt);
    letter-spacing: -0.01em;
  }

  .vs-cell.featured {
    background: rgba(111, 77, 255, 0.04);
  }

  .vs-cell.header.featured {
    background: rgba(111, 77, 255, 0.08);
    color: var(--purple-deep);
  }

  .vs-cell.vs-row-label {
    font-size: 14px;
    color: var(--slate);
    font-weight: 500;
  }

  :global(.check-lg)   { color: var(--purple-deep); font-weight: 700; font-size: 16px; }
  :global(.cross-lg)   { color: var(--slate-light); font-size: 15px; }
  :global(.partial-lg) { color: var(--slate); font-size: 12px; font-weight: 600; }

  @media (max-width: 1024px) {
    .vs-grid { grid-template-columns: 1.4fr repeat(3, 1fr); font-size: 12px; }
    .vs-cell { padding: 12px 14px; }
    .vs-section { padding: 80px 20px; }
  }

  @media (max-width: 640px) {
    .vs-grid { grid-template-columns: 1fr; }
    .vs-cell { border-right: none; }
    .vs-section { padding: 80px 20px; }
  }
</style>
