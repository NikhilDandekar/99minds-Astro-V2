---
import type { StatsBandConfig } from '../config/statsband';
import { homepageStats } from '../config/statsband';

export interface Props {
  config?: StatsBandConfig;
}

const { config = homepageStats } = Astro.props;
const { stats } = config;
---

<div class="py-20 px-8 bg-gradient-to-br from-[var(--purple-deep)] to-[var(--ink)] text-white relative overflow-hidden stats-band-bg">
  <div class="relative max-w-layout mx-auto grid grid-cols-2 lg:grid-cols-4 gap-8 z-10">
    {stats.map(stat => (
      <div>
        <div
          class="text-[56px] font-extrabold tracking-[-0.04em] leading-none mb-3"
          style="background: linear-gradient(180deg, #ffffff 0%, #b8bfff 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">
          {stat.value}
        </div>
        <div class="text-sm text-white/60 leading-relaxed">{stat.label}</div>
      </div>
    ))}
  </div>
</div>
