---
import type { FinalCTAConfig } from '../config/finalcta';
import { homepageCTA } from '../config/finalcta';

export interface Props {
  config?: FinalCTAConfig;
}

const { config = homepageCTA } = Astro.props;
const { titleLead, titleHighlight, titleTail, description, buttons } = config;
---

<div class="py-[120px] px-8 max-sm:py-20 max-sm:px-5 text-center bg-[var(--bg-alt)] relative overflow-hidden">
  <!-- radial glow -->
  <div class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full"
       style="background: radial-gradient(circle, rgba(170,143,255,0.18) 0%, transparent 60%);">
  </div>

  <div class="relative max-w-[720px] mx-auto">
    <h2 class="text-[clamp(36px,5vw,60px)] font-bold tracking-[-0.03em] leading-[1.05] text-[var(--ink)] mb-5">
      {titleLead}<span class="text-[var(--purple-deep)]">{titleHighlight}</span>{titleTail}
    </h2>
    <p class="text-[19px] text-[var(--slate)] leading-[1.55] mb-9">{description}</p>
    <div class="flex gap-3 justify-center flex-wrap">
      {buttons.map(btn => (
        btn.variant === 'ghost'
          ? <a href={btn.href}
               class="font-semibold text-[15px] px-[22px] py-3.5 rounded-full bg-white border border-[var(--line)] text-[var(--ink)] hover:border-[var(--purple-deep)] hover:text-[var(--purple-deep)] transition-all duration-200 no-underline inline-flex items-center">
              {btn.label}
            </a>
          : <a href={btn.href}
               class="font-semibold text-[15px] px-[22px] py-3.5 rounded-full bg-[var(--purple-deep)] text-white hover:bg-[var(--ink)] hover:-translate-y-px transition-all duration-200 no-underline inline-flex items-center">
              {btn.label}
            </a>
      ))}
    </div>
  </div>
</div>
