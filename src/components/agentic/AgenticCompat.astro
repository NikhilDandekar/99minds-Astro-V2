---
---

<section class="bg-white px-8 py-[120px] max-md:px-5 max-md:py-20">
  <div class="mx-auto max-w-[1280px]">

    <!-- Header (centered) -->
    <div class="mx-auto mb-12 max-w-[720px] text-center">
      <div class="mb-4 text-[13px] font-bold uppercase tracking-[0.1em] text-[var(--purple-deep)]">Universal compatibility</div>
      <h2 class="mb-5 font-bold leading-[1.05] tracking-[-0.03em] text-[var(--ink)]" style="font-size: clamp(32px, 4vw, 52px);">
        Works with <em style="font-family: 'Fraunces', Georgia, serif; font-style: italic; font-weight: 500;">every agent stack</em>.
      </h2>
      <p class="text-[19px] leading-[1.55] text-[var(--slate)]">
        Native integrations with the major AI platforms — plus MCP support for everything else, today and tomorrow.
      </p>
    </div>

    <!-- Compat cards -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { label: 'O', bg: 'linear-gradient(135deg, #10a37f, #1a7f64)', name: 'OpenAI',     meta: 'Assistants API · GPT-5 · Operator' },
        { label: 'C', bg: 'linear-gradient(135deg, #d4a373, #b88958)', name: 'Anthropic',  meta: 'Claude · MCP · Agent SDK' },
        { label: 'G', bg: 'linear-gradient(135deg, #4285f4, #34a853)', name: 'Google',     meta: 'Gemini · Vertex AI · Agent Builder' },
        { label: 'P', bg: 'linear-gradient(135deg, #20a4a4, #0a7575)', name: 'Perplexity', meta: 'Shopping · Pages · Agentic search' },
      ].map(c => (
        <div class="cursor-default rounded-[14px] border border-[var(--line)] bg-[var(--bg-alt)] p-6 text-center transition-all hover:-translate-y-1 hover:border-[var(--purple-light)] hover:bg-white hover:shadow-[0_12px_32px_-8px_rgba(111,77,255,0.15)]">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-[14px] border border-[var(--line)] text-[18px] font-extrabold text-white" style={`background: ${c.bg}; font-family: 'Fraunces', Georgia, serif;`}>{c.label}</div>
          <div class="mb-1 text-[14px] font-bold text-[var(--ink)]">{c.name}</div>
          <div class="text-[11px] text-[var(--slate)]">{c.meta}</div>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-[13px] text-[var(--slate)]">
      Plus Vercel AI SDK · LangChain · LangGraph · CrewAI · Microsoft Copilot Studio · IBM watsonx · Open source agents via MCP
    </p>

  </div>
</section>
