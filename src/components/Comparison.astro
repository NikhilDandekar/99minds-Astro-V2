---
import type { ComparisonConfig } from '../config/comparison';
import { homepageComparison } from '../config/comparison';

export interface Props {
  config?: ComparisonConfig;
}

const { config = homepageComparison } = Astro.props;
const { eyebrow, title, lede, usLabel, competitorLabels, rows } = config;

// Grid: feature label col + us col + N competitor cols
const totalCols = 1 + 1 + competitorLabels.length;
const gridCols: Record<number, string> = {
  3: 'md:grid-cols-[1.8fr_1fr_1fr]',
  4: 'md:grid-cols-[1.8fr_1fr_1fr_1fr]',
  5: 'md:grid-cols-[1.8fr_1fr_1fr_1fr_1fr]',
};
const gridClass = gridCols[totalCols] ?? 'md:grid-cols-[1.8fr_repeat(3,1fr)]';

function renderCell(val: string | boolean, highlight = false): string {
  if (val === true)  return `<span class="text-[#2dba7c] font-bold text-lg">&#10003;</span>`;
  if (val === false) return `<span class="text-[#c8c8d8] text-lg">&mdash;</span>`;
  if (highlight)     return `<span class="font-bold text-[#f5a623] text-sm">${val}</span>`;
  return `<span class="text-[#f5a623] text-sm font-semibold">${val}</span>`;
}
---

<section class="py-[120px] px-8 bg-white">
  <div class="max-w-layout mx-auto">

    <!-- Header -->
    <div class="max-w-[720px] mb-16">
      <div class="text-[13px] font-bold text-[var(--purple-deep)] uppercase tracking-[0.1em] mb-4">{eyebrow}</div>
      <h2 class="text-[clamp(32px,4vw,52px)] font-bold tracking-[-0.03em] leading-[1.05] text-[var(--ink)] mb-5">{title}</h2>
      <p class="text-[19px] text-[var(--slate)] leading-[1.55]">{lede}</p>
    </div>

    <!-- Desktop table -->
    <div class={`hidden border border-[var(--line)] rounded-2xl overflow-hidden bg-white md:grid ${gridClass}`}>

      <!-- Header row -->
      <div class="p-5 border-b border-r border-[var(--line)] bg-[var(--bg-alt)]"></div>
      <div class="p-5 border-b border-r-2 border-l-2 border-[var(--purple-deep)] bg-[var(--purple-deep)] text-white text-[13px] font-bold">
        {usLabel}
      </div>
      {competitorLabels.map((label, i) => (
        <div class={`p-5 border-b border-[var(--line)] bg-[var(--bg-alt)] text-[13px] font-bold text-[var(--ink)] ${i < competitorLabels.length - 1 ? 'border-r' : ''}`}>
          {label}
        </div>
      ))}

      <!-- Data rows -->
      {rows.map(row => (
        <>
          <div class="p-5 border-b border-r border-[var(--line)] bg-[var(--line-soft)] text-sm font-semibold text-[var(--ink)]">
            {row.feature}
          </div>
          <div
            class="p-5 border-b border-r-2 border-l-2 border-[var(--purple-deep)] bg-gradient-to-b from-[var(--purple-pale)] to-white text-sm flex items-center"
            set:html={renderCell(row.us, row.highlight)}
          />
          {row.competitors.map((val, i) => (
            <div
              class={`p-5 border-b border-[var(--line)] text-sm flex items-center ${i < row.competitors.length - 1 ? 'border-r' : ''}`}
              set:html={renderCell(val)}
            />
          ))}
        </>
      ))}
    </div>

    <!-- Mobile fallback -->
    <div class="md:hidden space-y-3">
      {rows.map(row => (
        <div class="border border-[var(--line)] rounded-xl p-5 bg-white">
          <div class="font-semibold text-[var(--ink)] mb-3">{row.feature}</div>
          <div class="grid grid-cols-2 gap-2 text-sm">
            <div class="flex items-center gap-2">
              <span class="font-bold text-[var(--purple-deep)]">{usLabel}</span>
              <span set:html={renderCell(row.us, row.highlight)} />
            </div>
            {row.competitors.map((val, i) => (
              <div class="flex items-center gap-2">
                <span class="text-[var(--slate)]">{competitorLabels[i]}</span>
                <span set:html={renderCell(val)} />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
