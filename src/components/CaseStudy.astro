---
import type { CaseStudyConfig } from '../config/casestudy';
import { giftCardCaseStudy } from '../config/casestudy';

export interface Props extends CaseStudyConfig {
  config?: CaseStudyConfig;
}

const { config, ...rest } = Astro.props;
const merged = { ...giftCardCaseStudy, ...rest, ...(config ?? {}) };

const {
  eyebrow,
  title,
  companyLogo,
  quote,
  authorInitials,
  authorName,
  authorRole,
  resultsLabel,
  results = [],
} = merged;
---

<section class="bg-[var(--bg-alt)] px-8 py-[120px] max-md:px-5 max-md:py-20">
  <div class="mx-auto max-w-[1280px]">

    <!-- Section Header -->
    <div class="mx-auto mb-16 max-w-[720px] text-center">
      <div class="mb-4 text-[13px] font-bold uppercase tracking-[0.1em] text-[var(--purple-deep)]">
        {eyebrow}
      </div>

      <h2 class="text-[clamp(32px,4vw,52px)] font-bold leading-[1.05] tracking-[-0.03em] text-[var(--ink)]">
        {title}
      </h2>
    </div>

    <!-- Card -->
    <div
      class="grid overflow-hidden rounded-[24px] border border-[var(--line)] bg-white shadow-[0_24px_60px_-20px_rgba(10,10,35,0.08)] lg:grid-cols-2"
    >

      <!-- Left -->
      <div class="border-b border-[var(--line)] p-14 lg:border-b-0 lg:border-r max-md:p-8">

        <div class="mb-8 text-[13px] font-extrabold tracking-[0.15em] text-[var(--slate-light)]">
          {companyLogo}
        </div>

        <p class="mb-10 text-[22px] font-medium leading-[1.55] tracking-[-0.01em] text-[var(--ink)] max-md:text-[18px]">
          {quote}
        </p>

        <div class="flex items-center gap-4">
          <div
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-[var(--purple-deep)] to-[var(--purple)] text-[14px] font-bold text-white"
          >
            {authorInitials}
          </div>

          <div>
            <div class="text-[15px] font-bold text-[var(--ink)]">
              {authorName}
            </div>

            <div class="mt-0.5 text-[13px] text-[var(--slate)]">
              {authorRole}
            </div>
          </div>
        </div>
      </div>

      <!-- Right -->
      <div class="bg-[#0a0a23] bg-[radial-gradient(circle_at_top_right,rgba(0,212,255,0.2),transparent_60%)] flex flex-col  p-14 max-md:p-8">

        <div class="mb-8 text-[12px] font-bold uppercase tracking-[0.1em] text-[var(--slate-light)]">
          {resultsLabel}
        </div>

        <div class="flex flex-col">
          {results.map((result) => (
            <div
              class="flex flex-col align-left gap-5 border-b border-[var(--line)] py-6 last:border-b-0"
            >
              <div
                class="min-w-[80px] text-[36px] font-extrabold leading-none tracking-[-0.03em] bg-clip-text text-transparent bg-gradient-to-b from-white to-[var(--purple-light)]"
              >
                {result.num}
              </div>

              <div class="text-[14px] leading-[1.5] text-white opacity-60">
                {result.desc}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>