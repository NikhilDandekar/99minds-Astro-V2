---
---
<section class="py-[120px] px-8 max-sm:py-20 max-sm:px-5 bg-[var(--ink)] text-white relative overflow-hidden">

  <!-- radial overlays -->
  <div class="absolute inset-0 pointer-events-none"
       style="background:radial-gradient(ellipse at top right,rgba(170,143,255,0.18) 0%,transparent 50%),radial-gradient(ellipse at bottom left,rgba(0,212,255,0.1) 0%,transparent 50%)">
  </div>

  <div class="relative max-w-[1280px] mx-auto grid grid-cols-1 lg:[grid-template-columns:1fr_1.1fr] gap-16 items-center">

    <!-- left: text + callouts -->
    <div>
      <div class="text-[13px] font-bold text-[var(--purple-light)] uppercase tracking-[0.1em] mb-4">For developers</div>
      <h2 class="text-[clamp(32px,4vw,52px)] font-bold tracking-[-0.03em] leading-[1.05] text-white mb-5">
        Evaluate any cart in
        <span style="background:linear-gradient(120deg,var(--purple-light),var(--accent-cyan));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">
          under 50ms
        </span>.
      </h2>
      <p class="text-[19px] leading-[1.55] mb-8" style="color:rgba(255,255,255,0.65)">
        A single endpoint takes a cart and a customer ID, returns every applicable promotion sorted by best-fit. Idempotent. Edge-deployed. Designed to live inside your checkout's hot path.
      </p>

      <div class="flex flex-col gap-6">
        {[
          {
            icon: '<path d="M13 2L3 14h7l-1 8 10-12h-7z"/>',
            title: 'Edge-deployed evaluation',
            body: 'Multi-region edge nodes mean p50 of 38ms anywhere on Earth. Your checkout never blocks waiting on a promo decision.',
          },
          {
            icon: '<circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/>',
            title: 'Stackable & exclusive logic',
            body: 'Built-in stacking rules. Tier-protected exclusives. No more two coupons accidentally combining for free product.',
          },
          {
            icon: '<path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path d="M12 7v5l3 2"/>',
            title: 'Replay any decision',
            body: 'Every evaluation is logged with the full inputs. Reproduce a customer\'s exact discount calculation months later for audits or disputes.',
          },
        ].map(c => (
          <div class="flex gap-4 items-start">
            <div class="w-9 h-9 rounded-[10px] flex items-center justify-center shrink-0"
                 style="background:rgba(170,143,255,0.15);border:1px solid rgba(170,143,255,0.3);color:var(--purple-light)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={c.icon} />
            </div>
            <div>
              <h4 class="text-[16px] font-bold text-white mb-1">{c.title}</h4>
              <p class="text-[14px] leading-[1.55]" style="color:rgba(255,255,255,0.65)">{c.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- right: code snippet -->
    <div class="rounded-[16px] overflow-hidden border"
         style="background:#1a1a3e;border-color:rgba(255,255,255,0.08);box-shadow:0 24px 60px -20px rgba(0,0,0,0.5)">
      <!-- tabs -->
      <div class="flex gap-[2px] border-b p-1 pb-0" style="background:rgba(0,0,0,0.3);border-color:rgba(255,255,255,0.06)">
        {['Evaluate (Node)', 'Rule (YAML)', 'Webhook'].map((tab, i) => (
          <button class={`px-[14px] py-[10px] font-mono text-[11px] rounded-t-[8px] border-none cursor-pointer transition-all ${i === 0 ? 'bg-[#1a1a3e] text-[var(--purple-light)]' : 'bg-transparent text-white/40'}`}>
            {tab}
          </button>
        ))}
      </div>
      <!-- code body -->
      <div class="px-7 py-6 font-mono text-[12.5px] leading-[1.75] min-h-[380px]" style="color:#e0e0ff">
        <span class="block" style="color:rgba(255,255,255,0.35);font-style:italic">// Evaluate every applicable promo for this cart</span>
        <span class="block"><span style="color:#c4b5fd">const</span> result <span style="color:rgba(255,255,255,0.5)">=</span> <span style="color:#c4b5fd">await</span> client<span style="color:rgba(255,255,255,0.5)">.</span>promotions<span style="color:rgba(255,255,255,0.5)">.</span><span style="color:#82d4ff">evaluate</span><span style="color:rgba(255,255,255,0.5)">(&#123;</span></span>
        <span class="block">  customer<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'cus_8KPq2x'</span><span style="color:rgba(255,255,255,0.5)">,</span></span>
        <span class="block">  cart<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:rgba(255,255,255,0.5)">&#123;</span></span>
        <span class="block">    items<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:rgba(255,255,255,0.5)">[</span></span>
        <span class="block">      <span style="color:rgba(255,255,255,0.5)">&#123;</span> sku<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'LIN-OS-M'</span><span style="color:rgba(255,255,255,0.5)">,</span> price<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#fbbf6e">16500</span><span style="color:rgba(255,255,255,0.5)">,</span> qty<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#fbbf6e">1</span> <span style="color:rgba(255,255,255,0.5)">&#125;,</span></span>
        <span class="block">      <span style="color:rgba(255,255,255,0.5)">&#123;</span> sku<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'WLT-28'</span><span style="color:rgba(255,255,255,0.5)">,</span>   price<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#fbbf6e">14500</span><span style="color:rgba(255,255,255,0.5)">,</span> qty<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#fbbf6e">1</span> <span style="color:rgba(255,255,255,0.5)">&#125;,</span></span>
        <span class="block">      <span style="color:rgba(255,255,255,0.5)">&#123;</span> sku<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'CTOTE'</span><span style="color:rgba(255,255,255,0.5)">,</span>   price<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#fbbf6e">5800</span><span style="color:rgba(255,255,255,0.5)">,</span>  qty<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#fbbf6e">1</span>  <span style="color:rgba(255,255,255,0.5)">&#125;</span></span>
        <span class="block">    <span style="color:rgba(255,255,255,0.5)">],</span></span>
        <span class="block">    currency<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'usd'</span></span>
        <span class="block">  <span style="color:rgba(255,255,255,0.5)">&#125;,</span></span>
        <span class="block">  context<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:rgba(255,255,255,0.5)">&#123;</span> channel<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'web'</span><span style="color:rgba(255,255,255,0.5)">,</span> region<span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'us-east'</span> <span style="color:rgba(255,255,255,0.5)">&#125;</span></span>
        <span class="block"><span style="color:rgba(255,255,255,0.5)">&#125;);</span></span>
        <span class="block">&nbsp;</span>
        <span class="block" style="color:rgba(255,255,255,0.35);font-style:italic">// ✓ 38ms response</span>
        <span class="block"><span style="color:rgba(255,255,255,0.5)">&#123;</span></span>
        <span class="block">  <span style="color:#c4b5fd">applied</span><span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:rgba(255,255,255,0.5)">[&#123;</span></span>
        <span class="block">    <span style="color:#c4b5fd">id</span><span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'promo_spring_refresh'</span><span style="color:rgba(255,255,255,0.5)">,</span></span>
        <span class="block">    <span style="color:#c4b5fd">discount</span><span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#fbbf6e">9200</span><span style="color:rgba(255,255,255,0.5)">,</span> <span style="color:rgba(255,255,255,0.35);font-style:italic">// $92.00</span></span>
        <span class="block">    <span style="color:#c4b5fd">points_bonus</span><span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#fbbf6e">1000</span><span style="color:rgba(255,255,255,0.5)">,</span></span>
        <span class="block">    <span style="color:#c4b5fd">reason</span><span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'Gold tier + spring collection'</span></span>
        <span class="block">  <span style="color:rgba(255,255,255,0.5)">&#125;],</span></span>
        <span class="block">  <span style="color:#c4b5fd">eval_id</span><span style="color:rgba(255,255,255,0.5)">:</span> <span style="color:#7ef0c5">'eval_38xK9q'</span> <span style="color:rgba(255,255,255,0.35);font-style:italic">// for replay/audit</span></span>
        <span class="block"><span style="color:rgba(255,255,255,0.5)">&#125;</span></span>
      </div>
    </div>

  </div>
</section>
