---
---

<section class="py-[120px] px-8 bg-[var(--bg-alt)] overflow-hidden relative">
  <div class="max-w-layout mx-auto">

    <!-- Header -->
    <div class="max-w-[760px] mb-14">
      <div class="text-[13px] font-bold text-[var(--purple-deep)] uppercase tracking-[0.1em] mb-4">The unified platform</div>
      <h2 class="text-[clamp(32px,4vw,52px)] font-bold tracking-[-0.03em] leading-[1.05] text-[var(--ink)]">
        One platform for every reward model.
        <span class="text-[var(--slate)] font-medium tracking-[-0.02em]">
          {' '}Grow your business with a comprehensive set of customer-value tools — designed to work individually or together.
        </span>
      </h2>
    </div>

    <!-- Bento Grid -->
    <div class="bento">

      <!-- TILE 1 (4 cols): Gift Cards & Store Credit -->
      <div class="bento-tile bento-tile-1 bg-white border border-[var(--line)] rounded-card p-7 pb-0 relative overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_50px_-16px_rgba(111,77,255,0.15)] hover:border-[var(--purple-light)]">
        <button class="absolute top-6 right-6 w-7 h-7 bg-[var(--purple-deep)] rounded-[7px] flex items-center justify-center text-white text-sm cursor-pointer z-[5] transition-all duration-200 hover:bg-[var(--ink)] hover:scale-105" aria-label="Expand gift cards">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h5M3 3v5M3 3l5 5M13 13H8M13 13V8M13 13l-5-5"/></svg>
        </button>
        <h3 class="text-xl font-bold tracking-[-0.02em] leading-tight mb-1.5 max-w-[360px]">Issue beautifully branded gift cards — globally, online and in person</h3>
        <p class="text-[13px] text-[var(--slate)] leading-relaxed max-w-[360px] mb-6">eGifts, store credit, refunds-as-credit, and bulk B2B gifting on one PCI-Level-1 ledger.</p>

        <div class="bento-visual-giftcards">
          <!-- Phone -->
          <div class="m-6 ml-8 bg-gradient-to-b from-[#2c2c2e] to-[#1a1a1c] rounded-[28px] p-2 relative z-[2]" style="box-shadow: 0 20px 40px -12px rgba(10,10,35,0.3);">
            <div class="bg-white rounded-[22px] px-4 py-6 text-center relative" style="min-height: 280px;">
              <div class="absolute top-1 left-1/2 -translate-x-1/2 w-14 h-3.5 bg-[#1a1a1c] rounded-[10px]"></div>
              <div class="text-[9px] text-[var(--slate-light)] uppercase tracking-[0.1em] font-semibold mt-3 mb-4">Send an eGift</div>
              <div class="bg-gradient-to-br from-[var(--purple-deep)] via-[var(--purple)] to-[var(--accent-coral)] rounded-xl p-3.5 text-white aspect-[1.6/1] flex flex-col justify-between relative overflow-hidden" style="box-shadow: 0 8px 16px -4px rgba(111,77,255,0.4);">
                <div class="absolute -top-[40%] -right-[20%] w-24 h-24 rounded-full" style="background: radial-gradient(circle, rgba(255,255,255,0.2), transparent 60%);"></div>
                <div class="text-[10px] font-extrabold tracking-[0.16em] text-left opacity-95">NORTHWIND</div>
                <div class="text-[32px] font-bold tracking-[-0.03em] leading-none text-left">$50</div>
                <div class="text-[9px] text-left opacity-90 italic">"Happy birthday, Ada ✨"</div>
              </div>
              <div class="bg-[var(--bg-alt)] rounded-lg px-2.5 py-2 text-[11px] mt-3 flex justify-between items-center">
                <span class="text-[var(--slate-light)] font-semibold">To</span>
                <span class="font-bold text-[var(--ink)]">ada@example.com</span>
              </div>
              <div class="bg-[var(--bg-alt)] rounded-lg px-2.5 py-2 text-[11px] mt-2 flex justify-between items-center">
                <span class="text-[var(--slate-light)] font-semibold">Send</span>
                <span class="font-bold text-[var(--ink)]">Apr 14 · 9:00 AM</span>
              </div>
            </div>
          </div>

          <!-- Checkout sidebar -->
          <div class="p-6 bg-white border-l border-[var(--line)] flex flex-col gap-2.5">
            <div class="flex justify-between items-center text-xs">
              <span class="text-[var(--slate)]">Amount</span>
              <strong class="text-[var(--ink)]">$50.00</strong>
            </div>
            <div class="bg-white border-[1.5px] border-[var(--accent-mint)] rounded-md px-2.5 py-2 text-[11px] text-[var(--ink)] font-mono">$50.00 USD</div>
            <div class="flex justify-between items-center text-xs mt-1.5"><span class="text-[var(--slate)]">Pay with</span></div>
            <div class="flex gap-1">
              <div class="flex-1 bg-[var(--ink)] border border-[var(--ink)] rounded-md py-1.5 px-2 text-center text-[10px] font-semibold text-white">Card</div>
              <div class="flex-1 bg-[var(--bg-alt)] border border-[var(--line)] rounded-md py-1.5 px-2 text-center text-[10px] font-semibold text-[var(--ink)]">Apple Pay</div>
              <div class="flex-1 bg-[var(--bg-alt)] border border-[var(--line)] rounded-md py-1.5 px-2 text-center text-[10px] font-semibold text-[var(--ink)]">Bank</div>
            </div>
            <div class="bg-[var(--bg-alt)] border border-[var(--line)] rounded-md px-2.5 py-2 text-[11px] text-[var(--ink)] font-mono">4242 4242 4242 4242</div>
            <div class="border-t border-dashed border-[var(--line)] my-1"></div>
            <div class="flex justify-between text-xs"><span class="text-[var(--slate)]">Subtotal</span><strong>$50.00</strong></div>
            <div class="flex justify-between text-xs"><span class="text-[var(--slate)]">VAT</span><strong>$0.00</strong></div>
            <div class="flex justify-between text-[13px] font-bold pt-1"><span>Total</span><span>$50.00</span></div>
            <div class="bg-[var(--ink)] text-white text-center py-2.5 rounded-lg text-xs font-bold mt-1">Send eGift →</div>
          </div>
        </div>
      </div>

      <!-- TILE 2: Loyalty Engine -->
      <div class="bento-tile bento-tile-2 bg-white border border-[var(--line)] rounded-card p-7 pb-0 relative overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_50px_-16px_rgba(111,77,255,0.15)] hover:border-[var(--purple-light)]">
        <button class="absolute top-6 right-6 w-7 h-7 bg-[var(--purple-deep)] rounded-[7px] flex items-center justify-center text-white text-sm cursor-pointer z-[5] transition-all duration-200 hover:bg-[var(--ink)]" aria-label="Expand loyalty">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h5M3 3v5M3 3l5 5M13 13H8M13 13V8M13 13l-5-5"/></svg>
        </button>
        <h3 class="text-xl font-bold tracking-[-0.02em] leading-tight mb-1.5">Build loyalty that earns the next purchase</h3>
        <p class="text-[13px] text-[var(--slate)] leading-relaxed mb-6">Tiered programs, points, gamified challenges.</p>

        <div class="bento-visual-loyalty">
          <div class="bg-gradient-to-br from-[#0a0a23] to-[#6f4dff] rounded-[14px] p-[18px] text-white mt-6 relative overflow-hidden" style="box-shadow: 0 12px 28px -10px rgba(10,10,35,0.3);">
            <div class="absolute -top-[30%] -right-[15%] w-[120px] h-[120px] rounded-full" style="background: radial-gradient(circle, rgba(255,192,96,0.25), transparent 60%);"></div>
            <div class="flex justify-between items-start mb-3 relative">
              <div class="text-[11px] font-bold uppercase tracking-[0.12em] opacity-85">Member status</div>
              <div class="bg-gradient-to-br from-[#ffc060] to-[#f5a623] text-[var(--ink)] px-2.5 py-0.5 rounded-full text-[9px] font-extrabold tracking-[0.08em] uppercase">★ Gold</div>
            </div>
            <div class="text-[28px] font-bold tracking-[-0.02em] leading-none mb-0.5 relative">8,420</div>
            <div class="text-[10px] opacity-70 uppercase tracking-[0.08em] font-semibold relative mb-3.5">Reward points</div>
            <div class="relative">
              <div class="flex justify-between text-[10px] mb-1.5">
                <span class="opacity-85">To Platinum</span>
                <span class="opacity-65 font-mono">8.4k / 12.5k</span>
              </div>
              <div class="h-1 bg-white/15 rounded-full overflow-hidden">
                <div class="w-[68%] h-full bg-gradient-to-r from-[#ffc060] to-[#ffe080] rounded-full"></div>
              </div>
            </div>
          </div>
          <div class="bg-white border border-[var(--line)] rounded-[10px] px-3 py-2.5 text-[11px] text-[var(--ink)] flex items-center gap-2 mb-6">
            <div class="w-1.5 h-1.5 rounded-full bg-[var(--accent-mint)] flex-shrink-0"></div>
            <span><strong>2× points weekend</strong> · ends Sunday</span>
          </div>
        </div>
      </div>

      <!-- TILE 3: Referral Engine -->
      <div class="bento-tile bento-tile-3 bg-white border border-[var(--line)] rounded-card p-7 pb-0 relative overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_50px_-16px_rgba(111,77,255,0.15)] hover:border-[var(--purple-light)]">
        <button class="absolute top-6 right-6 w-7 h-7 bg-[var(--purple-deep)] rounded-[7px] flex items-center justify-center text-white text-sm cursor-pointer z-[5] transition-all duration-200 hover:bg-[var(--ink)]" aria-label="Expand referral">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h5M3 3v5M3 3l5 5M13 13H8M13 13V8M13 13l-5-5"/></svg>
        </button>
        <h3 class="text-xl font-bold tracking-[-0.02em] leading-tight mb-1.5">Turn customers into a growth channel</h3>
        <p class="text-[13px] text-[var(--slate)] leading-relaxed mb-6">Branded referral eGifts that beat discount codes.</p>

        <div class="bento-visual-referral">
          <!-- Referrer -->
          <div class="bg-white border-[1.5px] border-[var(--purple-deep)] rounded-xl px-3.5 py-2.5 flex items-center gap-2.5 relative" style="box-shadow: 0 4px 12px -4px rgba(111,77,255,0.2);">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[var(--purple-deep)] to-[var(--purple)] flex items-center justify-center font-extrabold text-[13px] text-white flex-shrink-0">A</div>
            <div class="flex-1 min-w-0">
              <div class="text-xs font-bold">Ada · referrer</div>
              <div class="text-[10px] text-[var(--slate)] mt-px">Sent 3 invites this month</div>
            </div>
            <div class="bg-[var(--purple-pale)] text-[var(--purple-deep)] px-2.5 py-0.5 rounded-full text-[10px] font-extrabold font-mono">+$150</div>
          </div>

          <!-- Friends grid -->
          <div class="grid grid-cols-2 gap-2">
            {[
              { init: 'B', name: 'Bea', colorClass: 'bg-gradient-to-br from-[var(--accent-coral)] to-[#f5a623]', textClass: 'text-[var(--ink)]', status: '✓ Joined', green: true },
              { init: 'C', name: 'Cyrus', colorClass: 'bg-gradient-to-br from-[var(--accent-cyan)] to-[#4a9eff]', textClass: 'text-white', status: '✓ Joined', green: true },
              { init: 'D', name: 'Dani', colorClass: 'bg-gradient-to-br from-[var(--accent-mint)] to-[#1a8c5e]', textClass: 'text-[var(--ink)]', status: '✓ Joined', green: true },
              { init: '+', name: 'Invite more', colorClass: 'bg-[var(--line)]', textClass: 'text-[var(--slate)]', status: '$50 each', green: false, faded: true },
            ].map(f => (
              <div class={`bg-white border border-[var(--line)] rounded-[10px] px-2.5 py-2 flex items-center gap-2 transition-all duration-200 hover:border-[var(--purple-light)] hover:-translate-y-0.5 ${f.faded ? 'opacity-55' : ''}`}>
                <div class={`w-[26px] h-[26px] rounded-full ${f.colorClass} flex items-center justify-center font-extrabold text-[11px] ${f.textClass} flex-shrink-0`}>{f.init}</div>
                <div>
                  <div class={`text-[11px] font-bold ${f.faded ? 'text-[var(--slate)]' : ''}`}>{f.name}</div>
                  <div class={`text-[9px] mt-px ${f.green ? 'text-[#1a8c5e] font-bold' : 'text-[var(--slate)]'}`}>{f.status}</div>
                </div>
              </div>
            ))}
          </div>

          <!-- Total earned -->
          <div class="bg-gradient-to-br from-[var(--ink)] to-[var(--purple-deep)] rounded-[10px] px-3.5 py-2.5 text-white flex items-center justify-between text-[11px] font-semibold">
            <span>Total earned · this quarter</span>
            <span class="font-mono font-extrabold text-[var(--accent-mint)]">$420.00</span>
          </div>
        </div>
      </div>

      <!-- TILE 4: Promotions -->
      <div class="bento-tile bento-tile-4 bg-white border border-[var(--line)] rounded-card p-7 pb-0 relative overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_50px_-16px_rgba(111,77,255,0.15)] hover:border-[var(--purple-light)]">
        <button class="absolute top-6 right-6 w-7 h-7 bg-[var(--purple-deep)] rounded-[7px] flex items-center justify-center text-white text-sm cursor-pointer z-[5] transition-all duration-200 hover:bg-[var(--ink)]" aria-label="Expand promotions">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h5M3 3v5M3 3l5 5M13 13H8M13 13V8M13 13l-5-5"/></svg>
        </button>
        <h3 class="text-xl font-bold tracking-[-0.02em] leading-tight mb-1.5">Run promotions that don't bleed margin</h3>
        <p class="text-[13px] text-[var(--slate)] leading-relaxed mb-6">Rules-based + ML-personalized campaigns.</p>

        <div class="bento-visual-promo">
          <div class="text-[9px] text-[var(--slate-light)] uppercase tracking-[0.08em] font-bold mt-1">When</div>
          <div class="bg-white border border-[var(--line)] rounded-lg px-3 py-2.5 font-mono text-[11px] flex items-center gap-1.5">
            <span class="text-[var(--purple-deep)] font-bold">customer.tier</span>
            <span class="text-[var(--slate-light)]">∈</span>
            <span class="font-semibold">Gold, Platinum</span>
          </div>
          <div class="bg-white border border-[var(--line)] rounded-lg px-3 py-2.5 font-mono text-[11px] flex items-center gap-1.5">
            <span class="text-[var(--purple-deep)] font-bold">cart.value</span>
            <span class="text-[var(--slate-light)]">≥</span>
            <span class="font-semibold">$120</span>
          </div>
          <div class="text-[9px] text-[var(--slate-light)] uppercase tracking-[0.08em] font-bold mt-1">Then</div>
          <div class="bg-gradient-to-r from-[var(--purple-pale)] to-white border-[1.5px] border-[var(--purple-light)] rounded-lg px-3 py-2.5 font-mono text-[11px] flex items-center gap-1.5">
            <span class="text-[var(--purple-deep)] font-bold">discount</span>
            <span class="text-[var(--slate-light)]">=</span>
            <span class="text-[var(--purple-deep)] font-semibold">25% + 2× points</span>
          </div>
        </div>
      </div>

      <!-- TILE 5: Mobile Wallet Passes -->
      <div class="bento-tile bento-tile-5 bg-white border border-[var(--line)] rounded-card p-7 pb-0 relative overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_50px_-16px_rgba(111,77,255,0.15)] hover:border-[var(--purple-light)]">
        <button class="absolute top-6 right-6 w-7 h-7 bg-[var(--purple-deep)] rounded-[7px] flex items-center justify-center text-white text-sm cursor-pointer z-[5] transition-all duration-200 hover:bg-[var(--ink)]" aria-label="Expand wallet">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h5M3 3v5M3 3l5 5M13 13H8M13 13V8M13 13l-5-5"/></svg>
        </button>
        <h3 class="text-xl font-bold tracking-[-0.02em] leading-tight mb-1.5">Live in your customer's wallet</h3>
        <p class="text-[13px] text-[var(--slate)] leading-relaxed mb-6">Apple &amp; Google Wallet passes that update in real time.</p>

        <div class="bento-visual-wallet">
          <div class="bg-gradient-to-br from-[#0a0a23] via-[#6f4dff] to-[#aa8fff] rounded-xl p-4 text-white w-full max-w-[280px] relative overflow-hidden" style="box-shadow: 0 16px 40px -12px rgba(10,10,35,0.4); transform: rotate(-2deg);">
            <div class="absolute -top-[40%] -right-[25%] w-40 h-40 rounded-full" style="background: radial-gradient(circle, rgba(126,240,197,0.2), transparent 60%);"></div>
            <div class="flex justify-between items-start mb-3 relative">
              <div class="text-[10px] font-extrabold tracking-[0.12em] uppercase">NORTHWIND</div>
              <div class="bg-white/20 px-2 py-0.5 rounded-full text-[9px] font-bold">★ GOLD</div>
            </div>
            <div class="text-[28px] font-bold tracking-[-0.02em] leading-none relative">$184.50</div>
            <div class="text-[9px] opacity-70 uppercase tracking-[0.08em] mt-0.5 relative">Store balance · 2,840 pts</div>
            <div class="barcode mt-3"></div>
          </div>
          <div class="absolute bottom-3 right-4 flex gap-1.5 z-[3]">
            <div class="bg-white text-[var(--ink)] px-2.5 py-1 rounded-full text-[9px] font-bold" style="box-shadow: 0 4px 8px -2px rgba(10,10,35,0.2);">Apple</div>
            <div class="bg-white text-[var(--ink)] px-2.5 py-1 rounded-full text-[9px] font-bold" style="box-shadow: 0 4px 8px -2px rgba(10,10,35,0.2);">Google</div>
          </div>
        </div>
      </div>

      <!-- TILE 6 (WIDE): Embed in your platform -->
      <div class="bento-tile bento-tile-6 bg-white border border-[var(--line)] rounded-card p-7 pb-0 relative overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_50px_-16px_rgba(111,77,255,0.15)] hover:border-[var(--purple-light)]">
        <button class="absolute top-6 right-6 w-7 h-7 bg-[var(--purple-deep)] rounded-[7px] flex items-center justify-center text-white text-sm cursor-pointer z-[5] transition-all duration-200 hover:bg-[var(--ink)]" aria-label="Expand embed">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h5M3 3v5M3 3l5 5M13 13H8M13 13V8M13 13l-5-5"/></svg>
        </button>
        <h3 class="text-xl font-bold tracking-[-0.02em] leading-tight mb-1.5">Embed rewards anywhere in your platform</h3>
        <p class="text-[13px] text-[var(--slate)] leading-relaxed mb-6">One API. One ledger. One contract. Drop in checkout, mobile, in-store POS, or your own AI assistant.</p>

        <div class="bento-visual-embed">
          <!-- Receipt card -->
          <div class="bg-white border border-[var(--line)] rounded-xl p-[18px] m-6 ml-0" style="box-shadow: 0 8px 20px -8px rgba(10,10,35,0.1); align-self: center; z-index: 2;">
            <div class="flex items-center gap-2.5 mb-3.5 pb-3 border-b border-[var(--line)]">
              <div class="w-8 h-8 bg-gradient-to-br from-[var(--purple-deep)] to-[var(--purple)] rounded-lg flex items-center justify-center text-white font-extrabold text-sm">N</div>
              <div>
                <div class="text-xs font-bold text-[var(--ink)]">Northwind</div>
                <div class="text-[10px] text-[var(--slate)] mt-px">Order #NW-08420 · Apr 14</div>
              </div>
            </div>
            <div class="flex justify-between py-1.5 text-[11px] text-[var(--slate)]"><span>Heavyweight Hoodie</span><strong class="text-[var(--ink)]">$78.00</strong></div>
            <div class="flex justify-between py-1.5 text-[11px] text-[var(--slate)]"><span>Gold tier discount</span><strong class="text-[#1a8c5e]">−$11.70</strong></div>
            <div class="flex justify-between py-1.5 text-[11px] text-[var(--slate)]"><span>Store credit</span><strong class="text-[#1a8c5e]">−$42.50</strong></div>
            <div class="border-t border-dashed border-[var(--line)] my-1.5"></div>
            <div class="flex justify-between text-[13px] font-bold py-1 text-[var(--ink)]"><span>Total</span><span>$23.80</span></div>
            <div class="bg-[var(--purple-pale)] rounded-lg px-2.5 py-2 text-[10px] text-[var(--purple-deep)] mt-2 flex items-center gap-1.5 font-semibold">
              <span class="font-extrabold">99</span>
              Paid · 99minds reward stack applied
            </div>
          </div>

          <!-- Customer table -->
          <div class="bg-white border border-[var(--line)] border-l-0 rounded-r-xl overflow-hidden m-6 mr-0" style="align-self: center; box-shadow: 0 8px 20px -8px rgba(10,10,35,0.06);">
            <div class="bg-[var(--bg-alt)] border-b border-[var(--line)] px-4 py-3 flex items-center gap-2 text-[11px] text-[var(--slate)] font-mono">
              <div class="w-2 h-2 rounded-full bg-[#ff8a7a]"></div>
              <div class="w-2 h-2 rounded-full bg-[#ffc060]"></div>
              <div class="w-2 h-2 rounded-full bg-[#7ef0c5]"></div>
              <span class="ml-2">app.99minds.com/customers</span>
            </div>
            <div class="px-4 py-3.5 text-[13px] font-bold text-[var(--ink)]">Connected customer ledger</div>
            <div class="grid grid-cols-4 px-4 py-2 text-[9px] text-[var(--slate-light)] font-bold uppercase tracking-[0.06em] bg-[var(--bg-alt)] border-t border-[var(--line)]">
              <span>Customer</span><span>Country</span><span>Balance</span><span class="text-right">Lifetime Spend</span>
            </div>
            {[
              { init: 'A', name: 'Ada Lovelace', country: 'United States', balance: '$184.50', spend: '$8,348.00', color: 'bg-[var(--purple-pale)] text-[var(--purple-deep)]' },
              { init: 'B', name: 'Bea Holloway', country: 'United Kingdom', balance: '$42.10', spend: '$3,210.50', color: 'bg-[rgba(255,138,122,0.15)] text-[var(--accent-coral)]' },
              { init: 'C', name: 'Cyrus Patel', country: 'Canada', balance: '$0.00', spend: '$1,602.20', color: 'bg-[rgba(126,240,197,0.18)] text-[#1a8c5e]' },
              { init: 'D', name: 'Dani Romero', country: 'Australia', balance: '$320.00', spend: '$12,894.00', color: 'bg-[rgba(0,212,255,0.15)] text-[var(--accent-cyan)]' },
              { init: 'E', name: 'Eli Chen', country: 'United States', balance: '$58.00', spend: '$2,948.30', color: 'bg-[rgba(255,192,96,0.18)] text-[#b8821a]' },
              { init: 'F', name: 'Folio Studio', country: 'United States', balance: '$1,400.00', spend: '$28,612.40', color: 'bg-[var(--purple-pale)] text-[var(--purple-deep)]' },
            ].map(row => (
              <div class="grid grid-cols-4 px-4 py-2.5 border-t border-[var(--line)] text-[11px] items-center">
                <span class="flex items-center gap-2 font-bold text-[var(--ink)]">
                  <span class={`w-[18px] h-[18px] rounded-[4px] ${row.color} font-extrabold text-[9px] flex items-center justify-center flex-shrink-0`}>{row.init}</span>
                  {row.name}
                </span>
                <span class="text-[var(--slate)]">{row.country}</span>
                <span class="font-mono font-bold text-[var(--ink)]">{row.balance}</span>
                <span class="font-mono font-bold text-[var(--ink)] text-right">{row.spend}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div><!-- /bento -->
  </div>
</section>
