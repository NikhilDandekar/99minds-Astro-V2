---
const features = [
  {
    icon: `<path d="M13 2L3 14h7l-1 8 10-12h-7z"/>`,
    title: '142ms median latency',
    desc: 'Multi-region edge deployment. Reward issuance, balance lookup, and redemption never block your checkout.',
  },
  {
    icon: `<path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/>`,
    title: 'SOC 2, PCI-DSS, GDPR',
    desc: 'Audited annually. Card data tokenized at rest and in transit. Bring your own KMS keys for tier-1 compliance.',
  },
  {
    icon: `<path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/>`,
    title: 'Global by default',
    desc: '140+ currencies. Multi-region data residency. Localized pass artwork for Apple and Google Wallet.',
  },
  {
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/>`,
    title: 'One unified ledger',
    desc: 'Gift card balance, points, store credit — all reconciled in one accounting backbone. Double-entry, audit-ready.',
  },
  {
    icon: `<path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path d="M12 6v6l4 2"/>`,
    title: 'Realtime webhooks',
    desc: 'Subscribe to 60+ event types. At-least-once delivery, signed payloads, automatic retries with exponential backoff.',
  },
  {
    icon: `<path d="M4 7h16M4 12h16M4 17h10"/>`,
    title: 'No-code rule builder',
    desc: 'Marketing builds and ships campaigns without engineering. Visual editor compiles to the same engine your devs use.',
  },
];
---

<section class="features-section py-[120px] px-8 bg-[var(--ink)] text-white overflow-hidden relative">
  <div class="max-w-layout mx-auto relative">
    <div class="max-w-[720px] mb-16">
      <div class="text-[13px] font-bold text-[var(--purple-light)] uppercase tracking-[0.1em] mb-4">Built for scale</div>
      <h2 class="text-[clamp(32px,4vw,52px)] font-bold tracking-[-0.03em] leading-[1.05] text-white mb-5">Enterprise infrastructure, developer ergonomics.</h2>
      <p class="text-[19px] text-white/65 leading-[1.55]">
        The plumbing that lets you process millions of rewards a day without thinking about it.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(f => (
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-[16px] p-7 transition-all duration-300 hover:bg-white/[0.06] hover:border-[var(--purple)]/30 hover:-translate-y-0.5">
          <div class="w-11 h-11 bg-gradient-to-br from-[var(--purple)] to-[var(--purple-deep)] rounded-[11px] flex items-center justify-center mb-5 text-white">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={f.icon} />
          </div>
          <h3 class="text-[18px] font-bold tracking-[-0.01em] mb-2.5">{f.title}</h3>
          <p class="text-sm text-white/65 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
