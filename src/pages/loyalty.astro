---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Breadcrumb from '../components/loyalty/Breadcrumb.astro';
import ProductHero from '../components/loyalty/ProductHero.astro';
import TrustBar from '../components/TrustBar.astro';
import RulesBuilder from '../components/loyalty/RulesBuilder.astro';
import CapabilityRows from '../components/CapabilityRows.astro';
import { loyaltyCapabilityRows } from '../config/capabilityrows';
import DeveloperSection from '../components/DeveloperSection.astro';
import { loyaltyDeveloper } from '../config/developersection';
import UnifiedMoat from '../components/loyalty/UnifiedMoat.astro';
import Comparison from '../components/Comparison.astro';
import { loyaltyComparison } from '../config/comparison';
import StatsBand from '../components/StatsBand.astro';
import { loyaltyStats } from '../config/statsband';
import CaseStudy from '../components/CaseStudy.astro';
import { loyaltyCaseStudy } from '../config/casestudy';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { loyaltyCTA } from '../config/finalcta';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Loyalty Engine — 99minds"
  description="A visual rules builder for marketers. A programmable engine for developers. The same loyalty platform — finally aligned."
>
  <Nav />

  <Breadcrumb
    items={[
      { label: 'Products', href: '/products' },
      { label: 'Loyalty Engine' },
    ]}
  />
  <ProductHero
    pill="Loyalty Engine"
    title="Loyalty that"
    titleGradient="marketing ships"
    lede="A visual rules builder for marketers. A programmable engine for developers. The same loyalty platform — finally aligned."
    primaryCta={{ label: 'Start free trial →', href: '#' }}
    secondaryCta={{ label: 'Try the rules builder', href: '#' }}
    features={[
      { text: 'Launch your first program in <strong>under 30 days</strong> — Antavo takes a quarter, Yotpo isn\'t built for it' },
      { text: 'One ledger across <strong>points, gift card balance, and store credit</strong> — not three' },
      { text: 'Visual builder marketing <strong>actually uses</strong> — not a glorified Zapier' },
    ]}
  />

  <TrustBar />

  <RulesBuilder />

  <CapabilityRows rows={loyaltyCapabilityRows} />

  <DeveloperSection config={loyaltyDeveloper} />

  <UnifiedMoat />

  <Comparison config={loyaltyComparison} />

  <StatsBand config={loyaltyStats} />

  <CaseStudy config={loyaltyCaseStudy} />

  <FAQ />

  <FinalCTA config={loyaltyCTA} />

  <Footer />
</Layout>
