---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import GiftCardHero from '../components/giftcard/GiftCardHero.astro';
import GiftCardCapabilities from '../components/giftcard/GiftCardCapabilities.astro';
import CardDesigner from '../components/giftcard/CardDesigner.astro';
import DeveloperSection from '../components/DeveloperSection.astro';
import { giftCardDeveloper } from '../config/developersection';
import FraudCompliance from '../components/giftcard/FraudCompliance.astro';
import TrustBar from '../components/loyalty/TrustBar.astro';
import { giftCardTrustItems } from '../config/trustbar';
import Comparison from '../components/Comparison.astro';
import { giftCardComparison } from '../config/comparison';
import StatsBand from '../components/StatsBand.astro';
import { giftCardStats } from '../config/statsband';
import CaseStudy from "../components/CaseStudy.astro";
import FAQ from "../components/FAQ.astro";
import FinalCTA from '../components/FinalCTA.astro';
import { giftCardCTA } from '../config/finalcta';

const GiftCardFAQ = [
  {
    question: 'Can I generate branded invoices?',
    answer:
      'Yes. Add your logo, company details, tax settings, and payment terms.',
    open: true,
  },
  {
    question: 'Does it support GST invoices?',
    answer:
      'Yes. You can generate GST-compliant invoices with tax breakdowns.',
  },
  {
    question: 'Can I download invoices as PDF?',
    answer:
      'Absolutely. Invoices can be exported instantly as PDF files.',
  },
];
---

<Layout title="Gift Cards & eGifts -- 99minds">
  <Nav />

  <GiftCardHero />
  <TrustBar items={giftCardTrustItems} />
  <CardDesigner />
  <GiftCardCapabilities />
  <DeveloperSection config={giftCardDeveloper} />
  <FraudCompliance />

  <Comparison config={giftCardComparison} />

  <StatsBand config={giftCardStats} />

  <CaseStudy />

  <FAQ
    eyebrow="Invoice Generator FAQ"
    title="Everything you need to know."
    items={GiftCardFAQ}
  />

  <FinalCTA config={giftCardCTA} />

  <Footer />
</Layout>