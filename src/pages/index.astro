---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import LogoWall from '../components/LogoWall.astro';
import UnifiedPlatform from '../components/UnifiedPlatform.astro';
import Features from '../components/Features.astro';
import Comparison from '../components/Comparison.astro';
import { homepageComparison } from '../config/comparison';
import Developers from '../components/Developers.astro';
import Industries from '../components/Industries.astro';
import StatsBand from '../components/StatsBand.astro';
import { homepageStats } from '../config/statsband';
import Testimonial from '../components/Testimonial.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { homepageCTA } from '../config/finalcta';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <Hero />
  <LogoWall />
  <UnifiedPlatform />
  <Features />
  <Comparison config={homepageComparison} />
  <Developers />
  <Industries />
  <StatsBand config={homepageStats} />
  <Testimonial />
  <FinalCTA config={homepageCTA} />
  <Footer />
</Layout>
